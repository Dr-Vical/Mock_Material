<Window x:Class="RswareDesign.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:Fluent="urn:fluent-ribbon"
        xmlns:avalonDock="clr-namespace:AvalonDock;assembly=AvalonDock"
        xmlns:avalonDockLayout="clr-namespace:AvalonDock.Layout;assembly=AvalonDock"
        xmlns:avalonDockTheme="clr-namespace:AvalonDock.Themes;assembly=AvalonDock.Themes.VS2013"
        xmlns:avalonDockControls="clr-namespace:AvalonDock.Controls;assembly=AvalonDock"
        xmlns:views="clr-namespace:RswareDesign.Views"
        xmlns:vm="clr-namespace:RswareDesign.ViewModels"
        Title="{Binding Title}"
        Width="1920" Height="1080"
        WindowState="Maximized"
        Background="{DynamicResource BackgroundBrush}"
        TextElement.Foreground="{DynamicResource TextPrimary}"
        TextElement.FontFamily="{DynamicResource FontFamilyUI}"
        TextElement.FontSize="{DynamicResource FontSizeMD}">

    <Window.DataContext>
        <vm:MainWindowViewModel />
    </Window.DataContext>

    <!-- Style Dictionary: Colors.xaml → Fonts.xaml → Styles.xaml → Buttons.xaml -->

    <DockPanel LastChildFill="True">

        <!-- ═══════════════════════════════════════════════════ -->
        <!--  RIBBON MENU (Top) + Quick Actions overlay          -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Grid DockPanel.Dock="Top">
            <Fluent:Ribbon AutomaticStateManagement="True">

                <!-- ══════════════════════════════════════════════════════ -->
                <!--  [File] Tab                                            -->
                <!-- ══════════════════════════════════════════════════════ -->
                <Fluent:RibbonTabItem Header="File" KeyTip="F" Margin="4,0,0,0">
                    <Fluent:RibbonGroupBox Header="File">
                        <Button Style="{StaticResource RibbonLargeRipple}">
                            <StackPanel HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="FileDocumentPlus" Style="{StaticResource RibbonIconOpacityPulse}" />
                                <TextBlock Text="New" Style="{StaticResource RibbonButtonLabel}" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource RibbonLargeRipple}">
                            <StackPanel HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="FolderOpen" Style="{StaticResource RibbonIconOpacityPulse}" />
                                <TextBlock Text="Open" Style="{StaticResource RibbonButtonLabel}" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource RibbonLargeRipple}" Command="{Binding SaveParametersCommand}">
                            <StackPanel HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="ContentSave" Style="{StaticResource RibbonIconOpacityPulse}" />
                                <TextBlock Text="Save" Style="{StaticResource RibbonButtonLabel}" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource RibbonLargeRipple}">
                            <StackPanel HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="ContentSaveEdit" Style="{StaticResource RibbonIconOpacityPulse}" />
                                <TextBlock Text="Save As" Style="{StaticResource RibbonButtonLabel}" />
                            </StackPanel>
                        </Button>
                    </Fluent:RibbonGroupBox>
                    <Fluent:RibbonGroupBox Header="Print">
                        <Button Style="{StaticResource RibbonLargeRipple}">
                            <StackPanel HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="Printer" Style="{StaticResource RibbonIconOpacityPulse}" />
                                <TextBlock Text="Print" Style="{StaticResource RibbonButtonLabel}" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource RibbonLargeRipple}">
                            <StackPanel HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="FileDocumentEdit" Style="{StaticResource RibbonIconOpacityPulse}" />
                                <TextBlock Text="Page Setup" Style="{StaticResource RibbonButtonLabel}" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource RibbonLargeRipple}">
                            <StackPanel HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="PrinterSettings" Style="{StaticResource RibbonIconOpacityPulse}" />
                                <TextBlock Text="Print Setup" Style="{StaticResource RibbonButtonLabel}" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource RibbonLargeRipple}" Command="{Binding ExitAppCommand}">
                            <StackPanel HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="ExitToApp" Style="{StaticResource RibbonIconShake}" />
                                <TextBlock Text="Exit" Style="{StaticResource RibbonButtonLabel}" />
                            </StackPanel>
                        </Button>
                    </Fluent:RibbonGroupBox>
                </Fluent:RibbonTabItem>

                <!-- ══════════════════════════════════════════════════════ -->
                <!--  [Tools] Tab                                           -->
                <!-- ══════════════════════════════════════════════════════ -->
                <Fluent:RibbonTabItem Header="Tools" KeyTip="T">
                    <Fluent:RibbonGroupBox Header="Scan">
                        <Button Style="{StaticResource RibbonLargeRipple}" Command="{Binding RescanCommand}">
                            <StackPanel HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="Refresh" Style="{StaticResource RibbonIconOpacityPulse}" />
                                <TextBlock Text="ReScan" Style="{StaticResource RibbonButtonLabel}" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource RibbonLargeRipple}">
                            <StackPanel HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="CogRefresh" Style="{StaticResource RibbonIconOpacityPulse}" />
                                <TextBlock Text="ReScan Option" Style="{StaticResource RibbonButtonLabel}" />
                            </StackPanel>
                        </Button>
                    </Fluent:RibbonGroupBox>
                    <Fluent:RibbonGroupBox Header="Communication">
                        <Button Style="{StaticResource RibbonLargeRipple}">
                            <StackPanel HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="SerialPort" Style="{StaticResource RibbonIconOpacityPulse}" />
                                <TextBlock Text="Com Setting" Style="{StaticResource RibbonButtonLabel}" />
                            </StackPanel>
                        </Button>
                    </Fluent:RibbonGroupBox>
                </Fluent:RibbonTabItem>

                <!-- ══════════════════════════════════════════════════════ -->
                <!--  [Views] Tab (Default Selected)                        -->
                <!-- ══════════════════════════════════════════════════════ -->
                <Fluent:RibbonTabItem Header="Views" KeyTip="V" IsSelected="True">
                    <Fluent:RibbonGroupBox Header="Panels">
                        <ToggleButton Style="{StaticResource RibbonLargeRippleToggle}" IsChecked="{Binding IsDriveTreeVisible, Mode=TwoWay}">
                            <StackPanel HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="FileTree" Style="{StaticResource RibbonIconOpacityPulse}" />
                                <TextBlock Text="DriveTree" Style="{StaticResource RibbonButtonLabel}" />
                            </StackPanel>
                        </ToggleButton>
                        <ToggleButton Style="{StaticResource RibbonLargeRippleToggle}" IsChecked="{Binding IsMainPanelVisible, Mode=TwoWay}">
                            <StackPanel HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="ViewDashboard" Style="{StaticResource RibbonIconOpacityPulse}" />
                                <TextBlock Text="Main Panel" Style="{StaticResource RibbonButtonLabel}" />
                            </StackPanel>
                        </ToggleButton>
                        <ToggleButton Style="{StaticResource RibbonLargeRippleToggle}" IsChecked="{Binding IsActionPanelVisible, Mode=TwoWay}">
                            <StackPanel HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="FormatListChecks" Style="{StaticResource RibbonIconOpacityPulse}" />
                                <TextBlock Text="Action Panel" Style="{StaticResource RibbonButtonLabel}" />
                            </StackPanel>
                        </ToggleButton>
                        <ToggleButton Style="{StaticResource RibbonLargeRippleToggle}" IsChecked="{Binding IsErrorLogVisible, Mode=TwoWay}">
                            <StackPanel HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="AlertCircleOutline" Style="{StaticResource RibbonIconOpacityPulse}" />
                                <TextBlock Text="Error Log" Style="{StaticResource RibbonButtonLabel}" />
                            </StackPanel>
                        </ToggleButton>
                    </Fluent:RibbonGroupBox>
                    <Fluent:RibbonGroupBox Header="Theme">
                        <!-- Theme (Dark/Gray/Light) -->
                        <StackPanel VerticalAlignment="Center" Width="120" Margin="4,2" ClipToBounds="True">
                            <TextBlock Text="Theme" Style="{StaticResource RibbonInlineLabel}" />
                            <ComboBox Style="{StaticResource RibbonDarkComboBox}"
                                      ItemsSource="{Binding AvailableThemes}"
                                      SelectedItem="{Binding SelectedTheme, Mode=TwoWay}" />
                        </StackPanel>
                        <!-- Font Size -->
                        <StackPanel VerticalAlignment="Center" Width="58" Margin="4,2" ClipToBounds="True">
                            <TextBlock Text="Font" Style="{StaticResource RibbonInlineLabel}" />
                            <ComboBox Style="{StaticResource RibbonDarkComboBox}"
                                      ItemsSource="{Binding AvailableFontSizes}"
                                      SelectedItem="{Binding SelectedFontSize, Mode=TwoWay}" />
                        </StackPanel>
                        <!-- Color (Hue Slider) -->
                        <StackPanel VerticalAlignment="Center" Width="110" Margin="4,2" ClipToBounds="True">
                            <TextBlock Text="Color" Style="{StaticResource RibbonInlineLabel}" />
                            <Slider Style="{StaticResource HueSliderStyle}"
                                    Minimum="0" Maximum="360"
                                    Value="{Binding HueValue, Mode=TwoWay}" />
                        </StackPanel>
                        <!-- Saturation Slider -->
                        <StackPanel VerticalAlignment="Center" Width="110" Margin="4,2" ClipToBounds="True">
                            <TextBlock Text="Saturation" Style="{StaticResource RibbonInlineLabel}" TextTrimming="CharacterEllipsis" />
                            <Slider Style="{StaticResource SaturationSliderStyle}"
                                    Minimum="0" Maximum="100"
                                    Value="{Binding SaturationValue, Mode=TwoWay}" />
                        </StackPanel>
                        <!-- 한영 Toggle -->
                        <StackPanel VerticalAlignment="Center" Width="46" Margin="8,2,4,2" ClipToBounds="True">
                            <TextBlock Text="Lang" Style="{StaticResource RibbonInlineLabel}" />
                            <ToggleButton IsChecked="{Binding IsKorean, Mode=TwoWay}"
                                          OverridesDefaultStyle="True"
                                          Cursor="Hand" Focusable="False"
                                          MinWidth="36" Height="18">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Bd"
                                                Background="{DynamicResource SurfaceVariantBrush}"
                                                BorderBrush="{DynamicResource BorderDefault}"
                                                BorderThickness="1" CornerRadius="2" Padding="4,1">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Bd" Property="Background"
                                                        Value="{DynamicResource RibbonButton.CheckedBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background"
                                                        Value="{DynamicResource RibbonButton.HoverBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <TextBlock FontSize="{DynamicResource FontSizeXS}"
                                           Foreground="{DynamicResource TextPrimary}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="EN" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsKorean}" Value="True">
                                                    <Setter Property="Text" Value="KR" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </ToggleButton>
                        </StackPanel>
                    </Fluent:RibbonGroupBox>
                </Fluent:RibbonTabItem>

                <!-- ══════════════════════════════════════════════════════ -->
                <!--  [Help] Tab                                            -->
                <!-- ══════════════════════════════════════════════════════ -->
                <Fluent:RibbonTabItem Header="Help" KeyTip="H">
                    <Fluent:RibbonGroupBox Header="Info">
                        <Button Style="{StaticResource RibbonLargeRipple}">
                            <StackPanel HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="ClipboardTextOutline" Style="{StaticResource RibbonIconOpacityPulse}" />
                                <TextBlock Text="Release List" Style="{StaticResource RibbonButtonLabel}" />
                            </StackPanel>
                        </Button>
                    </Fluent:RibbonGroupBox>
                    <Fluent:RibbonGroupBox Header="About">
                        <StackPanel VerticalAlignment="Center" Margin="{StaticResource Padding.RibbonInline}">
                            <TextBlock Text="Version" Style="{StaticResource RibbonInlineLabel}" />
                            <TextBlock Text="Rsware 1.2.1"
                                       Foreground="{DynamicResource TextPrimary}"
                                       FontSize="{DynamicResource FontSizeSM}"
                                       FontFamily="{DynamicResource FontFamilyUI}" />
                        </StackPanel>
                    </Fluent:RibbonGroupBox>
                </Fluent:RibbonTabItem>

                <!-- ══════════════════════════════════════════════════════ -->
                <!--  [Admin Option] Tab — password protected                -->
                <!-- ══════════════════════════════════════════════════════ -->
                <Fluent:RibbonTabItem Header="Admin Option" KeyTip="A">
                    <Fluent:RibbonGroupBox Header="Settings">
                        <Button Style="{StaticResource RibbonLargeRipple}" Command="{Binding AdminMotorDbCommand}">
                            <StackPanel HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="DatabaseCog" Style="{StaticResource RibbonIconOpacityPulse}" />
                                <TextBlock Text="Motor DB" Style="{StaticResource RibbonButtonLabel}" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource RibbonLargeRipple}" Command="{Binding AdminParamSettingCommand}">
                            <StackPanel HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="TuneVertical" Style="{StaticResource RibbonIconOpacityPulse}" />
                                <TextBlock Text="Param Setting" Style="{StaticResource RibbonButtonLabel}" />
                            </StackPanel>
                        </Button>
                    </Fluent:RibbonGroupBox>
                </Fluent:RibbonTabItem>

            </Fluent:Ribbon>

            <!-- ═══════════════════════════════════════════════════ -->
            <!--  QUICK ACTIONS (overlay, right side of ribbon)     -->
            <!-- ═══════════════════════════════════════════════════ -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Margin="0,0,8,16">
                <!-- Enable (fixed green icon — special case, only these 3 buttons) -->
                <Button Style="{StaticResource QuickActionButton}" Command="{Binding EnableCommand}"
                        Padding="10,6" MinHeight="38">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Play"
                                                 Width="22" Height="22"
                                                 VerticalAlignment="Center"
                                                 Foreground="{DynamicResource SuccessBrush}">
                            <materialDesign:PackIcon.Effect>
                                <DropShadowEffect Color="{Binding Color, Source={StaticResource SuccessBrush}}" ShadowDepth="0" BlurRadius="8" Opacity="0.6" />
                            </materialDesign:PackIcon.Effect>
                        </materialDesign:PackIcon>
                        <TextBlock Text="Enable" Style="{StaticResource QuickActionLabel}"
                                   FontSize="{DynamicResource FontSizeSM}" Margin="8,0,0,0" />
                    </StackPanel>
                </Button>
                <!-- Disable All (fixed red icon — special case) -->
                <Button Style="{StaticResource QuickActionButton}" Command="{Binding DisableAllCommand}"
                        Padding="10,6" MinHeight="38">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Stop"
                                                 Width="22" Height="22"
                                                 VerticalAlignment="Center"
                                                 Foreground="{DynamicResource ErrorBrush}">
                            <materialDesign:PackIcon.Effect>
                                <DropShadowEffect Color="{Binding Color, Source={StaticResource ErrorBrush}}" ShadowDepth="0" BlurRadius="8" Opacity="0.6" />
                            </materialDesign:PackIcon.Effect>
                        </materialDesign:PackIcon>
                        <TextBlock Text="Disable All" Style="{StaticResource QuickActionLabel}"
                                   FontSize="{DynamicResource FontSizeSM}" Margin="8,0,0,0" />
                    </StackPanel>
                </Button>
                <!-- Separator -->
                <Rectangle Width="1" Height="24" Fill="{DynamicResource DividerBrush}" Margin="10,0" VerticalAlignment="Center" />
                <!-- Clear Fault All (fixed amber icon — special case) -->
                <Button Style="{StaticResource QuickActionButton}" Command="{Binding ClearFaultAllCommand}"
                        Padding="10,6" MinHeight="38">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AlertRemove"
                                                 Width="22" Height="22"
                                                 VerticalAlignment="Center"
                                                 Foreground="{DynamicResource WarningBrush}">
                            <materialDesign:PackIcon.Effect>
                                <DropShadowEffect Color="{Binding Color, Source={StaticResource WarningBrush}}" ShadowDepth="0" BlurRadius="8" Opacity="0.6" />
                            </materialDesign:PackIcon.Effect>
                        </materialDesign:PackIcon>
                        <TextBlock Text="Clear Fault All" Style="{StaticResource QuickActionLabel}"
                                   FontSize="{DynamicResource FontSizeSM}" Margin="8,0,0,0" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ═══════════════════════════════════════════════════ -->
        <!--  STATUS BAR (Bottom)                                -->
        <!-- ═══════════════════════════════════════════════════ -->
        <StatusBar DockPanel.Dock="Bottom"
                   Background="{DynamicResource StatusBarBrush}"
                   Foreground="{DynamicResource StatusBarForeground}"
                   Height="{DynamicResource Size.StatusBarHeight}">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Margin="0,0,6,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{DynamicResource ErrorBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="Fill" Value="{DynamicResource SuccessBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding ConnectionStatus}" />
                </StackPanel>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="{Binding DriveInfo}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="{Binding ModeInfo}" />
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="{Binding SelectedPort}" />
            </StatusBarItem>
        </StatusBar>

        <!-- ═══════════════════════════════════════════════════ -->
        <!--  AVALONDOCK MAIN LAYOUT (Center)                    -->
        <!-- ═══════════════════════════════════════════════════ -->
        <avalonDock:DockingManager x:Name="dockManager">
            <avalonDock:DockingManager.Theme>
                <avalonDockTheme:Vs2013DarkTheme />
            </avalonDock:DockingManager.Theme>
            <!-- Hide document tab strip (single document, no tabs needed) -->
            <avalonDock:DockingManager.Resources>
                <Style TargetType="{x:Type avalonDockControls:LayoutDocumentTabItem}">
                    <Setter Property="Visibility" Value="Collapsed" />
                </Style>
            </avalonDock:DockingManager.Resources>

            <avalonDockLayout:LayoutRoot>
                <avalonDockLayout:LayoutPanel Orientation="Horizontal">

                    <!-- Left: Drive Tree -->
                    <avalonDockLayout:LayoutAnchorablePane DockWidth="250">
                        <avalonDockLayout:LayoutAnchorable Title="Drive Tree"
                                                            ContentId="driveTree"
                                                            CanClose="False"
                                                            CanFloat="True"
                                                            CanAutoHide="True">
                            <views:DriveTreeView />
                        </avalonDockLayout:LayoutAnchorable>
                    </avalonDockLayout:LayoutAnchorablePane>

                    <!-- Center: unified content area -->
                    <avalonDockLayout:LayoutPanel Orientation="Vertical">
                        <avalonDockLayout:LayoutDocumentPane>
                            <avalonDockLayout:LayoutDocument Title="{Binding ActiveDocumentTitle}"
                                                              ContentId="paramEditor"
                                                              CanClose="False">
                                <Grid x:Name="centerContentGrid">
                                    <Grid.ColumnDefinitions>
                                        <!-- Parameter panels (collapsible) -->
                                        <ColumnDefinition x:Name="ParamPanelColumn" Width="*" MinWidth="0" />
                                        <!-- Splitter -->
                                        <ColumnDefinition x:Name="CenterSplitterColumn" Width="Auto" />
                                        <!-- Monitor & Scope -->
                                        <ColumnDefinition x:Name="MonitorColumn" Width="0" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Left: Parameter panels (collapsible) -->
                                    <Grid Grid.Column="0">
                                        <Grid.ColumnDefinitions>
                                            <!-- Expanded content -->
                                            <ColumnDefinition x:Name="ParamContentColumn" Width="*" />
                                            <!-- Collapsed sidebar (always visible) -->
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Expanded: header + panels -->
                                        <Grid x:Name="ParamExpandedArea" Grid.Column="0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}"
                                                    BorderBrush="{DynamicResource BorderDefault}" BorderThickness="0,0,0,1"
                                                    Padding="4,2">
                                                <DockPanel>
                                                    <Button DockPanel.Dock="Right"
                                                            Click="BtnCollapseParams_Click"
                                                            Background="Transparent" BorderThickness="0"
                                                            Padding="4,2" Cursor="Hand" ToolTip="Collapse parameter panels">
                                                        <materialDesign:PackIcon Kind="ChevronLeft"
                                                                                 Width="14" Height="14"
                                                                                 Foreground="{DynamicResource TextSecondary}" />
                                                    </Button>
                                                    <TextBlock x:Name="ParamHeaderText" Text="Parameters"
                                                               VerticalAlignment="Center"
                                                               FontSize="{DynamicResource FontSizeXS}"
                                                               Foreground="{DynamicResource TextSecondary}" />
                                                </DockPanel>
                                            </Border>
                                            <Grid x:Name="centerPanelGrid" Grid.Row="1" />
                                        </Grid>

                                        <!-- Collapsed sidebar: vertical bar with expand button -->
                                        <Border x:Name="ParamCollapsedBar" Grid.Column="1"
                                                Width="28" Background="{DynamicResource SurfaceVariantBrush}"
                                                BorderBrush="{DynamicResource PrimaryBrush}"
                                                BorderThickness="2,0,0,0"
                                                Visibility="Collapsed" Cursor="Hand"
                                                MouseLeftButtonDown="ParamCollapsedBar_Click">
                                            <Border.Triggers>
                                                <EventTrigger RoutedEvent="MouseEnter">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="Width"
                                                                             To="34" Duration="0:0:0.15" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                                <EventTrigger RoutedEvent="MouseLeave">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="Width"
                                                                             To="28" Duration="0:0:0.15" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </Border.Triggers>
                                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <materialDesign:PackIcon Kind="ChevronDoubleRight"
                                                                         Width="18" Height="18"
                                                                         Foreground="{DynamicResource PrimaryBrush}"
                                                                         HorizontalAlignment="Center"
                                                                         Margin="0,0,0,6" />
                                                <TextBlock Text="P&#x000A;a&#x000A;r&#x000A;a&#x000A;m"
                                                           FontSize="{DynamicResource FontSizeSM}"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimary}"
                                                           TextAlignment="Center"
                                                           LineHeight="14"
                                                           HorizontalAlignment="Center" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <!-- Splitter between params and monitor -->
                                    <GridSplitter x:Name="CenterSplitter" Grid.Column="1"
                                                  Width="3" HorizontalAlignment="Center"
                                                  VerticalAlignment="Stretch"
                                                  Background="{DynamicResource BorderDefault}"
                                                  Visibility="Collapsed" />

                                    <!-- Right: Monitor & Scope (embedded) -->
                                    <views:MonitorControlDialog x:Name="monitorControlView" Grid.Column="2" />
                                </Grid>
                            </avalonDockLayout:LayoutDocument>
                        </avalonDockLayout:LayoutDocumentPane>

                        <!-- Error Log: center panel bottom -->
                        <avalonDockLayout:LayoutAnchorablePane DockHeight="150">
                            <avalonDockLayout:LayoutAnchorable x:Name="errorLogPane"
                                                                Title="Error Log"
                                                                ContentId="errorLog"
                                                                CanClose="True"
                                                                CanFloat="True"
                                                                CanAutoHide="True">
                                <views:ErrorLogView />
                            </avalonDockLayout:LayoutAnchorable>
                        </avalonDockLayout:LayoutAnchorablePane>
                    </avalonDockLayout:LayoutPanel>

                </avalonDockLayout:LayoutPanel>

                <!-- Control Panel (hidden initially, shown as floating on toggle) -->
                <avalonDockLayout:LayoutRoot.RightSide>
                    <avalonDockLayout:LayoutAnchorSide>
                        <avalonDockLayout:LayoutAnchorGroup>
                            <avalonDockLayout:LayoutAnchorable x:Name="controlPanelPane"
                                                                Title="Control Panel"
                                                                ContentId="controlPanel"
                                                                CanClose="True"
                                                                CanFloat="True"
                                                                CanAutoHide="True"
                                                                FloatingWidth="620"
                                                                FloatingHeight="380">
                                <views:ControlPanelView />
                            </avalonDockLayout:LayoutAnchorable>
                        </avalonDockLayout:LayoutAnchorGroup>
                    </avalonDockLayout:LayoutAnchorSide>
                </avalonDockLayout:LayoutRoot.RightSide>
            </avalonDockLayout:LayoutRoot>
        </avalonDock:DockingManager>

    </DockPanel>
</Window>
