<Window x:Class="RswareDesign.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:Fluent="urn:fluent-ribbon"
        xmlns:avalonDock="clr-namespace:AvalonDock;assembly=AvalonDock"
        xmlns:avalonDockLayout="clr-namespace:AvalonDock.Layout;assembly=AvalonDock"
        xmlns:avalonDockTheme="clr-namespace:AvalonDock.Themes;assembly=AvalonDock.Themes.VS2013"
        xmlns:views="clr-namespace:RswareDesign.Views"
        xmlns:vm="clr-namespace:RswareDesign.ViewModels"
        Title="{Binding Title}"
        Width="1920" Height="1080"
        WindowState="Maximized"
        Background="{DynamicResource BackgroundBrush}"
        TextElement.Foreground="{DynamicResource TextPrimary}"
        TextElement.FontFamily="{DynamicResource FontFamilyUI}"
        TextElement.FontSize="{DynamicResource FontSizeMD}">

    <Window.DataContext>
        <vm:MainWindowViewModel />
    </Window.DataContext>

    <DockPanel LastChildFill="True">

        <!-- ═══════════════════════════════════════════════════ -->
        <!--  RIBBON MENU (Top)                                  -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Fluent:Ribbon DockPanel.Dock="Top"
                       AutomaticStateManagement="True">

            <!-- ── File Tab ── -->
            <Fluent:RibbonTabItem Header="File" KeyTip="F">
                <Fluent:RibbonGroupBox Header="File">
                    <Fluent:Button Header="Open"
                                   LargeIcon="{materialDesign:PackIcon Kind=FolderOpen, Size=32}"
                                   Icon="{materialDesign:PackIcon Kind=FolderOpen, Size=16}"
                                   SizeDefinition="Large"
                                   KeyTip="O" />
                    <Fluent:Button Header="Save"
                                   LargeIcon="{materialDesign:PackIcon Kind=ContentSave, Size=32}"
                                   Icon="{materialDesign:PackIcon Kind=ContentSave, Size=16}"
                                   SizeDefinition="Large"
                                   Command="{Binding SaveParametersCommand}"
                                   KeyTip="S" />
                    <Fluent:Button Header="Load"
                                   LargeIcon="{materialDesign:PackIcon Kind=FileUpload, Size=32}"
                                   Icon="{materialDesign:PackIcon Kind=FileUpload, Size=16}"
                                   SizeDefinition="Large"
                                   KeyTip="L" />
                    <Fluent:Button Header="Close"
                                   Icon="{materialDesign:PackIcon Kind=Close, Size=16}"
                                   SizeDefinition="Middle"
                                   KeyTip="C" />
                </Fluent:RibbonGroupBox>
            </Fluent:RibbonTabItem>

            <!-- ── Tools Tab ── -->
            <Fluent:RibbonTabItem Header="Tools" KeyTip="T">
                <Fluent:RibbonGroupBox Header="Configuration">
                    <Fluent:Button Header="Drive"
                                   LargeIcon="{materialDesign:PackIcon Kind=Cog, Size=32}"
                                   Icon="{materialDesign:PackIcon Kind=Cog, Size=16}"
                                   SizeDefinition="Large" />
                    <Fluent:Button Header="Motor"
                                   LargeIcon="{materialDesign:PackIcon Kind=Engine, Size=32}"
                                   Icon="{materialDesign:PackIcon Kind=Engine, Size=16}"
                                   SizeDefinition="Large" />
                    <Fluent:Button Header="Encoder"
                                   LargeIcon="{materialDesign:PackIcon Kind=RotateRight, Size=32}"
                                   Icon="{materialDesign:PackIcon Kind=RotateRight, Size=16}"
                                   SizeDefinition="Large" />
                </Fluent:RibbonGroupBox>
            </Fluent:RibbonTabItem>

            <!-- ── Connection Tab (Default Selected) ── -->
            <Fluent:RibbonTabItem Header="Connection" KeyTip="N" IsSelected="True">
                <Fluent:RibbonGroupBox Header="Serial Port">
                    <Fluent:ComboBox Header="Port"
                                     ItemsSource="{Binding AvailablePorts}"
                                     SelectedItem="{Binding SelectedPort}"
                                     Width="120" />
                    <Fluent:Button Header="Rescan"
                                   Icon="{materialDesign:PackIcon Kind=Refresh, Size=16}"
                                   SizeDefinition="Middle"
                                   Command="{Binding RescanCommand}" />
                </Fluent:RibbonGroupBox>
                <Fluent:RibbonGroupBox Header="Connection">
                    <Fluent:Button Header="Connect"
                                   LargeIcon="{materialDesign:PackIcon Kind=LanConnect, Size=32}"
                                   Icon="{materialDesign:PackIcon Kind=LanConnect, Size=16}"
                                   SizeDefinition="Large"
                                   Command="{Binding ConnectCommand}" />
                    <Fluent:Button Header="Disconnect"
                                   LargeIcon="{materialDesign:PackIcon Kind=LanDisconnect, Size=32}"
                                   Icon="{materialDesign:PackIcon Kind=LanDisconnect, Size=16}"
                                   SizeDefinition="Large"
                                   Command="{Binding DisconnectCommand}" />
                </Fluent:RibbonGroupBox>
            </Fluent:RibbonTabItem>

            <!-- ── Options Tab ── -->
            <Fluent:RibbonTabItem Header="Options" KeyTip="P">
                <Fluent:RibbonGroupBox Header="Appearance">
                    <Fluent:ToggleButton Header="Dark Theme"
                                         LargeIcon="{materialDesign:PackIcon Kind=ThemeLightDark, Size=32}"
                                         Icon="{materialDesign:PackIcon Kind=ThemeLightDark, Size=16}"
                                         SizeDefinition="Large"
                                         IsChecked="{Binding IsDarkTheme, Mode=TwoWay}" />
                </Fluent:RibbonGroupBox>
                <Fluent:RibbonGroupBox Header="User Mode">
                    <Fluent:DropDownButton Header="Mode"
                                           LargeIcon="{materialDesign:PackIcon Kind=AccountCog, Size=32}"
                                           Icon="{materialDesign:PackIcon Kind=AccountCog, Size=16}"
                                           SizeDefinition="Large">
                        <Fluent:MenuItem Header="Standard" />
                        <Fluent:MenuItem Header="Advanced" />
                        <Fluent:MenuItem Header="Expert" />
                    </Fluent:DropDownButton>
                </Fluent:RibbonGroupBox>
            </Fluent:RibbonTabItem>

            <!-- ── Views Tab ── -->
            <Fluent:RibbonTabItem Header="Views" KeyTip="V">
                <Fluent:RibbonGroupBox Header="Panels">
                    <Fluent:ToggleButton Header="Drive Tree"
                                         LargeIcon="{materialDesign:PackIcon Kind=FileTree, Size=32}"
                                         Icon="{materialDesign:PackIcon Kind=FileTree, Size=16}"
                                         SizeDefinition="Large"
                                         IsChecked="{Binding IsDriveTreeVisible, Mode=TwoWay}" />
                    <Fluent:ToggleButton Header="Error Log"
                                         Icon="{materialDesign:PackIcon Kind=AlertCircleOutline, Size=16}"
                                         SizeDefinition="Middle"
                                         IsChecked="{Binding IsErrorLogVisible, Mode=TwoWay}" />
                    <Fluent:ToggleButton Header="Actions"
                                         Icon="{materialDesign:PackIcon Kind=FormatListChecks, Size=16}"
                                         SizeDefinition="Middle"
                                         IsChecked="{Binding IsActionPanelVisible, Mode=TwoWay}" />
                </Fluent:RibbonGroupBox>
                <Fluent:RibbonGroupBox Header="Display">
                    <Fluent:ToggleButton Header="Show Helps"
                                         Icon="{materialDesign:PackIcon Kind=HelpCircleOutline, Size=16}"
                                         SizeDefinition="Middle"
                                         IsChecked="{Binding ShowHelps, Mode=TwoWay}" />
                    <Fluent:ToggleButton Header="Show Status"
                                         Icon="{materialDesign:PackIcon Kind=InformationOutline, Size=16}"
                                         SizeDefinition="Middle"
                                         IsChecked="{Binding ShowStatus, Mode=TwoWay}" />
                    <Fluent:ToggleButton Header="Show Commands"
                                         Icon="{materialDesign:PackIcon Kind=Console, Size=16}"
                                         SizeDefinition="Middle"
                                         IsChecked="{Binding ShowCommands, Mode=TwoWay}" />
                </Fluent:RibbonGroupBox>
            </Fluent:RibbonTabItem>

        </Fluent:Ribbon>

        <!-- ═══════════════════════════════════════════════════ -->
        <!--  STATUS BAR (Bottom)                                -->
        <!-- ═══════════════════════════════════════════════════ -->
        <StatusBar DockPanel.Dock="Bottom"
                   Background="{DynamicResource StatusBarBrush}"
                   Foreground="{DynamicResource StatusBarForeground}"
                   Height="{DynamicResource Size.StatusBarHeight}">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Margin="0,0,6,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{DynamicResource ErrorBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="Fill" Value="{DynamicResource SuccessBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding ConnectionStatus}" />
                </StackPanel>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="{Binding DriveInfo}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="{Binding ModeInfo}" />
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="{Binding SelectedPort}" />
            </StatusBarItem>
        </StatusBar>

        <!-- ═══════════════════════════════════════════════════ -->
        <!--  AVALONDOCK MAIN LAYOUT (Center)                    -->
        <!-- ═══════════════════════════════════════════════════ -->
        <avalonDock:DockingManager x:Name="dockManager">
            <avalonDock:DockingManager.Theme>
                <avalonDockTheme:Vs2013DarkTheme />
            </avalonDock:DockingManager.Theme>

            <avalonDockLayout:LayoutRoot>
                <avalonDockLayout:LayoutPanel Orientation="Vertical">

                    <!-- Upper area: Tree | Editor | Actions -->
                    <avalonDockLayout:LayoutPanel Orientation="Horizontal">

                        <!-- Left: Drive Tree -->
                        <avalonDockLayout:LayoutAnchorablePane DockWidth="250">
                            <avalonDockLayout:LayoutAnchorable Title="Drive Tree"
                                                                ContentId="driveTree"
                                                                CanClose="False"
                                                                CanFloat="True"
                                                                CanAutoHide="True">
                                <views:DriveTreeView />
                            </avalonDockLayout:LayoutAnchorable>
                        </avalonDockLayout:LayoutAnchorablePane>

                        <!-- Center: Parameter Editor (Document Area) -->
                        <avalonDockLayout:LayoutDocumentPane>
                            <avalonDockLayout:LayoutDocument Title="ECAT Homing"
                                                              ContentId="paramEditor"
                                                              CanClose="False">
                                <views:ParameterEditorView />
                            </avalonDockLayout:LayoutDocument>
                        </avalonDockLayout:LayoutDocumentPane>

                        <!-- Right: Action Panel -->
                        <avalonDockLayout:LayoutAnchorablePane DockWidth="160">
                            <avalonDockLayout:LayoutAnchorable Title="Actions"
                                                                ContentId="actions"
                                                                CanClose="False"
                                                                CanFloat="True"
                                                                CanAutoHide="True">
                                <views:ActionPanelView />
                            </avalonDockLayout:LayoutAnchorable>
                        </avalonDockLayout:LayoutAnchorablePane>

                    </avalonDockLayout:LayoutPanel>

                    <!-- Bottom: Error Log -->
                    <avalonDockLayout:LayoutAnchorablePane DockHeight="150">
                        <avalonDockLayout:LayoutAnchorable Title="Error Log"
                                                            ContentId="errorLog"
                                                            CanClose="False"
                                                            CanFloat="True"
                                                            CanAutoHide="True">
                            <views:ErrorLogView />
                        </avalonDockLayout:LayoutAnchorable>
                    </avalonDockLayout:LayoutAnchorablePane>

                </avalonDockLayout:LayoutPanel>
            </avalonDockLayout:LayoutRoot>
        </avalonDock:DockingManager>

    </DockPanel>
</Window>
