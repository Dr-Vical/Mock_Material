<Window x:Class="RswareDesign.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:Fluent="urn:fluent-ribbon"
        xmlns:avalonDock="clr-namespace:AvalonDock;assembly=AvalonDock"
        xmlns:avalonDockLayout="clr-namespace:AvalonDock.Layout;assembly=AvalonDock"
        xmlns:avalonDockTheme="clr-namespace:AvalonDock.Themes;assembly=AvalonDock.Themes.VS2013"
        xmlns:views="clr-namespace:RswareDesign.Views"
        xmlns:vm="clr-namespace:RswareDesign.ViewModels"
        Title="{Binding Title}"
        Width="1920" Height="1080"
        WindowState="Maximized"
        Background="{DynamicResource BackgroundBrush}"
        TextElement.Foreground="{DynamicResource TextPrimary}"
        TextElement.FontFamily="{DynamicResource FontFamilyUI}"
        TextElement.FontSize="{DynamicResource FontSizeMD}">

    <Window.DataContext>
        <vm:MainWindowViewModel />
    </Window.DataContext>

    <!-- Style Dictionary: Colors.xaml → Fonts.xaml → Styles.xaml → Buttons.xaml -->

    <DockPanel LastChildFill="True">

        <!-- ═══════════════════════════════════════════════════ -->
        <!--  RIBBON MENU (Top)                                  -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Fluent:Ribbon DockPanel.Dock="Top"
                       AutomaticStateManagement="True">

            <!-- ── File Tab ── -->
            <Fluent:RibbonTabItem Header="File" KeyTip="F">
                <Fluent:RibbonGroupBox Header="File">
                    <Button Style="{StaticResource RibbonLargeRipple}">
                        <StackPanel HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="FolderOpen" Style="{StaticResource RibbonIconOpacityPulse}" />
                            <TextBlock Text="Open" Style="{StaticResource RibbonButtonLabel}" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource RibbonLargeRipple}" Command="{Binding SaveParametersCommand}">
                        <StackPanel HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="ContentSave" Style="{StaticResource RibbonIconOpacityPulse}" />
                            <TextBlock Text="Save" Style="{StaticResource RibbonButtonLabel}" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource RibbonLargeRipple}">
                        <StackPanel HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="ContentSaveEdit" Style="{StaticResource RibbonIconOpacityPulse}" />
                            <TextBlock Text="Save As" Style="{StaticResource RibbonButtonLabel}" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource RibbonLargeRipple}">
                        <StackPanel HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="FileUpload" Style="{StaticResource RibbonIconOpacityPulse}" />
                            <TextBlock Text="Load" Style="{StaticResource RibbonButtonLabel}" />
                        </StackPanel>
                    </Button>
                </Fluent:RibbonGroupBox>
            </Fluent:RibbonTabItem>

            <!-- ── Tools Tab ── -->
            <Fluent:RibbonTabItem Header="Tools" KeyTip="T">
                <Fluent:RibbonGroupBox Header="Configuration">
                    <Button Style="{StaticResource RibbonLargeRipple}">
                        <StackPanel HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="Cog" Style="{StaticResource RibbonIconOpacityPulse}" />
                            <TextBlock Text="Drive" Style="{StaticResource RibbonButtonLabel}" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource RibbonLargeRipple}">
                        <StackPanel HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="Engine" Style="{StaticResource RibbonIconOpacityPulse}" />
                            <TextBlock Text="Motor" Style="{StaticResource RibbonButtonLabel}" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource RibbonLargeRipple}">
                        <StackPanel HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="RotateRight" Style="{StaticResource RibbonIconOpacityPulse}" />
                            <TextBlock Text="Encoder" Style="{StaticResource RibbonButtonLabel}" />
                        </StackPanel>
                    </Button>
                </Fluent:RibbonGroupBox>
                <Fluent:RibbonGroupBox Header="Monitor">
                    <Button Style="{StaticResource RibbonLargeRipple}" Command="{Binding OpenOscilloscopeCommand}">
                        <StackPanel HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="ChartBellCurveCumulative" Style="{StaticResource RibbonIconOpacityPulse}" />
                            <TextBlock Text="Oscilloscope" Style="{StaticResource RibbonButtonLabel}" />
                        </StackPanel>
                    </Button>
                </Fluent:RibbonGroupBox>
            </Fluent:RibbonTabItem>

            <!-- ── Connection Tab (Default Selected) ── -->
            <Fluent:RibbonTabItem Header="Connection" KeyTip="N" IsSelected="True">
                <Fluent:RibbonGroupBox Header="Serial Port">
                    <StackPanel VerticalAlignment="Center" Margin="4,2">
                        <TextBlock Text="Port" Foreground="{DynamicResource TextSecondary}"
                                   FontSize="{DynamicResource FontSizeXS}" Margin="0,0,0,2" />
                        <ComboBox ItemsSource="{Binding AvailablePorts}"
                                  SelectedItem="{Binding SelectedPort}"
                                  Style="{StaticResource RibbonDarkComboBox}"
                                  Width="120" MinHeight="26" />
                    </StackPanel>
                    <Button Style="{StaticResource RibbonLargeRipple}" Command="{Binding RescanCommand}">
                        <StackPanel HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="Refresh" Style="{StaticResource RibbonIconOpacityPulse}" />
                            <TextBlock Text="Rescan" Style="{StaticResource RibbonButtonLabel}" />
                        </StackPanel>
                    </Button>
                </Fluent:RibbonGroupBox>
                <Fluent:RibbonGroupBox Header="Connection">
                    <Button Style="{StaticResource RibbonLargeRipple}" Command="{Binding ConnectCommand}">
                        <StackPanel HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="LanConnect" Style="{StaticResource RibbonIconOpacityPulse}" />
                            <TextBlock Text="Connect" Style="{StaticResource RibbonButtonLabel}" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource RibbonLargeRipple}" Command="{Binding DisconnectCommand}">
                        <StackPanel HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="LanDisconnect" Style="{StaticResource RibbonIconShake}" />
                            <TextBlock Text="Disconnect" Style="{StaticResource RibbonButtonLabel}" />
                        </StackPanel>
                    </Button>
                </Fluent:RibbonGroupBox>
            </Fluent:RibbonTabItem>

            <!-- ── Options Tab ── -->
            <Fluent:RibbonTabItem Header="Options" KeyTip="P">
                <Fluent:RibbonGroupBox Header="Appearance">
                    <ToggleButton Style="{StaticResource RibbonLargeRippleToggle}" IsChecked="{Binding IsDarkTheme, Mode=TwoWay}">
                        <StackPanel HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="ThemeLightDark" Style="{StaticResource RibbonIconOpacityPulse}" />
                            <TextBlock Text="Dark Theme" Style="{StaticResource RibbonButtonLabel}" />
                        </StackPanel>
                    </ToggleButton>
                </Fluent:RibbonGroupBox>
                <Fluent:RibbonGroupBox Header="Theme Color">
                    <StackPanel VerticalAlignment="Center" Margin="4,2">
                        <DockPanel Margin="0,0,0,4">
                            <Rectangle x:Name="ColorPreview" DockPanel.Dock="Right"
                                       Width="20" Height="20" RadiusX="4" RadiusY="4"
                                       Fill="{DynamicResource PrimaryBrush}" Margin="8,0,0,0" />
                            <TextBlock Text="Primary Hue" Foreground="{DynamicResource TextSecondary}"
                                       FontSize="{DynamicResource FontSizeXS}" VerticalAlignment="Center" />
                        </DockPanel>
                        <Slider x:Name="HueSlider" Style="{StaticResource HueSliderStyle}"
                                Minimum="0" Maximum="360" Value="210" Width="200"
                                ValueChanged="HueSlider_ValueChanged" />
                    </StackPanel>
                </Fluent:RibbonGroupBox>
                <Fluent:RibbonGroupBox Header="User Mode">
                    <Fluent:DropDownButton Header="Mode"
                                           LargeIcon="{materialDesign:PackIcon Kind=AccountCog, Size=32}"
                                           Icon="{materialDesign:PackIcon Kind=AccountCog, Size=16}"
                                           SizeDefinition="Large">
                        <Fluent:MenuItem Header="Standard" />
                        <Fluent:MenuItem Header="Advanced" />
                        <Fluent:MenuItem Header="Expert" />
                    </Fluent:DropDownButton>
                </Fluent:RibbonGroupBox>
            </Fluent:RibbonTabItem>

            <!-- ── Views Tab ── -->
            <Fluent:RibbonTabItem Header="Views" KeyTip="V">
                <Fluent:RibbonGroupBox Header="Panels">
                    <ToggleButton Style="{StaticResource RibbonLargeRippleToggle}" IsChecked="{Binding IsDriveTreeVisible, Mode=TwoWay}">
                        <StackPanel HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="FileTree" Style="{StaticResource RibbonIconOpacityPulse}" />
                            <TextBlock Text="Drive Tree" Style="{StaticResource RibbonButtonLabel}" />
                        </StackPanel>
                    </ToggleButton>
                    <ToggleButton Style="{StaticResource RibbonLargeRippleToggle}" IsChecked="{Binding IsErrorLogVisible, Mode=TwoWay}">
                        <StackPanel HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="AlertCircleOutline" Style="{StaticResource RibbonIconOpacityPulse}" />
                            <TextBlock Text="Error Log" Style="{StaticResource RibbonButtonLabel}" />
                        </StackPanel>
                    </ToggleButton>
                    <ToggleButton Style="{StaticResource RibbonLargeRippleToggle}" IsChecked="{Binding IsActionPanelVisible, Mode=TwoWay}">
                        <StackPanel HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="FormatListChecks" Style="{StaticResource RibbonIconOpacityPulse}" />
                            <TextBlock Text="Actions" Style="{StaticResource RibbonButtonLabel}" />
                        </StackPanel>
                    </ToggleButton>
                </Fluent:RibbonGroupBox>
                <Fluent:RibbonGroupBox Header="Display">
                    <ToggleButton Style="{StaticResource RibbonLargeRippleToggle}" IsChecked="{Binding ShowHelps, Mode=TwoWay}">
                        <StackPanel HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="HelpCircleOutline" Style="{StaticResource RibbonIconOpacityPulse}" />
                            <TextBlock Text="Show Helps" Style="{StaticResource RibbonButtonLabel}" />
                        </StackPanel>
                    </ToggleButton>
                    <ToggleButton Style="{StaticResource RibbonLargeRippleToggle}" IsChecked="{Binding ShowStatus, Mode=TwoWay}">
                        <StackPanel HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="InformationOutline" Style="{StaticResource RibbonIconOpacityPulse}" />
                            <TextBlock Text="Show Status" Style="{StaticResource RibbonButtonLabel}" />
                        </StackPanel>
                    </ToggleButton>
                    <ToggleButton Style="{StaticResource RibbonLargeRippleToggle}" IsChecked="{Binding ShowCommands, Mode=TwoWay}">
                        <StackPanel HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="Console" Style="{StaticResource RibbonIconOpacityPulse}" />
                            <TextBlock Text="Show Commands" Style="{StaticResource RibbonButtonLabel}" />
                        </StackPanel>
                    </ToggleButton>
                </Fluent:RibbonGroupBox>
            </Fluent:RibbonTabItem>

        </Fluent:Ribbon>

        <!-- ═══════════════════════════════════════════════════ -->
        <!--  STATUS BAR (Bottom)                                -->
        <!-- ═══════════════════════════════════════════════════ -->
        <StatusBar DockPanel.Dock="Bottom"
                   Background="{DynamicResource StatusBarBrush}"
                   Foreground="{DynamicResource StatusBarForeground}"
                   Height="{DynamicResource Size.StatusBarHeight}">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Margin="0,0,6,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{DynamicResource ErrorBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="Fill" Value="{DynamicResource SuccessBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding ConnectionStatus}" />
                </StackPanel>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="{Binding DriveInfo}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="{Binding ModeInfo}" />
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="{Binding SelectedPort}" />
            </StatusBarItem>
        </StatusBar>

        <!-- ═══════════════════════════════════════════════════ -->
        <!--  AVALONDOCK MAIN LAYOUT (Center)                    -->
        <!-- ═══════════════════════════════════════════════════ -->
        <avalonDock:DockingManager x:Name="dockManager">
            <avalonDock:DockingManager.Theme>
                <avalonDockTheme:Vs2013DarkTheme />
            </avalonDock:DockingManager.Theme>

            <avalonDockLayout:LayoutRoot>
                <avalonDockLayout:LayoutPanel Orientation="Horizontal">

                    <!-- Left: Drive Tree -->
                    <avalonDockLayout:LayoutAnchorablePane DockWidth="250">
                        <avalonDockLayout:LayoutAnchorable Title="Drive Tree"
                                                            ContentId="driveTree"
                                                            CanClose="False"
                                                            CanFloat="True"
                                                            CanAutoHide="True">
                            <views:DriveTreeView />
                        </avalonDockLayout:LayoutAnchorable>
                    </avalonDockLayout:LayoutAnchorablePane>

                    <!-- Center: Editor (top) + Error Log (bottom) -->
                    <avalonDockLayout:LayoutPanel Orientation="Vertical">
                        <avalonDockLayout:LayoutDocumentPane>
                            <avalonDockLayout:LayoutDocument Title="ECAT Homing"
                                                              ContentId="paramEditor"
                                                              CanClose="False">
                                <views:ParameterEditorView />
                            </avalonDockLayout:LayoutDocument>
                        </avalonDockLayout:LayoutDocumentPane>

                        <!-- Error Log: center panel bottom -->
                        <avalonDockLayout:LayoutAnchorablePane DockHeight="150">
                            <avalonDockLayout:LayoutAnchorable Title="Error Log"
                                                                ContentId="errorLog"
                                                                CanClose="False"
                                                                CanFloat="True"
                                                                CanAutoHide="True">
                                <views:ErrorLogView />
                            </avalonDockLayout:LayoutAnchorable>
                        </avalonDockLayout:LayoutAnchorablePane>
                    </avalonDockLayout:LayoutPanel>

                    <!-- Right: Action Panel -->
                    <avalonDockLayout:LayoutAnchorablePane DockWidth="160">
                        <avalonDockLayout:LayoutAnchorable Title="Actions"
                                                            ContentId="actions"
                                                            CanClose="False"
                                                            CanFloat="True"
                                                            CanAutoHide="True">
                            <views:ActionPanelView />
                        </avalonDockLayout:LayoutAnchorable>
                    </avalonDockLayout:LayoutAnchorablePane>

                </avalonDockLayout:LayoutPanel>
            </avalonDockLayout:LayoutRoot>
        </avalonDock:DockingManager>

    </DockPanel>
</Window>
