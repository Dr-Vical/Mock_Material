<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  5-ROLE COLOR SYSTEM — DARK THEME (검정톤)                    -->
    <!--  Monochrome: White / Black / Gray palette                    -->
    <!-- ═══════════════════════════════════════════════════════════ -->

    <!-- ── 1. Primary ── -->
    <SolidColorBrush x:Key="PrimaryBrush"          Color="#FF78909C" />
    <SolidColorBrush x:Key="PrimaryHoverBrush"      Color="#FF607D8B" />
    <SolidColorBrush x:Key="PrimaryForegroundBrush" Color="#FFFFFFFF" />

    <!-- ── 2. Secondary ── -->
    <SolidColorBrush x:Key="SecondaryBrush"         Color="#FFB0BEC5" />
    <SolidColorBrush x:Key="SecondaryHoverBrush"    Color="#FF90A4AE" />

    <!-- ── 3. Surface ── -->
    <SolidColorBrush x:Key="SurfaceBrush"           Color="#FF2D2D30" />
    <SolidColorBrush x:Key="SurfaceVariantBrush"    Color="#FF3C3C3C" />

    <!-- ── 4. Background ── -->
    <SolidColorBrush x:Key="BackgroundBrush"        Color="#FF1E1E1E" />

    <!-- ── 5. Error ── -->
    <SolidColorBrush x:Key="ErrorBrush"             Color="#FFEF5350" />
    <SolidColorBrush x:Key="WarningBrush"           Color="#FFFFD54F" />
    <SolidColorBrush x:Key="SuccessBrush"           Color="#FF66BB6A" />

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  TEXT COLORS                                                  -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <SolidColorBrush x:Key="TextPrimary"            Color="#FFE0E0E0" />
    <SolidColorBrush x:Key="TextSecondary"          Color="#FF9E9E9E" />
    <SolidColorBrush x:Key="TextDisabled"           Color="#FF616161" />
    <SolidColorBrush x:Key="TextOnPrimary"          Color="#FFFFFFFF" />

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  BORDER COLORS                                                -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <SolidColorBrush x:Key="BorderDefault"          Color="#FF424242" />
    <SolidColorBrush x:Key="BorderFocused"          Color="#FF90A4AE" />
    <SolidColorBrush x:Key="DividerBrush"           Color="#FF424242" />

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  COMPONENT-SPECIFIC COLORS                                    -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <SolidColorBrush x:Key="ValueHighlightBrush"     Color="#FFFFD54F" />

    <SolidColorBrush x:Key="RibbonBackgroundBrush"  Color="#FF252526" />
    <SolidColorBrush x:Key="TreeBackgroundBrush"    Color="#FF252526" />
    <SolidColorBrush x:Key="GridHeaderBrush"        Color="#FF37474F" />
    <SolidColorBrush x:Key="GridAlternatingRowBrush" Color="#FF2A2A2E" />
    <SolidColorBrush x:Key="StatusBarBrush"         Color="#FF546E7A" />
    <SolidColorBrush x:Key="StatusBarForeground"    Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="SelectedRowBrush"       Color="#FF37474F" />

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  RIBBON ITEM COLOR — Gray monochrome (Secondary role)        -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <SolidColorBrush x:Key="RibbonItemBrush"        Color="#FFB0BEC5" />
    <SolidColorBrush x:Key="RibbonItemErrorBrush"   Color="#FFEF5350" />

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  RIBBON BUTTON STATE COLORS                                    -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <SolidColorBrush x:Key="RibbonButton.HoverBrush"   Color="#20FFFFFF" />
    <SolidColorBrush x:Key="RibbonButton.PressedBrush"  Color="#35FFFFFF" />
    <SolidColorBrush x:Key="RibbonButton.CheckedBrush"  Color="#FF3C3C3C" />

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  COMBOBOX STATE COLORS                                        -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <SolidColorBrush x:Key="ComboBox.HoverBackground"  Color="#FF4A4A4D" />
    <SolidColorBrush x:Key="ComboBox.HoverBorder"      Color="#FF6A6A6D" />

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  PANEL A/B/C/D IDENTIFICATION COLORS                        -->
    <!-- ═══════════════════════════════════════════════════════════ -->

    <!-- Panel A/B/C/D — visible accent on dark theme -->
    <LinearGradientBrush x:Key="PanelABrush" StartPoint="0,0.5" EndPoint="1,0.5">
        <GradientStop Color="#50C06060" Offset="0" />
        <GradientStop Color="#002D2D30" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="PanelBBrush" StartPoint="0,0.5" EndPoint="1,0.5">
        <GradientStop Color="#50C0A850" Offset="0" />
        <GradientStop Color="#002D2D30" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="PanelCBrush" StartPoint="0,0.5" EndPoint="1,0.5">
        <GradientStop Color="#505878C0" Offset="0" />
        <GradientStop Color="#002D2D30" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="PanelDBrush" StartPoint="0,0.5" EndPoint="1,0.5">
        <GradientStop Color="#5058C078" Offset="0" />
        <GradientStop Color="#002D2D30" Offset="1" />
    </LinearGradientBrush>

    <SolidColorBrush x:Key="PanelAAccent" Color="#FFC06060" />
    <SolidColorBrush x:Key="PanelBAccent" Color="#FFC0A850" />
    <SolidColorBrush x:Key="PanelCAccent" Color="#FF5878C0" />
    <SolidColorBrush x:Key="PanelDAccent" Color="#FF58C078" />

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  CHART CHANNEL COLORS (Oscilloscope / Monitor)              -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <SolidColorBrush x:Key="ChartCH1Brush" Color="#FFFFEB3B" />
    <SolidColorBrush x:Key="ChartCH2Brush" Color="#FF4CAF50" />
    <SolidColorBrush x:Key="ChartCH3Brush" Color="#FF29B6F6" />
    <SolidColorBrush x:Key="ChartCH4Brush" Color="#FFEF5350" />

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  FLUENT.RIBBON BACKGROUND OVERRIDES                         -->
    <!--  Match ribbon area to our BackgroundBrush / SurfaceBrush    -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <SolidColorBrush x:Key="Fluent.Ribbon.Brushes.RibbonTabControl.Background" Color="#FF1E1E1E" />
    <SolidColorBrush x:Key="Fluent.Ribbon.Brushes.Ribbon.Background"           Color="#FF1E1E1E" />
    <SolidColorBrush x:Key="Fluent.Ribbon.Brushes.RibbonWindow.TitleBackground" Color="#FF1E1E1E" />
    <SolidColorBrush x:Key="Fluent.Ribbon.Brushes.RibbonGroupBox.Background"   Color="#FF2D2D30" />

</ResourceDictionary>
