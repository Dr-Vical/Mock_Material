<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  5-ROLE COLOR SYSTEM — LIGHT THEME (흰색톤)                    -->
    <!--  Monochrome: White / Black / Gray palette                    -->
    <!-- ═══════════════════════════════════════════════════════════ -->

    <!-- ── 1. Primary ── -->
    <SolidColorBrush x:Key="PrimaryBrush"          Color="#FF546E7A" />
    <SolidColorBrush x:Key="PrimaryHoverBrush"      Color="#FF455A64" />
    <SolidColorBrush x:Key="PrimaryForegroundBrush" Color="#FFFFFFFF" />

    <!-- ── 2. Secondary ── -->
    <SolidColorBrush x:Key="SecondaryBrush"         Color="#FF78909C" />
    <SolidColorBrush x:Key="SecondaryHoverBrush"    Color="#FF607D8B" />

    <!-- ── 3. Surface ── -->
    <SolidColorBrush x:Key="SurfaceBrush"           Color="#FFE8E8E8" />
    <SolidColorBrush x:Key="SurfaceVariantBrush"    Color="#FFDEDEDE" />

    <!-- ── 4. Background ── -->
    <SolidColorBrush x:Key="BackgroundBrush"        Color="#FFF5F5F5" />

    <!-- ── 5. Error ── -->
    <SolidColorBrush x:Key="ErrorBrush"             Color="#FFE53935" />
    <SolidColorBrush x:Key="WarningBrush"           Color="#FFFFC107" />
    <SolidColorBrush x:Key="SuccessBrush"           Color="#FF43A047" />

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  TEXT COLORS                                                  -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <SolidColorBrush x:Key="TextPrimary"            Color="#FF212121" />
    <SolidColorBrush x:Key="TextSecondary"          Color="#FF757575" />
    <SolidColorBrush x:Key="TextDisabled"           Color="#FFBDBDBD" />
    <SolidColorBrush x:Key="TextOnPrimary"          Color="#FFFFFFFF" />

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  BORDER COLORS                                                -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <SolidColorBrush x:Key="BorderDefault"          Color="#FFC8C8C8" />
    <SolidColorBrush x:Key="BorderFocused"          Color="#FF546E7A" />
    <SolidColorBrush x:Key="DividerBrush"           Color="#FFC8C8C8" />

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  COMPONENT-SPECIFIC COLORS                                    -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <SolidColorBrush x:Key="RibbonBackgroundBrush"  Color="#FFEEEEEE" />
    <SolidColorBrush x:Key="TreeBackgroundBrush"    Color="#FFEEEEEE" />
    <SolidColorBrush x:Key="GridHeaderBrush"        Color="#FFD6D9DC" />
    <SolidColorBrush x:Key="GridAlternatingRowBrush" Color="#FFE2E2E2" />
    <SolidColorBrush x:Key="StatusBarBrush"         Color="#FF546E7A" />
    <SolidColorBrush x:Key="StatusBarForeground"    Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="SelectedRowBrush"       Color="#FFCFD8DC" />

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  RIBBON ITEM COLOR — Gray monochrome (Secondary role)        -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <SolidColorBrush x:Key="RibbonItemBrush"        Color="#FF546E7A" />
    <SolidColorBrush x:Key="RibbonItemErrorBrush"   Color="#FFC62828" />

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  RIBBON BUTTON STATE COLORS                                    -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <SolidColorBrush x:Key="RibbonButton.HoverBrush"   Color="#10000000" />
    <SolidColorBrush x:Key="RibbonButton.PressedBrush"  Color="#20000000" />
    <SolidColorBrush x:Key="RibbonButton.CheckedBrush"  Color="#FFD0D0D0" />

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  COMBOBOX STATE COLORS                                        -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <SolidColorBrush x:Key="ComboBox.HoverBackground"  Color="#FFD8D8D8" />
    <SolidColorBrush x:Key="ComboBox.HoverBorder"      Color="#FFA0A0A0" />

</ResourceDictionary>
