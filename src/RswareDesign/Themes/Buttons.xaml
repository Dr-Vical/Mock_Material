<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  RIBBON LARGE BUTTON                                         -->
    <!--  4 States: Normal / MouseOver / Pressed / (Disabled)         -->
    <!--                                                               -->
    <!--  Normal   → Transparent                                       -->
    <!--  Hover    → RibbonButton.HoverBrush (subtle white overlay)    -->
    <!--  Pressed  → RibbonButton.PressedBrush (deeper overlay)        -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="RibbonLargeRipple" TargetType="Button">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" Background="Transparent"
                            CornerRadius="{StaticResource Radius.SM}"
                            Padding="8,7,8,1" MinWidth="54" MinHeight="53">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- Hover -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background"
                                    Value="{DynamicResource RibbonButton.HoverBrush}" />
                        </Trigger>
                        <!-- Pressed -->
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bg" Property="Background"
                                    Value="{DynamicResource RibbonButton.PressedBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  RIBBON LARGE TOGGLEBUTTON                                    -->
    <!--  4 States: Normal / MouseOver / Pressed / IsChecked           -->
    <!--                                                               -->
    <!--  Normal   → Transparent                                       -->
    <!--  Hover    → RibbonButton.HoverBrush                           -->
    <!--  Pressed  → RibbonButton.PressedBrush                         -->
    <!--  Checked  → RibbonButton.CheckedBrush (persistent highlight)  -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="RibbonLargeRippleToggle" TargetType="ToggleButton">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="Bg" Background="Transparent"
                            CornerRadius="{StaticResource Radius.SM}"
                            Padding="8,7,8,1" MinWidth="54" MinHeight="53">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- Hover (unchecked) -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsChecked" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Bg" Property="Background"
                                    Value="{DynamicResource RibbonButton.HoverBrush}" />
                        </MultiTrigger>
                        <!-- Pressed -->
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bg" Property="Background"
                                    Value="{DynamicResource RibbonButton.PressedBrush}" />
                        </Trigger>
                        <!-- Checked (persistent) -->
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Bg" Property="Background"
                                    Value="{DynamicResource RibbonButton.CheckedBrush}" />
                        </Trigger>
                        <!-- Hover while Checked -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsChecked" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Bg" Property="Background"
                                    Value="{DynamicResource RibbonButton.PressedBrush}" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  QUICK ACTION BUTTON (compact toolbar button)                -->
    <!--  Horizontal icon + text, always visible action bar           -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="QuickActionButton" TargetType="Button">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" Background="Transparent"
                            CornerRadius="{StaticResource Radius.SM}"
                            Padding="{TemplateBinding Padding}"
                            MinHeight="{TemplateBinding MinHeight}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background"
                                    Value="{DynamicResource RibbonButton.HoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bg" Property="Background"
                                    Value="{DynamicResource RibbonButton.PressedBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  QUICK ACTION ICON (smaller, for inline toolbar)             -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="QuickActionIcon" TargetType="materialDesign:PackIcon"
           xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
        <Setter Property="Width" Value="{StaticResource Size.IconMD}" />
        <Setter Property="Height" Value="{StaticResource Size.IconMD}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{DynamicResource RibbonItemBrush}" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  QUICK ACTION LABEL (compact text next to icon)              -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="QuickActionLabel" TargetType="TextBlock">
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="4,0,0,0" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeXS}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        <Setter Property="FontFamily" Value="{DynamicResource FontFamilyUI}" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  RIBBON DARK COMBOBOX (full template — dark popup)           -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="RibbonDarkComboBox" TargetType="ComboBox">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Background" Value="{DynamicResource SurfaceVariantBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderDefault}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="6,3" />
        <Setter Property="FontFamily" Value="{DynamicResource FontFamilyUI}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeSM}" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="OverridesDefaultStyle" Value="True" />
                    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Padding" Value="6,4" />
                    <Setter Property="Cursor" Value="Hand" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ComboBoxItem">
                                <Border x:Name="itemBg"
                                        Background="{TemplateBinding Background}"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsHighlighted" Value="True">
                                        <Setter TargetName="itemBg" Property="Background"
                                                Value="{DynamicResource RibbonButton.HoverBrush}" />
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="itemBg" Property="Background"
                                                Value="{DynamicResource PrimaryBrush}" />
                                        <Setter Property="Foreground" Value="{DynamicResource TextOnPrimary}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <!-- Toggle button (entire ComboBox surface) -->
                        <ToggleButton x:Name="toggleButton"
                                      ClickMode="Press"
                                      Focusable="False"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="toggleBorder"
                                            Background="{DynamicResource SurfaceVariantBrush}"
                                            BorderBrush="{DynamicResource BorderDefault}"
                                            BorderThickness="1"
                                            CornerRadius="2">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="16" />
                                            </Grid.ColumnDefinitions>
                                            <Path Grid.Column="1"
                                                  Data="M0,0 L4,4 L8,0"
                                                  Fill="{DynamicResource TextSecondary}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,2,0" />
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="toggleBorder" Property="Background"
                                                    Value="{DynamicResource ComboBox.HoverBackground}" />
                                            <Setter TargetName="toggleBorder" Property="BorderBrush"
                                                    Value="{DynamicResource ComboBox.HoverBorder}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <!-- Selected item display (right margin clears 16px arrow) -->
                        <ContentPresenter x:Name="contentPresenter"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Center"
                                          Margin="6,3,18,3"
                                          IsHitTestVisible="False" />
                        <!-- Dropdown popup (dark themed) -->
                        <Popup x:Name="PART_Popup"
                               AllowsTransparency="True"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               Placement="Bottom"
                               PopupAnimation="Slide">
                            <Border x:Name="dropdownBorder"
                                    Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderDefault}"
                                    BorderThickness="1"
                                    CornerRadius="2"
                                    MinWidth="{TemplateBinding ActualWidth}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                    Margin="0,2,0,0"
                                    Padding="0,2">
                                <ScrollViewer CanContentScroll="True">
                                    <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
