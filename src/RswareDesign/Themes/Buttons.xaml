<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  RIBBON LARGE BUTTON                                         -->
    <!--  4 States: Normal / MouseOver / Pressed / (Disabled)         -->
    <!--                                                               -->
    <!--  Normal   → Transparent                                       -->
    <!--  Hover    → RibbonButton.HoverBrush (subtle white overlay)    -->
    <!--  Pressed  → RibbonButton.PressedBrush (deeper overlay)        -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="RibbonLargeRipple" TargetType="Button">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" Background="Transparent"
                            CornerRadius="{StaticResource Radius.SM}"
                            Padding="8,4" MinWidth="54" MinHeight="56">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- Hover -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background"
                                    Value="{DynamicResource RibbonButton.HoverBrush}" />
                        </Trigger>
                        <!-- Pressed -->
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bg" Property="Background"
                                    Value="{DynamicResource RibbonButton.PressedBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  RIBBON LARGE TOGGLEBUTTON                                    -->
    <!--  4 States: Normal / MouseOver / Pressed / IsChecked           -->
    <!--                                                               -->
    <!--  Normal   → Transparent                                       -->
    <!--  Hover    → RibbonButton.HoverBrush                           -->
    <!--  Pressed  → RibbonButton.PressedBrush                         -->
    <!--  Checked  → RibbonButton.CheckedBrush (persistent highlight)  -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="RibbonLargeRippleToggle" TargetType="ToggleButton">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="Bg" Background="Transparent"
                            CornerRadius="{StaticResource Radius.SM}"
                            Padding="8,4" MinWidth="54" MinHeight="56">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- Hover (unchecked) -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsChecked" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Bg" Property="Background"
                                    Value="{DynamicResource RibbonButton.HoverBrush}" />
                        </MultiTrigger>
                        <!-- Pressed -->
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bg" Property="Background"
                                    Value="{DynamicResource RibbonButton.PressedBrush}" />
                        </Trigger>
                        <!-- Checked (persistent) -->
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Bg" Property="Background"
                                    Value="{DynamicResource RibbonButton.CheckedBrush}" />
                        </Trigger>
                        <!-- Hover while Checked -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsChecked" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Bg" Property="Background"
                                    Value="{DynamicResource RibbonButton.PressedBrush}" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  RIBBON DARK COMBOBOX                                        -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="RibbonDarkComboBox" TargetType="ComboBox">
        <Setter Property="Background" Value="{DynamicResource SurfaceVariantBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderDefault}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="6,3" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource ComboBox.HoverBackground}" />
                <Setter Property="BorderBrush" Value="{DynamicResource ComboBox.HoverBorder}" />
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
