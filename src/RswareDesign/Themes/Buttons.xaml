<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  RIBBON LARGE BUTTON                                         -->
    <!--  4 States: Normal / MouseOver / Pressed / (Disabled)         -->
    <!--                                                               -->
    <!--  Normal   → Transparent                                       -->
    <!--  Hover    → RibbonButton.HoverBrush (subtle white overlay)    -->
    <!--  Pressed  → RibbonButton.PressedBrush (deeper overlay)        -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="RibbonLargeRipple" TargetType="Button">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" Background="Transparent"
                            CornerRadius="{StaticResource Radius.SM}"
                            Padding="8,7,8,1" MinWidth="54" MinHeight="53">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- Hover -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background"
                                    Value="{DynamicResource RibbonButton.HoverBrush}" />
                        </Trigger>
                        <!-- Pressed -->
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bg" Property="Background"
                                    Value="{DynamicResource RibbonButton.PressedBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  RIBBON LARGE TOGGLEBUTTON                                    -->
    <!--  4 States: Normal / MouseOver / Pressed / IsChecked           -->
    <!--                                                               -->
    <!--  Normal   → Transparent                                       -->
    <!--  Hover    → RibbonButton.HoverBrush                           -->
    <!--  Pressed  → RibbonButton.PressedBrush                         -->
    <!--  Checked  → RibbonButton.CheckedBrush (persistent highlight)  -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="RibbonLargeRippleToggle" TargetType="ToggleButton">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="Bg" Background="Transparent"
                            CornerRadius="{StaticResource Radius.SM}"
                            Padding="8,7,8,1" MinWidth="54" MinHeight="53">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- Hover (unchecked) -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsChecked" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Bg" Property="Background"
                                    Value="{DynamicResource RibbonButton.HoverBrush}" />
                        </MultiTrigger>
                        <!-- Pressed -->
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bg" Property="Background"
                                    Value="{DynamicResource RibbonButton.PressedBrush}" />
                        </Trigger>
                        <!-- Checked (persistent) -->
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Bg" Property="Background"
                                    Value="{DynamicResource RibbonButton.CheckedBrush}" />
                        </Trigger>
                        <!-- Hover while Checked -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsChecked" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Bg" Property="Background"
                                    Value="{DynamicResource RibbonButton.PressedBrush}" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  QUICK ACTION BUTTON (compact toolbar button)                -->
    <!--  Horizontal icon + text, always visible action bar           -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="QuickActionButton" TargetType="Button">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" Background="Transparent"
                            CornerRadius="{StaticResource Radius.SM}"
                            Padding="8,4" MinHeight="28">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background"
                                    Value="{DynamicResource RibbonButton.HoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bg" Property="Background"
                                    Value="{DynamicResource RibbonButton.PressedBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  QUICK ACTION ICON (smaller, for inline toolbar)             -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="QuickActionIcon" TargetType="materialDesign:PackIcon"
           xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
        <Setter Property="Width" Value="{StaticResource Size.IconMD}" />
        <Setter Property="Height" Value="{StaticResource Size.IconMD}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{DynamicResource RibbonItemBrush}" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  QUICK ACTION LABEL (compact text next to icon)              -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="QuickActionLabel" TargetType="TextBlock">
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="4,0,0,0" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeXS}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        <Setter Property="FontFamily" Value="{DynamicResource FontFamilyUI}" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  RIBBON DARK COMBOBOX                                        -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="RibbonDarkComboBox" TargetType="ComboBox">
        <Setter Property="Background" Value="{DynamicResource SurfaceVariantBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderDefault}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="6,3" />
        <!-- Dropdown items: always dark text on system popup background -->
        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="Foreground" Value="#FF212121" />
                </Style>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource ComboBox.HoverBackground}" />
                <Setter Property="BorderBrush" Value="{DynamicResource ComboBox.HoverBorder}" />
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
