<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  5-ROLE COLOR SYSTEM — GRAY THEME (회색톤)                    -->
    <!--  Monochrome: White / Black / Gray palette                    -->
    <!-- ═══════════════════════════════════════════════════════════ -->

    <!-- ── 1. Primary ── -->
    <SolidColorBrush x:Key="PrimaryBrush"          Color="#FF90A4AE" />
    <SolidColorBrush x:Key="PrimaryHoverBrush"      Color="#FF78909C" />
    <SolidColorBrush x:Key="PrimaryForegroundBrush" Color="#FFFFFFFF" />

    <!-- ── 2. Secondary ── -->
    <SolidColorBrush x:Key="SecondaryBrush"         Color="#FFCFD8DC" />
    <SolidColorBrush x:Key="SecondaryHoverBrush"    Color="#FFB0BEC5" />

    <!-- ── 3. Surface ── -->
    <SolidColorBrush x:Key="SurfaceBrush"           Color="#FF58585E" />
    <SolidColorBrush x:Key="SurfaceVariantBrush"    Color="#FF65656B" />

    <!-- ── 4. Background ── -->
    <SolidColorBrush x:Key="BackgroundBrush"        Color="#FF48484E" />

    <!-- ── 5. Error ── -->
    <SolidColorBrush x:Key="ErrorBrush"             Color="#FFEF5350" />
    <SolidColorBrush x:Key="WarningBrush"           Color="#FFFFD54F" />
    <SolidColorBrush x:Key="SuccessBrush"           Color="#FF66BB6A" />

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  TEXT COLORS                                                  -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <SolidColorBrush x:Key="TextPrimary"            Color="#FFF0F0F0" />
    <SolidColorBrush x:Key="TextSecondary"          Color="#FFB8B8B8" />
    <SolidColorBrush x:Key="TextDisabled"           Color="#FF787878" />
    <SolidColorBrush x:Key="TextOnPrimary"          Color="#FFFFFFFF" />

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  BORDER COLORS                                                -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <SolidColorBrush x:Key="BorderDefault"          Color="#FF6E6E74" />
    <SolidColorBrush x:Key="BorderFocused"          Color="#FF90A4AE" />
    <SolidColorBrush x:Key="DividerBrush"           Color="#FF6E6E74" />

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  COMPONENT-SPECIFIC COLORS                                    -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <SolidColorBrush x:Key="RibbonBackgroundBrush"  Color="#FF505056" />
    <SolidColorBrush x:Key="TreeBackgroundBrush"    Color="#FF505056" />
    <SolidColorBrush x:Key="GridHeaderBrush"        Color="#FF525258" />
    <SolidColorBrush x:Key="GridAlternatingRowBrush" Color="#FF4E4E54" />
    <SolidColorBrush x:Key="StatusBarBrush"         Color="#FF607D8B" />
    <SolidColorBrush x:Key="StatusBarForeground"    Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="SelectedRowBrush"       Color="#FF607D8B" />

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  RIBBON ITEM COLOR — Gray monochrome (Secondary role)        -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <SolidColorBrush x:Key="RibbonItemBrush"        Color="#FFCFD8DC" />
    <SolidColorBrush x:Key="RibbonItemErrorBrush"   Color="#FFEF5350" />

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  RIBBON BUTTON STATE COLORS                                    -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <SolidColorBrush x:Key="RibbonButton.HoverBrush"   Color="#20FFFFFF" />
    <SolidColorBrush x:Key="RibbonButton.PressedBrush"  Color="#35FFFFFF" />
    <SolidColorBrush x:Key="RibbonButton.CheckedBrush"  Color="#FF65656B" />

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  COMBOBOX STATE COLORS                                        -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <SolidColorBrush x:Key="ComboBox.HoverBackground"  Color="#FF68686E" />
    <SolidColorBrush x:Key="ComboBox.HoverBorder"      Color="#FF888890" />

</ResourceDictionary>
