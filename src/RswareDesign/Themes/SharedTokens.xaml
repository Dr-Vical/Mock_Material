<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <!-- ═══════════════════════════════════════════════════ -->
    <!--  COLOR TOKENS (5-Role System) — DynamicResource    -->
    <!-- ═══════════════════════════════════════════════════ -->

    <!-- Primary -->
    <SolidColorBrush x:Key="PrimaryBrush"          Color="#FF1976D2" />
    <SolidColorBrush x:Key="PrimaryHoverBrush"      Color="#FF1565C0" />
    <SolidColorBrush x:Key="PrimaryForegroundBrush" Color="#FFFFFFFF" />

    <!-- Secondary -->
    <SolidColorBrush x:Key="SecondaryBrush"         Color="#FFFFB74D" />
    <SolidColorBrush x:Key="SecondaryHoverBrush"    Color="#FFFFA726" />

    <!-- Surface -->
    <SolidColorBrush x:Key="SurfaceBrush"           Color="#FF2D2D30" />
    <SolidColorBrush x:Key="SurfaceVariantBrush"    Color="#FF3C3C3C" />

    <!-- Background -->
    <SolidColorBrush x:Key="BackgroundBrush"        Color="#FF1E1E1E" />

    <!-- Error -->
    <SolidColorBrush x:Key="ErrorBrush"             Color="#FFEF5350" />
    <SolidColorBrush x:Key="WarningBrush"           Color="#FFFFD54F" />
    <SolidColorBrush x:Key="SuccessBrush"           Color="#FF66BB6A" />

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimary"            Color="#FFE0E0E0" />
    <SolidColorBrush x:Key="TextSecondary"          Color="#FF9E9E9E" />
    <SolidColorBrush x:Key="TextDisabled"           Color="#FF616161" />
    <SolidColorBrush x:Key="TextOnPrimary"          Color="#FFFFFFFF" />

    <!-- Border -->
    <SolidColorBrush x:Key="BorderDefault"          Color="#FF424242" />
    <SolidColorBrush x:Key="BorderFocused"          Color="#FF90CAF9" />
    <SolidColorBrush x:Key="DividerBrush"           Color="#FF424242" />

    <!-- Component-Specific -->
    <SolidColorBrush x:Key="RibbonBackgroundBrush"  Color="#FF252526" />
    <SolidColorBrush x:Key="TreeBackgroundBrush"    Color="#FF252526" />
    <SolidColorBrush x:Key="GridHeaderBrush"        Color="#FF37474F" />
    <SolidColorBrush x:Key="GridAlternatingRowBrush" Color="#FF2A2A2E" />
    <SolidColorBrush x:Key="StatusBarBrush"         Color="#FF007ACC" />
    <SolidColorBrush x:Key="StatusBarForeground"    Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="SelectedRowBrush"       Color="#FF264F78" />

    <!-- ═══════════════════════════════════════════════════ -->
    <!--  TYPOGRAPHY TOKENS — DynamicResource               -->
    <!-- ═══════════════════════════════════════════════════ -->

    <FontFamily x:Key="FontFamilyUI">Segoe UI, Malgun Gothic</FontFamily>
    <FontFamily x:Key="FontFamilyCode">Cascadia Code, Consolas</FontFamily>
    <FontFamily x:Key="FontFamilyMono">Consolas, Courier New</FontFamily>

    <system:Double x:Key="FontSizeXS">10</system:Double>
    <system:Double x:Key="FontSizeSM">11</system:Double>
    <system:Double x:Key="FontSizeMD">12</system:Double>
    <system:Double x:Key="FontSizeLG">13</system:Double>
    <system:Double x:Key="FontSizeXL">14</system:Double>
    <system:Double x:Key="FontSizeXXL">16</system:Double>
    <system:Double x:Key="FontSize3XL">20</system:Double>

    <!-- ═══════════════════════════════════════════════════ -->
    <!--  SPACING TOKENS — StaticResource                   -->
    <!-- ═══════════════════════════════════════════════════ -->

    <Thickness x:Key="Padding.Panel">12</Thickness>
    <Thickness x:Key="Padding.ToolWindow">8</Thickness>
    <Thickness x:Key="Padding.Dialog">24</Thickness>
    <Thickness x:Key="Padding.Input">8,4</Thickness>
    <Thickness x:Key="Padding.Button">12,6</Thickness>
    <Thickness x:Key="Padding.Button.Small">8,4</Thickness>
    <Thickness x:Key="Padding.GridCell">6,3</Thickness>

    <Thickness x:Key="Margin.ListItem">0,0,0,4</Thickness>
    <Thickness x:Key="Margin.FormField">0,0,0,12</Thickness>
    <Thickness x:Key="Margin.Section">0,0,0,24</Thickness>
    <Thickness x:Key="Margin.Inline">0,0,8,0</Thickness>

    <CornerRadius x:Key="Radius.None">0</CornerRadius>
    <CornerRadius x:Key="Radius.SM">2</CornerRadius>
    <CornerRadius x:Key="Radius.MD">4</CornerRadius>
    <CornerRadius x:Key="Radius.LG">6</CornerRadius>
    <CornerRadius x:Key="Radius.XL">8</CornerRadius>

    <!-- ═══════════════════════════════════════════════════ -->
    <!--  SIZE TOKENS — StaticResource                      -->
    <!-- ═══════════════════════════════════════════════════ -->

    <system:Double x:Key="Size.StatusBarHeight">24</system:Double>
    <system:Double x:Key="Size.GridRowHeight">28</system:Double>
    <system:Double x:Key="Size.GridHeaderHeight">32</system:Double>
    <system:Double x:Key="Size.TreeItemHeight">28</system:Double>
    <system:Double x:Key="Size.ActionButtonHeight">32</system:Double>
    <system:Double x:Key="Size.ActionButtonWidth">140</system:Double>
    <system:Double x:Key="Size.SidebarWidth">250</system:Double>
    <system:Double x:Key="Size.ActionPanelWidth">160</system:Double>
    <system:Double x:Key="Size.ErrorPanelHeight">150</system:Double>
    <system:Double x:Key="Size.IconSM">14</system:Double>
    <system:Double x:Key="Size.IconMD">16</system:Double>
    <system:Double x:Key="Size.IconLG">20</system:Double>
    <system:Double x:Key="Size.IconXL">24</system:Double>

</ResourceDictionary>
