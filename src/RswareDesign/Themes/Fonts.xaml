<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  FONT FAMILY — DynamicResource                               -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <FontFamily x:Key="FontFamilyUI">Segoe UI, Malgun Gothic</FontFamily>
    <FontFamily x:Key="FontFamilyCode">Cascadia Code, Consolas</FontFamily>
    <FontFamily x:Key="FontFamilyMono">Consolas, Courier New</FontFamily>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  FONT SIZE — DynamicResource                                 -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <system:Double x:Key="FontSizeXS">10</system:Double>
    <system:Double x:Key="FontSizeSM">11</system:Double>
    <system:Double x:Key="FontSizeMD">12</system:Double>
    <system:Double x:Key="FontSizeLG">13</system:Double>
    <system:Double x:Key="FontSizeXL">14</system:Double>
    <system:Double x:Key="FontSizeXXL">16</system:Double>
    <system:Double x:Key="FontSize3XL">20</system:Double>

</ResourceDictionary>
