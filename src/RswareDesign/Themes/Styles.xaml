<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib"
                    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  SPACING TOKENS — StaticResource                             -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <Thickness x:Key="Padding.Panel">13</Thickness>
    <Thickness x:Key="Padding.ToolWindow">9</Thickness>
    <Thickness x:Key="Padding.Dialog">25</Thickness>
    <Thickness x:Key="Padding.Input">9,5</Thickness>
    <Thickness x:Key="Padding.Button">13,7</Thickness>
    <Thickness x:Key="Padding.Button.Small">9,5</Thickness>
    <Thickness x:Key="Padding.GridCell">7,4</Thickness>

    <Thickness x:Key="Margin.ListItem">0,0,0,5</Thickness>
    <Thickness x:Key="Margin.FormField">0,0,0,13</Thickness>
    <Thickness x:Key="Margin.Section">0,0,0,25</Thickness>
    <Thickness x:Key="Margin.Inline">0,0,9,0</Thickness>

    <CornerRadius x:Key="Radius.None">0</CornerRadius>
    <CornerRadius x:Key="Radius.SM">2</CornerRadius>
    <CornerRadius x:Key="Radius.MD">4</CornerRadius>
    <CornerRadius x:Key="Radius.LG">6</CornerRadius>
    <CornerRadius x:Key="Radius.XL">8</CornerRadius>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  RIBBON INLINE TOKENS — for non-button controls in ribbon    -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <Thickness x:Key="Padding.RibbonInline">4,2</Thickness>
    <Thickness x:Key="Margin.RibbonLabelGap">0,0,0,3</Thickness>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  RIBBON INLINE LABEL — labels inside RibbonGroupBox          -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="RibbonInlineLabel" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeXS}" />
        <Setter Property="FontFamily" Value="{DynamicResource FontFamilyUI}" />
        <Setter Property="Margin" Value="{StaticResource Margin.RibbonLabelGap}" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  SIZE TOKENS — StaticResource                                -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <system:Double x:Key="Size.StatusBarHeight">24</system:Double>
    <system:Double x:Key="Size.GridRowHeight">28</system:Double>
    <system:Double x:Key="Size.GridHeaderHeight">32</system:Double>
    <system:Double x:Key="Size.TreeItemHeight">28</system:Double>
    <system:Double x:Key="Size.ActionButtonHeight">32</system:Double>
    <system:Double x:Key="Size.ActionButtonWidth">140</system:Double>
    <system:Double x:Key="Size.SidebarWidth">250</system:Double>
    <system:Double x:Key="Size.ActionPanelWidth">160</system:Double>
    <system:Double x:Key="Size.ErrorPanelHeight">150</system:Double>
    <system:Double x:Key="Size.IconSM">14</system:Double>
    <system:Double x:Key="Size.IconMD">16</system:Double>
    <system:Double x:Key="Size.IconLG">20</system:Double>
    <system:Double x:Key="Size.IconXL">24</system:Double>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  RIBBON ICON SIZE                                            -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <system:Double x:Key="RibbonIcon.Size">32</system:Double>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  RIBBON ICON EFFECT: Opacity Pulse (default)                 -->
    <!--  Color: RibbonItemBrush (Secondary role)                     -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="RibbonIconOpacityPulse" TargetType="materialDesign:PackIcon">
        <Setter Property="Width" Value="{StaticResource RibbonIcon.Size}" />
        <Setter Property="Height" Value="{StaticResource RibbonIcon.Size}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{DynamicResource RibbonItemBrush}" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ButtonBase}}" Value="True">
                <DataTrigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             To="0.5" Duration="0:0:0.15" AutoReverse="True" />
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.EnterActions>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  RIBBON ICON EFFECT: Shake (error/disconnect only)           -->
    <!--  Color: RibbonItemErrorBrush (Error role)                    -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="RibbonIconShake" TargetType="materialDesign:PackIcon">
        <Setter Property="Width" Value="{StaticResource RibbonIcon.Size}" />
        <Setter Property="Height" Value="{StaticResource RibbonIcon.Size}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{DynamicResource RibbonItemErrorBrush}" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="RenderTransform">
            <Setter.Value>
                <TranslateTransform />
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ButtonBase}}" Value="True">
                <DataTrigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)">
                                <LinearDoubleKeyFrame KeyTime="0:0:0.05" Value="3" />
                                <LinearDoubleKeyFrame KeyTime="0:0:0.10" Value="-3" />
                                <LinearDoubleKeyFrame KeyTime="0:0:0.15" Value="2" />
                                <LinearDoubleKeyFrame KeyTime="0:0:0.20" Value="-2" />
                                <LinearDoubleKeyFrame KeyTime="0:0:0.25" Value="0" />
                            </DoubleAnimationUsingKeyFrames>
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.EnterActions>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  RIBBON BUTTON LABEL                                         -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="RibbonButtonLabel" TargetType="TextBlock">
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Margin" Value="0,2,0,0" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeXS}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  HUE SLIDER                                                  -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="SliderTransparentRepeatButton" TargetType="RepeatButton">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Background="Transparent" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="HueSliderStyle" TargetType="Slider">
        <Setter Property="Height" Value="24" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Grid>
                        <Border Height="8" CornerRadius="4" VerticalAlignment="Center" Margin="8,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                    <GradientStop Color="#FFFF0000" Offset="0.0" />
                                    <GradientStop Color="#FFFFFF00" Offset="0.167" />
                                    <GradientStop Color="#FF00FF00" Offset="0.333" />
                                    <GradientStop Color="#FF00FFFF" Offset="0.5" />
                                    <GradientStop Color="#FF0000FF" Offset="0.667" />
                                    <GradientStop Color="#FFFF00FF" Offset="0.833" />
                                    <GradientStop Color="#FFFF0000" Offset="1.0" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <Track x:Name="PART_Track">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Style="{StaticResource SliderTransparentRepeatButton}" />
                            </Track.DecreaseRepeatButton>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Style="{StaticResource SliderTransparentRepeatButton}" />
                            </Track.IncreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb>
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Grid Width="18" Height="18">
                                                <Ellipse Fill="White" Width="18" Height="18">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect ShadowDepth="1"
                                                                          BlurRadius="3"
                                                                          Opacity="0.4" />
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                                <Ellipse Fill="{DynamicResource PrimaryBrush}"
                                                         Width="10" Height="10" />
                                            </Grid>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
