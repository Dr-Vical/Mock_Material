<Window x:Class="RswareDesign.Views.OscilloscopeOptionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Oscilloscope Options"
        Width="380" Height="400"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="Transparent"
        TextElement.Foreground="{DynamicResource TextPrimary}"
        TextElement.FontFamily="{DynamicResource FontFamilyUI}"
        TextElement.FontSize="{DynamicResource FontSizeMD}">

    <Border Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource RSBlueBrush}"
            BorderThickness="2"
            CornerRadius="{StaticResource Radius.LG}"
            Margin="8"
            Effect="{StaticResource MaterialDesignShadowDepth3}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0"
                    Background="{DynamicResource RSBlueBrush}"
                    CornerRadius="8,8,0,0"
                    Padding="12,8"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="ChartTimelineVariantShimmer"
                                                 Width="{StaticResource Size.IconLG}"
                                                 Height="{StaticResource Size.IconLG}"
                                                 Foreground="{DynamicResource TextOnPrimary}"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,8,0" />
                        <TextBlock Text="Oscilloscope Options"
                                   FontSize="{DynamicResource FontSizeLG}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextOnPrimary}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Padding="4" MinWidth="0" Width="28" Height="28"
                            Click="BtnCancel_Click">
                        <materialDesign:PackIcon Kind="Close" Width="16" Height="16"
                                                 Foreground="{DynamicResource TextOnPrimary}" />
                    </Button>
                </Grid>
            </Border>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="{StaticResource Padding.Dialog}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Settings Grid -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Sample Period :" Foreground="{DynamicResource TextSecondary}" FontSize="{DynamicResource FontSizeSM}" VerticalAlignment="Center" Margin="0,0,12,8" />
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtSamplePeriod" Text="0.001"
                             Background="{DynamicResource SurfaceVariantBrush}" Foreground="{DynamicResource ValueHighlightBrush}"
                             BorderBrush="{DynamicResource BorderDefault}" FontFamily="{DynamicResource FontFamilyCode}"
                             FontSize="{DynamicResource FontSizeSM}" Padding="6,4" Margin="0,0,0,8" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Samples / Division :" Foreground="{DynamicResource TextSecondary}" FontSize="{DynamicResource FontSizeSM}" VerticalAlignment="Center" Margin="0,0,12,8" />
                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtSamplesPerDiv" Text="50.0"
                             Background="{DynamicResource SurfaceVariantBrush}" Foreground="{DynamicResource ValueHighlightBrush}"
                             BorderBrush="{DynamicResource BorderDefault}" FontFamily="{DynamicResource FontFamilyCode}"
                             FontSize="{DynamicResource FontSizeSM}" Padding="6,4" Margin="0,0,0,8" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Trigger Signal :" Foreground="{DynamicResource TextSecondary}" FontSize="{DynamicResource FontSizeSM}" VerticalAlignment="Center" Margin="0,0,12,8" />
                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="TxtTriggerSignal" Text="0.0"
                             Background="{DynamicResource SurfaceVariantBrush}" Foreground="{DynamicResource ValueHighlightBrush}"
                             BorderBrush="{DynamicResource BorderDefault}" FontFamily="{DynamicResource FontFamilyCode}"
                             FontSize="{DynamicResource FontSizeSM}" Padding="6,4" Margin="0,0,0,8" />

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Trigger Mode :" Foreground="{DynamicResource TextSecondary}" FontSize="{DynamicResource FontSizeSM}" VerticalAlignment="Center" Margin="0,0,12,8" />
                    <TextBox Grid.Row="3" Grid.Column="1" x:Name="TxtTriggerMode" Text="0.0"
                             Background="{DynamicResource SurfaceVariantBrush}" Foreground="{DynamicResource ValueHighlightBrush}"
                             BorderBrush="{DynamicResource BorderDefault}" FontFamily="{DynamicResource FontFamilyCode}"
                             FontSize="{DynamicResource FontSizeSM}" Padding="6,4" Margin="0,0,0,8" />

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Trigger Threshold :" Foreground="{DynamicResource TextSecondary}" FontSize="{DynamicResource FontSizeSM}" VerticalAlignment="Center" Margin="0,0,12,8" />
                    <TextBox Grid.Row="4" Grid.Column="1" x:Name="TxtTriggerThreshold" Text="0.0"
                             Background="{DynamicResource SurfaceVariantBrush}" Foreground="{DynamicResource ValueHighlightBrush}"
                             BorderBrush="{DynamicResource BorderDefault}" FontFamily="{DynamicResource FontFamilyCode}"
                             FontSize="{DynamicResource FontSizeSM}" Padding="6,4" Margin="0,0,0,8" />

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Pretrigger, %10 :" Foreground="{DynamicResource TextSecondary}" FontSize="{DynamicResource FontSizeSM}" VerticalAlignment="Center" Margin="0,0,12,8" />
                    <TextBox Grid.Row="5" Grid.Column="1" x:Name="TxtPretrigger" Text="10.0"
                             Background="{DynamicResource SurfaceVariantBrush}" Foreground="{DynamicResource ValueHighlightBrush}"
                             BorderBrush="{DynamicResource BorderDefault}" FontFamily="{DynamicResource FontFamilyCode}"
                             FontSize="{DynamicResource FontSizeSM}" Padding="6,4" Margin="0,0,0,8" />

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Trigger Status :" Foreground="{DynamicResource TextSecondary}" FontSize="{DynamicResource FontSizeSM}" VerticalAlignment="Center" Margin="0,0,12,0" />
                    <TextBox Grid.Row="6" Grid.Column="1" x:Name="TxtTriggerStatus" Text="0.0"
                             Background="{DynamicResource SurfaceVariantBrush}" Foreground="{DynamicResource ValueHighlightBrush}"
                             BorderBrush="{DynamicResource BorderDefault}" FontFamily="{DynamicResource FontFamilyCode}"
                             FontSize="{DynamicResource FontSizeSM}" Padding="6,4" />
                </Grid>

                <!-- Buttons -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                    <Button Content="{DynamicResource loc.btn.cancel}"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Margin="{StaticResource Margin.Inline}"
                            Click="BtnCancel_Click" />
                    <Button Content="{DynamicResource loc.btn.ok}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="{DynamicResource PrimaryBrush}"
                            BorderThickness="0"
                            Click="BtnOk_Click" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
