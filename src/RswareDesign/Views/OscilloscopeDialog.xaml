<Window x:Class="RswareDesign.Views.OscilloscopeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:scottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        Title="Oscilloscope - Step Response Monitor"
        Width="1100" Height="700"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        TextElement.Foreground="{DynamicResource TextPrimary}"
        TextElement.FontFamily="{DynamicResource FontFamilyUI}"
        TextElement.FontSize="{DynamicResource FontSizeMD}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════ -->
        <!--  TOP TOOLBAR                                        -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderDefault}"
                BorderThickness="0,0,0,1"
                Padding="{StaticResource Padding.ToolWindow}">
            <DockPanel>
                <!-- Right side controls -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="Time/Div:"
                               Foreground="{DynamicResource TextSecondary}"
                               VerticalAlignment="Center"
                               Margin="{StaticResource Margin.Inline}" />
                    <ComboBox x:Name="TimeDivCombo"
                              Width="90"
                              SelectedIndex="2"
                              Margin="{StaticResource Margin.Inline}">
                        <ComboBoxItem Content="1 ms" />
                        <ComboBoxItem Content="5 ms" />
                        <ComboBoxItem Content="10 ms" />
                        <ComboBoxItem Content="50 ms" />
                        <ComboBoxItem Content="100 ms" />
                    </ComboBox>
                    <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                               Margin="8,2" />
                    <TextBlock Text="Trigger:"
                               Foreground="{DynamicResource TextSecondary}"
                               VerticalAlignment="Center"
                               Margin="{StaticResource Margin.Inline}" />
                    <ComboBox Width="90"
                              SelectedIndex="0"
                              Margin="{StaticResource Margin.Inline}">
                        <ComboBoxItem Content="Auto" />
                        <ComboBoxItem Content="Normal" />
                        <ComboBoxItem Content="Single" />
                    </ComboBox>
                </StackPanel>

                <!-- Left side: Channel toggles -->
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button x:Name="BtnStartStop"
                            Click="BtnStartStop_Click"
                            Padding="{StaticResource Padding.Button.Small}"
                            Margin="{StaticResource Margin.Inline}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon x:Name="StartStopIcon"
                                                     Kind="Play" Width="14" Height="14"
                                                     VerticalAlignment="Center"
                                                     Margin="0,0,4,0" />
                            <TextBlock x:Name="StartStopText"
                                       Text="Start" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                               Margin="8,2" />
                    <CheckBox x:Name="ChkCh1" Content="CH1 Position"
                              IsChecked="True"
                              Foreground="#FFFFEB3B"
                              Margin="{StaticResource Margin.Inline}"
                              Checked="Channel_Changed" Unchecked="Channel_Changed" />
                    <CheckBox x:Name="ChkCh2" Content="CH2 Velocity"
                              IsChecked="True"
                              Foreground="#FF4CAF50"
                              Margin="{StaticResource Margin.Inline}"
                              Checked="Channel_Changed" Unchecked="Channel_Changed" />
                    <CheckBox x:Name="ChkCh3" Content="CH3 Current"
                              IsChecked="True"
                              Foreground="#FF29B6F6"
                              Margin="{StaticResource Margin.Inline}"
                              Checked="Channel_Changed" Unchecked="Channel_Changed" />
                    <CheckBox x:Name="ChkCh4" Content="CH4 Error"
                              IsChecked="True"
                              Foreground="#FFEF5350"
                              Margin="{StaticResource Margin.Inline}"
                              Checked="Channel_Changed" Unchecked="Channel_Changed" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════ -->
        <!--  CHART AREA                                         -->
        <!-- ═══════════════════════════════════════════════════ -->
        <scottPlot:WpfPlot x:Name="OscPlot" Grid.Row="1" />

        <!-- ═══════════════════════════════════════════════════ -->
        <!--  BOTTOM STATUS BAR                                  -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderDefault}"
                BorderThickness="0,1,0,0"
                Padding="{StaticResource Padding.ToolWindow}">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="Close"
                        Click="BtnClose_Click"
                        Padding="{StaticResource Padding.Button.Small}"
                        MinWidth="80" />
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="InformationOutline"
                                             Width="14" Height="14"
                                             Foreground="{DynamicResource TextSecondary}"
                                             VerticalAlignment="Center"
                                             Margin="0,0,6,0" />
                    <TextBlock Text="Sample Rate: 10 kHz"
                               Foreground="{DynamicResource TextSecondary}"
                               Margin="{StaticResource Margin.Inline}" />
                    <TextBlock Text="|"
                               Foreground="{DynamicResource BorderDefault}"
                               Margin="{StaticResource Margin.Inline}" />
                    <TextBlock Text="Points: 500"
                               Foreground="{DynamicResource TextSecondary}"
                               Margin="{StaticResource Margin.Inline}" />
                    <TextBlock Text="|"
                               Foreground="{DynamicResource BorderDefault}"
                               Margin="{StaticResource Margin.Inline}" />
                    <TextBlock Text="Duration: 50 ms"
                               Foreground="{DynamicResource TextSecondary}"
                               Margin="{StaticResource Margin.Inline}" />
                    <TextBlock Text="|"
                               Foreground="{DynamicResource BorderDefault}"
                               Margin="{StaticResource Margin.Inline}" />
                    <TextBlock x:Name="TxtStatus"
                               Text="Stopped"
                               Foreground="{DynamicResource SecondaryBrush}" />
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
