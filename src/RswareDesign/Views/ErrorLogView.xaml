<UserControl x:Class="RswareDesign.Views.ErrorLogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{DynamicResource SurfaceBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header Bar -->
        <Border Grid.Row="0"
                Background="{DynamicResource GridHeaderBrush}"
                Padding="{StaticResource Padding.ToolWindow}">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="AlertCircleOutline"
                                         Width="{DynamicResource Size.IconSM}"
                                         Height="{DynamicResource Size.IconSM}"
                                         Foreground="{DynamicResource WarningBrush}"
                                         VerticalAlignment="Center"
                                         Margin="0,0,6,0" />
                <TextBlock Text="Status / Error Log"
                           Foreground="{DynamicResource TextPrimary}"
                           FontWeight="SemiBold"
                           FontSize="{DynamicResource FontSizeSM}"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Status DataGrid -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding StatusEntries}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  RowHeight="{DynamicResource Size.GridRowHeight}"
                  ColumnHeaderHeight="{DynamicResource Size.GridHeaderHeight}"
                  Background="{DynamicResource SurfaceBrush}"
                  Foreground="{DynamicResource TextPrimary}"
                  BorderThickness="0"
                  FontFamily="{DynamicResource FontFamilyCode}"
                  FontSize="{DynamicResource FontSizeSM}"
                  HorizontalGridLinesBrush="{DynamicResource DividerBrush}">

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="{DynamicResource GridHeaderBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                    <Setter Property="FontFamily" Value="{DynamicResource FontFamilyUI}" />
                    <Setter Property="FontSize" Value="{DynamicResource FontSizeSM}" />
                    <Setter Property="Padding" Value="{DynamicResource Padding.GridCell}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
                    <Setter Property="BorderThickness" Value="0,0,1,1" />
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="Padding" Value="{DynamicResource Padding.GridCell}" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="DataGridCell">
                                <Border Padding="{TemplateBinding Padding}"
                                        Background="{TemplateBinding Background}">
                                    <ContentPresenter VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </DataGrid.CellStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="STATUS"
                                    Binding="{Binding Status}"
                                    Width="*" />
                <DataGridTextColumn Header="VALUE"
                                    Binding="{Binding Value}"
                                    Width="200" />
                <DataGridTextColumn Header="UNITS"
                                    Binding="{Binding Units}"
                                    Width="100" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
