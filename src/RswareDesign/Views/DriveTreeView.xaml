<UserControl x:Class="RswareDesign.Views.DriveTreeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:RswareDesign.Converters"
             Background="{DynamicResource TreeBackgroundBrush}">

    <UserControl.Resources>
        <converters:StringToPackIconKindConverter x:Key="IconKindConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Animation overlay for +1/-1 floating text -->
        <Canvas x:Name="animationCanvas"
                Grid.Row="0"
                IsHitTestVisible="False"
                Panel.ZIndex="100" />

        <TreeView x:Name="driveTree"
                  Grid.Row="0"
                  ItemsSource="{Binding TreeNodes}"
                  Background="Transparent"
                  BorderThickness="0"
                  Padding="{StaticResource Padding.ToolWindow}"
                  SelectedItemChanged="OnTreeNodeSelected">

            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
                    <Setter Property="FontFamily" Value="{DynamicResource FontFamilyUI}" />
                    <Setter Property="FontSize" Value="{DynamicResource FontSizeSM}" />
                    <Setter Property="Padding" Value="4,3" />
                </Style>
            </TreeView.ItemContainerStyle>

            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                    <StackPanel Orientation="Horizontal" Margin="2,2">
                        <Viewbox Width="{DynamicResource Size.IconMD}"
                                 Height="{DynamicResource Size.IconMD}"
                                 VerticalAlignment="Center"
                                 Margin="0,0,6,0"
                                 Visibility="{Binding HasCustomIcon, Converter={StaticResource BoolToVis}}">
                            <Path Data="{Binding CustomIconPath, TargetNullValue='M0 0'}"
                                  Fill="{DynamicResource PrimaryBrush}"
                                  Stretch="Uniform" />
                        </Viewbox>
                        <materialDesign:PackIcon
                            Kind="{Binding IconKind, Converter={StaticResource IconKindConverter}}"
                            Width="{DynamicResource Size.IconMD}"
                            Height="{DynamicResource Size.IconMD}"
                            Foreground="{DynamicResource PrimaryBrush}"
                            VerticalAlignment="Center"
                            Margin="0,0,6,0"
                            Visibility="{Binding HasCustomIcon, Converter={StaticResource InverseBoolToVis}}" />
                        <TextBlock Text="{Binding Name}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>

        <!-- ═══ Feature panel (slides in when a drive is selected) ═══ -->
        <Border x:Name="FeaturePanel" Grid.Row="1"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource DividerBrush}"
                BorderThickness="0,1,0,0"
                ClipToBounds="True" Height="0">
            <StackPanel x:Name="FeatureContent" Margin="0,2,0,2">
                <!-- Selected drive label -->
                <TextBlock x:Name="TxtSelectedDrive" Text="Drive A"
                           FontSize="{DynamicResource FontSizeXS}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondary}"
                           HorizontalAlignment="Center" Margin="0,1,0,3" />
                <!-- 3 feature buttons in a row -->
                <UniformGrid Columns="3" Height="28">
                    <Button x:Name="BtnParam" Click="OnParamClick"
                            Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="TableCog" Width="14" Height="14"
                                Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,4,0" />
                            <TextBlock Text="{DynamicResource loc.drivetree.param}" FontSize="{DynamicResource FontSizeXS}"
                                       Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnGraph" Click="OnGraphClick"
                            Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ChartBellCurveCumulative" Width="14" Height="14"
                                Foreground="{DynamicResource SuccessBrush}" VerticalAlignment="Center" Margin="0,0,4,0" />
                            <TextBlock Text="{DynamicResource loc.drivetree.graph}" FontSize="{DynamicResource FontSizeXS}"
                                       Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnChart" Click="OnChartClick"
                            Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="GamepadVariant" Width="14" Height="14"
                                Foreground="{DynamicResource WarningBrush}" VerticalAlignment="Center" Margin="0,0,4,0" />
                            <TextBlock Text="{DynamicResource loc.drivetree.control}" FontSize="{DynamicResource FontSizeXS}"
                                       Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </UniformGrid>
            </StackPanel>
        </Border>

        <!-- ═══ A/B/C/D drive buttons (always visible) ═══ -->
        <Border Grid.Row="2"
                Background="{DynamicResource SurfaceVariantBrush}"
                BorderBrush="{DynamicResource DividerBrush}"
                BorderThickness="0,1,0,0">
            <UniformGrid Columns="4" Height="32">
                <Button x:Name="BtnDriveA" Tag="A" Click="OnDriveClick"
                        Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="{DynamicResource loc.drivetree.tooltip.drivea}">
                    <TextBlock x:Name="TxtDriveA" Text="A" FontWeight="Bold"
                               FontSize="{DynamicResource FontSizeMD}"
                               Foreground="{DynamicResource TextSecondary}"
                               HorizontalAlignment="Center" />
                </Button>
                <Button x:Name="BtnDriveB" Tag="B" Click="OnDriveClick"
                        Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="{DynamicResource loc.drivetree.tooltip.driveb}">
                    <TextBlock x:Name="TxtDriveB" Text="B" FontWeight="Bold"
                               FontSize="{DynamicResource FontSizeMD}"
                               Foreground="{DynamicResource TextSecondary}"
                               HorizontalAlignment="Center" />
                </Button>
                <Button x:Name="BtnDriveC" Tag="C" Click="OnDriveClick"
                        Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="{DynamicResource loc.drivetree.tooltip.drivec}">
                    <TextBlock x:Name="TxtDriveC" Text="C" FontWeight="Bold"
                               FontSize="{DynamicResource FontSizeMD}"
                               Foreground="{DynamicResource TextSecondary}"
                               HorizontalAlignment="Center" />
                </Button>
                <Button x:Name="BtnDriveD" Tag="D" Click="OnDriveClick"
                        Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="{DynamicResource loc.drivetree.tooltip.drived}">
                    <TextBlock x:Name="TxtDriveD" Text="D" FontWeight="Bold"
                               FontSize="{DynamicResource FontSizeMD}"
                               Foreground="{DynamicResource TextSecondary}"
                               HorizontalAlignment="Center" />
                </Button>
            </UniformGrid>
        </Border>
    </Grid>
</UserControl>
