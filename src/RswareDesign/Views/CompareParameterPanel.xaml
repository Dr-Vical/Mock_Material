<UserControl x:Class="RswareDesign.Views.CompareParameterPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:models="clr-namespace:RswareDesign.Models"
             xmlns:converters="clr-namespace:RswareDesign.Converters"
             Background="{DynamicResource SurfaceBrush}"
             BorderBrush="{DynamicResource DividerBrush}"
             BorderThickness="1">

    <UserControl.Resources>
        <converters:StringToPackIconKindConverter x:Key="IconKindConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header: panel label + progress + close -->
        <Border Grid.Row="0"
                Background="{Binding HeaderBrush, RelativeSource={RelativeSource AncestorType=UserControl}}"
                BorderBrush="{DynamicResource DividerBrush}"
                BorderThickness="0,0,0,1"
                Padding="{StaticResource Padding.PanelHeader}">
            <DockPanel>
                <!-- Close button (rightmost) -->
                <Button DockPanel.Dock="Right"
                        Click="OnCloseClick"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="4,2"
                        Cursor="Hand"
                        ToolTip="{DynamicResource loc.compare.tooltip.close}"
                        VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="Close"
                                             Width="14" Height="14"
                                             Foreground="{DynamicResource TextSecondary}" />
                </Button>
                <!-- Loading progress (left of close) -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="10,0,6,0">
                    <TextBlock x:Name="progressText"
                               Text="{Binding LoadedCount, RelativeSource={RelativeSource AncestorType=UserControl}, FallbackValue='0'}"
                               FontSize="{DynamicResource FontSizeXS}"
                               FontFamily="{DynamicResource FontFamilyCode}"
                               Foreground="{DynamicResource TextSecondary}"
                               VerticalAlignment="Center" />
                    <TextBlock Text="/"
                               FontSize="{DynamicResource FontSizeXS}"
                               FontFamily="{DynamicResource FontFamilyCode}"
                               Foreground="{DynamicResource TextDisabled}"
                               Margin="2,0"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{Binding TotalCount, RelativeSource={RelativeSource AncestorType=UserControl}, FallbackValue='0'}"
                               FontSize="{DynamicResource FontSizeXS}"
                               FontFamily="{DynamicResource FontFamilyCode}"
                               Foreground="{DynamicResource TextSecondary}"
                               VerticalAlignment="Center" />
                    <ProgressBar Value="{Binding LoadedCount, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                 Maximum="{Binding TotalCount, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                 Width="48" Height="4"
                                 VerticalAlignment="Center"
                                 Margin="8,0,0,0"
                                 Background="{DynamicResource SurfaceVariantBrush}"
                                 Foreground="{Binding LabelBrush, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                </StackPanel>
                <!-- Panel label -->
                <TextBlock Text="{Binding PanelLabel, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           FontSize="{DynamicResource FontSizeMD}"
                           FontWeight="Bold"
                           FontFamily="{DynamicResource FontFamilyUI}"
                           Foreground="{Binding LabelBrush, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <!-- Content: DataGrid + Action buttons (flush right) -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Parameter grid -->
            <DataGrid x:Name="parameterGrid"
                      Grid.Column="0"
                      ItemsSource="{Binding PanelParameters, RelativeSource={RelativeSource AncestorType=UserControl}}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserSortColumns="False"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      PreviewMouseLeftButtonDown="Grid_PreviewMouseLeftButtonDown"
                      PreviewMouseMove="Grid_PreviewMouseMove"
                      PreviewMouseLeftButtonUp="Grid_PreviewMouseLeftButtonUp"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      RowHeight="{DynamicResource Size.GridRowHeight}"
                      ColumnHeaderHeight="{DynamicResource Size.GridHeaderHeight}"
                      Background="{DynamicResource SurfaceBrush}"
                      Foreground="{DynamicResource TextPrimary}"
                      BorderThickness="0"
                      FontFamily="{DynamicResource FontFamilyCode}"
                      FontSize="{DynamicResource FontSizeSM}"
                      HorizontalGridLinesBrush="{DynamicResource DividerBrush}"
                      AlternatingRowBackground="{DynamicResource GridAlternatingRowBrush}"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="{DynamicResource GridHeaderBrush}" />
                        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Setter Property="FontFamily" Value="{DynamicResource FontFamilyUI}" />
                        <Setter Property="FontSize" Value="{DynamicResource FontSizeSM}" />
                        <Setter Property="Padding" Value="{DynamicResource Padding.GridCell}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
                        <Setter Property="BorderThickness" Value="0,0,1,1" />
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="{DynamicResource Padding.GridCell}" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Padding="{TemplateBinding Padding}"
                                            Background="{TemplateBinding Background}">
                                        <ContentPresenter VerticalAlignment="Center" />
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SelectedRowBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="Transparent" />
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SelectedRowBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SurfaceVariantBrush}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <!-- ★ Favorite toggle (DataGridCheckBoxColumn — single-click guaranteed) -->
                    <DataGridCheckBoxColumn Header="★" Width="30"
                                            Binding="{Binding IsFavorite, UpdateSourceTrigger=PropertyChanged}">
                        <DataGridCheckBoxColumn.ElementStyle>
                            <Style TargetType="CheckBox">
                                <Setter Property="HorizontalAlignment" Value="Center" />
                                <Setter Property="Cursor" Value="Hand" />
                                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                <Setter Property="Validation.ErrorTemplate" Value="{x:Null}" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="CheckBox">
                                            <Grid Background="Transparent">
                                                <materialDesign:PackIcon x:Name="star" Kind="StarOutline"
                                                    Width="14" Height="14"
                                                    Foreground="{DynamicResource TextDisabled}"
                                                    HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="star" Property="Kind" Value="Star" />
                                                    <Setter TargetName="star" Property="Foreground" Value="{DynamicResource WarningBrush}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGridCheckBoxColumn.ElementStyle>
                        <DataGridCheckBoxColumn.EditingElementStyle>
                            <Style TargetType="CheckBox">
                                <Setter Property="HorizontalAlignment" Value="Center" />
                                <Setter Property="Cursor" Value="Hand" />
                                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                <Setter Property="Validation.ErrorTemplate" Value="{x:Null}" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="CheckBox">
                                            <Grid Background="Transparent">
                                                <materialDesign:PackIcon x:Name="star" Kind="StarOutline"
                                                    Width="14" Height="14"
                                                    Foreground="{DynamicResource TextDisabled}"
                                                    HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="star" Property="Kind" Value="Star" />
                                                    <Setter TargetName="star" Property="Foreground" Value="{DynamicResource WarningBrush}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGridCheckBoxColumn.EditingElementStyle>
                    </DataGridCheckBoxColumn>

                    <!-- FT NUM -->
                    <DataGridTextColumn Header="{DynamicResource loc.compare.col.ftnum}"
                                        Binding="{Binding ShortNumber}"
                                        IsReadOnly="True"
                                        Width="65" MinWidth="65">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="{DynamicResource loc.compare.col.parameter}"
                                        Binding="{Binding Name}"
                                        IsReadOnly="True"
                                        Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="{DynamicResource loc.compare.col.value}"
                                        Binding="{Binding Value, UpdateSourceTrigger=LostFocus}"
                                        Width="55" MinWidth="55">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource ValueHighlightBrush}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- UNITS, DEFAULT, MIN, MAX -->
                    <DataGridTextColumn Header="{DynamicResource loc.compare.col.units}"
                                        Binding="{Binding Unit}"
                                        IsReadOnly="True"
                                        Width="80">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="{DynamicResource loc.compare.col.default}"
                                        Binding="{Binding Default}"
                                        IsReadOnly="True"
                                        Width="65">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="{DynamicResource loc.compare.col.min}"
                                        Binding="{Binding Min}"
                                        IsReadOnly="True"
                                        Width="80">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="{DynamicResource loc.compare.col.max}"
                                        Binding="{Binding Max}"
                                        IsReadOnly="True"
                                        Width="80">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Action buttons (flush right, after MAX) -->
            <Border Grid.Column="1"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource DividerBrush}"
                    BorderThickness="1,0,0,0"
                    Padding="4,0">
                <ItemsControl x:Name="actionItemsControl"
                              VerticalAlignment="Top"
                              Margin="2,4" />
            </Border>
        </Grid>
    </Grid>
</UserControl>
