<UserControl x:Class="RswareDesign.Views.CompareParameterPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:models="clr-namespace:RswareDesign.Models"
             xmlns:converters="clr-namespace:RswareDesign.Converters"
             Background="{DynamicResource SurfaceBrush}"
             BorderBrush="{DynamicResource DividerBrush}"
             BorderThickness="1">

    <UserControl.Resources>
        <converters:StringToPackIconKindConverter x:Key="IconKindConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header: panel label + progress + close (compact) -->
        <Border Grid.Row="0"
                Background="{Binding HeaderBrush, RelativeSource={RelativeSource AncestorType=UserControl}}"
                BorderBrush="{DynamicResource DividerBrush}"
                BorderThickness="0,0,0,1"
                Padding="8,2">
            <DockPanel>
                <!-- Close button (rightmost) -->
                <Button DockPanel.Dock="Right"
                        Click="OnCloseClick"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="4,1"
                        Cursor="Hand"
                        ToolTip="Close Panel">
                    <materialDesign:PackIcon Kind="Close"
                                             Width="12" Height="12"
                                             Foreground="{DynamicResource TextSecondary}" />
                </Button>
                <!-- Loading progress (left of close) -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="8,0,4,0">
                    <TextBlock x:Name="progressText"
                               Text="{Binding LoadedCount, RelativeSource={RelativeSource AncestorType=UserControl}, FallbackValue='0'}"
                               FontSize="{DynamicResource FontSizeXS}"
                               FontFamily="{DynamicResource FontFamilyCode}"
                               Foreground="{DynamicResource TextSecondary}"
                               VerticalAlignment="Center" />
                    <TextBlock Text="/"
                               FontSize="{DynamicResource FontSizeXS}"
                               FontFamily="{DynamicResource FontFamilyCode}"
                               Foreground="{DynamicResource TextDisabled}"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{Binding TotalCount, RelativeSource={RelativeSource AncestorType=UserControl}, FallbackValue='0'}"
                               FontSize="{DynamicResource FontSizeXS}"
                               FontFamily="{DynamicResource FontFamilyCode}"
                               Foreground="{DynamicResource TextSecondary}"
                               VerticalAlignment="Center" />
                    <ProgressBar Value="{Binding LoadedCount, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                 Maximum="{Binding TotalCount, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                 Width="40" Height="4"
                                 VerticalAlignment="Center"
                                 Margin="6,0,0,0"
                                 Background="{DynamicResource SurfaceVariantBrush}"
                                 Foreground="{Binding LabelBrush, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                </StackPanel>
                <!-- Panel label -->
                <TextBlock Text="{Binding PanelLabel, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           FontSize="{DynamicResource FontSizeSM}"
                           FontWeight="Bold"
                           FontFamily="{DynamicResource FontFamilyUI}"
                           Foreground="{Binding LabelBrush, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <!-- Content: DataGrid (left) + Action buttons (right) -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Parameter grid -->
            <DataGrid Grid.Column="0"
                      ItemsSource="{Binding Parameters}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      RowHeight="{DynamicResource Size.GridRowHeight}"
                      ColumnHeaderHeight="{DynamicResource Size.GridHeaderHeight}"
                      Background="{DynamicResource SurfaceBrush}"
                      Foreground="{DynamicResource TextPrimary}"
                      BorderThickness="0"
                      FontFamily="{DynamicResource FontFamilyCode}"
                      FontSize="{DynamicResource FontSizeSM}"
                      HorizontalGridLinesBrush="{DynamicResource DividerBrush}"
                      AlternatingRowBackground="{DynamicResource GridAlternatingRowBrush}">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="{DynamicResource GridHeaderBrush}" />
                        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Setter Property="FontFamily" Value="{DynamicResource FontFamilyUI}" />
                        <Setter Property="FontSize" Value="{DynamicResource FontSizeSM}" />
                        <Setter Property="Padding" Value="{StaticResource Padding.GridCell}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
                        <Setter Property="BorderThickness" Value="0,0,1,1" />
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="{StaticResource Padding.GridCell}" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Padding="{TemplateBinding Padding}"
                                            Background="{TemplateBinding Background}">
                                        <ContentPresenter VerticalAlignment="Center" />
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SelectedRowBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="Transparent" />
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SelectedRowBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SurfaceVariantBrush}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <!-- Priority 0: FT NUM, PARAMETER, VALUE — kept visible, font scales last -->
                    <DataGridTextColumn Header="FT NUM"
                                        Binding="{Binding FtNumber}"
                                        IsReadOnly="True"
                                        Width="80">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="PARAMETER"
                                        Binding="{Binding Name}"
                                        IsReadOnly="True"
                                        Width="220">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="VALUE"
                                        Binding="{Binding Value}"
                                        Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource ValueHighlightBrush}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Priority 1: UNITS, DEFAULT, MIN, MAX — shrinks/hides first -->
                    <DataGridTextColumn Header="UNITS"
                                        Binding="{Binding Unit}"
                                        IsReadOnly="True"
                                        Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="DEFAULT"
                                        Binding="{Binding Default}"
                                        IsReadOnly="True"
                                        Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="MIN"
                                        Binding="{Binding Min}"
                                        IsReadOnly="True"
                                        Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="MAX"
                                        Binding="{Binding Max}"
                                        IsReadOnly="True"
                                        Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Action buttons (right sidebar — template-driven) -->
            <Border Grid.Column="1"
                    Background="{DynamicResource SurfaceVariantBrush}"
                    BorderBrush="{DynamicResource DividerBrush}"
                    BorderThickness="1,0,0,0"
                    Width="100">
                <ItemsControl x:Name="actionItemsControl"
                              Margin="6,6" />
            </Border>
        </Grid>
    </Grid>
</UserControl>
