<Window x:Class="RswareDesign.Views.PrintPreviewDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Print Preview"
        Width="900" Height="700"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        Background="Transparent"
        TextElement.Foreground="{DynamicResource TextPrimary}"
        TextElement.FontFamily="{DynamicResource FontFamilyUI}"
        TextElement.FontSize="{DynamicResource FontSizeMD}">

    <Border Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource RSBlueBrush}"
            BorderThickness="2"
            CornerRadius="{StaticResource Radius.LG}"
            Margin="4">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Background="{DynamicResource SurfaceVariantBrush}"
                    CornerRadius="8,8,0,0"
                    Padding="12,8" MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="FileEye"
                                                 Width="{StaticResource Size.IconMD}"
                                                 Height="{StaticResource Size.IconMD}"
                                                 Foreground="{DynamicResource PrimaryBrush}"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,8,0" />
                        <TextBlock Text="Print Preview"
                                   FontSize="{DynamicResource FontSizeLG}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"
                                   VerticalAlignment="Center" />
                        <TextBlock x:Name="TxtPageInfo"
                                   Margin="16,0,0,0"
                                   FontSize="{DynamicResource FontSizeSM}"
                                   Foreground="{DynamicResource TextSecondary}"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Style="{StaticResource MaterialDesignFlatButton}"
                                Content="Print"
                                Foreground="{DynamicResource PrimaryBrush}"
                                Click="BtnPrint_Click"
                                Margin="0,0,4,0" />
                        <Button Style="{StaticResource MaterialDesignIconButton}"
                                Click="BtnClose_Click"
                                Width="28" Height="28">
                            <materialDesign:PackIcon Kind="Close"
                                                     Width="16" Height="16"
                                                     Foreground="{DynamicResource TextSecondary}" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Document Viewer -->
            <DocumentViewer x:Name="Viewer" Grid.Row="1" />
        </Grid>
    </Border>
</Window>
