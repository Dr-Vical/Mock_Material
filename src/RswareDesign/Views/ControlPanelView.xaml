<UserControl x:Class="RswareDesign.Views.ControlPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{DynamicResource SurfaceVariantBrush}">

    <Grid>
    <Border x:Name="EnableBorder" BorderThickness="2" BorderBrush="Transparent"
            CornerRadius="{StaticResource Radius.MD}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="8,6">

            <!-- ═══ Axis Status Monitor ═══ -->
            <TextBlock Text="Axis Status Monitor" FontSize="{DynamicResource FontSizeSM}"
                       FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"
                       Margin="0,0,0,6" />

            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="4" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="4" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Card 1: ACTUAL POSITION -->
                <Border Grid.Column="0" Background="{DynamicResource SurfaceVariantBrush}"
                        CornerRadius="{StaticResource Radius.MD}" Padding="8,6">
                    <StackPanel>
                        <TextBlock Text="ACTUAL POSITION" FontSize="{DynamicResource FontSizeXS}"
                                   Foreground="{DynamicResource TextSecondary}" FontWeight="SemiBold"
                                   Margin="0,0,0,4" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                            <TextBlock x:Name="TxtPositionValue" Text="0.00"
                                       FontSize="{DynamicResource FontSizeXXL}" FontWeight="Bold"
                                       FontFamily="{DynamicResource FontFamilyCode}"
                                       Foreground="{DynamicResource SuccessBrush}" />
                            <TextBlock Text=" mm" FontSize="{DynamicResource FontSizeSM}"
                                       Foreground="{DynamicResource SuccessBrush}"
                                       VerticalAlignment="Bottom" Margin="0,0,0,2" />
                        </StackPanel>
                        <!-- Progress bar -->
                        <Grid x:Name="PositionBarGrid" Height="4" Margin="0,2,0,4">
                            <Border Background="{DynamicResource BackgroundBrush}" CornerRadius="2" />
                            <Border x:Name="PositionProgressBar" Background="{DynamicResource SuccessBrush}"
                                    CornerRadius="2" HorizontalAlignment="Left" Width="0" />
                        </Grid>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock x:Name="TxtPositionRange" Text="-1,000 ~ 3,000 mm"
                                       FontSize="{DynamicResource FontSizeXS}"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontFamily="{DynamicResource FontFamilyCode}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Card 2: ACTUAL VELOCITY -->
                <Border Grid.Column="2" Background="{DynamicResource SurfaceVariantBrush}"
                        CornerRadius="{StaticResource Radius.MD}" Padding="8,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="ACTUAL VELOCITY" FontSize="{DynamicResource FontSizeXS}"
                                       Foreground="{DynamicResource TextSecondary}" FontWeight="SemiBold"
                                       Margin="0,0,0,4" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                <TextBlock x:Name="TxtVelocityValue" Text="0"
                                           FontSize="{DynamicResource FontSizeXXL}" FontWeight="Bold"
                                           FontFamily="{DynamicResource FontFamilyCode}"
                                           Foreground="{DynamicResource SuccessBrush}" />
                                <TextBlock Text=" rpm" FontSize="{DynamicResource FontSizeSM}"
                                           Foreground="{DynamicResource SuccessBrush}"
                                           VerticalAlignment="Bottom" Margin="0,0,0,2" />
                            </StackPanel>
                            <TextBlock x:Name="TxtVelocityMax" Text="3,900 rpm"
                                       FontSize="{DynamicResource FontSizeXS}"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontFamily="{DynamicResource FontFamilyCode}"
                                       HorizontalAlignment="Left" Margin="0,4,0,0" />
                        </StackPanel>
                        <Canvas x:Name="VelocityArcGauge" Grid.Column="1"
                                Width="48" Height="48" VerticalAlignment="Center" Margin="4,0,0,0" />
                    </Grid>
                </Border>

                <!-- Card 3: ACTUAL LOAD -->
                <Border Grid.Column="4" Background="{DynamicResource SurfaceVariantBrush}"
                        CornerRadius="{StaticResource Radius.MD}" Padding="8,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="ACTUAL LOAD" FontSize="{DynamicResource FontSizeXS}"
                                       Foreground="{DynamicResource TextSecondary}" FontWeight="SemiBold"
                                       Margin="0,0,0,4" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                <TextBlock x:Name="TxtLoadValue" Text="0"
                                           FontSize="{DynamicResource FontSizeXXL}" FontWeight="Bold"
                                           FontFamily="{DynamicResource FontFamilyCode}"
                                           Foreground="{DynamicResource TextPrimary}" />
                                <TextBlock Text=" %" FontSize="{DynamicResource FontSizeSM}"
                                           Foreground="{DynamicResource TextPrimary}"
                                           VerticalAlignment="Bottom" Margin="0,0,0,2" />
                            </StackPanel>
                        </StackPanel>
                        <Grid Grid.Column="1" Width="28" Margin="4,0,0,0" VerticalAlignment="Center">
                            <StackPanel>
                                <TextBlock Text="300%" FontSize="8"
                                           Foreground="{DynamicResource TextSecondary}"
                                           FontFamily="{DynamicResource FontFamilyCode}"
                                           HorizontalAlignment="Center" Margin="0,0,0,2" />
                                <Border Height="40" Background="{DynamicResource BackgroundBrush}"
                                        CornerRadius="2">
                                    <Border x:Name="LoadBarFill" Background="{DynamicResource SecondaryBrush}"
                                            CornerRadius="2" VerticalAlignment="Bottom" Height="0" />
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <Rectangle Height="1" Fill="{DynamicResource DividerBrush}" Margin="0,2,0,6" />

            <!-- ═══ Control Buttons ═══ -->
            <DockPanel Margin="0,0,0,4">
                <TextBlock x:Name="TxtEnableStatus" DockPanel.Dock="Right"
                           Text="● Disabled" FontSize="{DynamicResource FontSizeXS}"
                           Foreground="{DynamicResource ErrorBrush}"
                           FontFamily="{DynamicResource FontFamilyCode}"
                           VerticalAlignment="Center" />
                <TextBlock Text="Control" FontSize="{DynamicResource FontSizeSM}"
                           FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" />
            </DockPanel>

            <!-- Row 1: Enable / Disable / Clear Fault -->
            <UniformGrid Columns="3" Margin="0,0,0,2">
                <Button Margin="2,1" Padding="4,1" Cursor="Hand" Background="{DynamicResource SuccessBrush}" Foreground="{DynamicResource TextOnPrimary}" BorderThickness="0" Click="BtnEnable_Click">
                    <StackPanel Orientation="Horizontal"><materialDesign:PackIcon Kind="Play" Width="11" Height="11" VerticalAlignment="Center" Margin="0,0,2,0" /><TextBlock Text="Enable" FontSize="{DynamicResource FontSizeXS}" VerticalAlignment="Center" /></StackPanel>
                </Button>
                <Button Margin="2,1" Padding="4,1" Cursor="Hand" Background="{DynamicResource ErrorBrush}" Foreground="{DynamicResource TextOnPrimary}" BorderThickness="0" Click="BtnDisable_Click">
                    <StackPanel Orientation="Horizontal"><materialDesign:PackIcon Kind="Stop" Width="11" Height="11" VerticalAlignment="Center" Margin="0,0,2,0" /><TextBlock Text="Disable" FontSize="{DynamicResource FontSizeXS}" VerticalAlignment="Center" /></StackPanel>
                </Button>
                <Button Margin="2,1" Padding="4,1" Cursor="Hand" Background="{DynamicResource WarningBrush}" Foreground="#212121" BorderThickness="0" Click="BtnClearFault_Click">
                    <StackPanel Orientation="Horizontal"><materialDesign:PackIcon Kind="AlertRemove" Width="11" Height="11" VerticalAlignment="Center" Margin="0,0,2,0" /><TextBlock Text="Clear Fault" FontSize="{DynamicResource FontSizeXS}" VerticalAlignment="Center" /></StackPanel>
                </Button>
            </UniformGrid>

            <!-- Row 2: Jog- / Jog+ / Zero Set -->
            <UniformGrid Columns="3" Margin="0,0,0,2">
                <Button x:Name="BtnJogMinus" Margin="2,1" Padding="4,2" Cursor="Hand" BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1" Background="Transparent" Foreground="{DynamicResource TextPrimary}"
                        PreviewMouseLeftButtonDown="BtnJogMinus_Down" PreviewMouseLeftButtonUp="BtnJog_Up">
                    <TextBlock Text="Jog -" FontSize="{DynamicResource FontSizeXS}" VerticalAlignment="Center" />
                </Button>
                <Button x:Name="BtnJogPlus" Margin="2,1" Padding="4,2" Cursor="Hand" BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1" Background="Transparent" Foreground="{DynamicResource TextPrimary}"
                        PreviewMouseLeftButtonDown="BtnJogPlus_Down" PreviewMouseLeftButtonUp="BtnJog_Up">
                    <TextBlock Text="Jog +" FontSize="{DynamicResource FontSizeXS}" VerticalAlignment="Center" />
                </Button>
                <Button Margin="2,1" Padding="4,2" Cursor="Hand" BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1" Background="Transparent" Foreground="{DynamicResource TextPrimary}" Click="BtnZeroSet_Click">
                    <StackPanel Orientation="Horizontal"><materialDesign:PackIcon Kind="Numeric0CircleOutline" Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,2,0" /><TextBlock Text="Zero Set" FontSize="{DynamicResource FontSizeXS}" VerticalAlignment="Center" /></StackPanel>
                </Button>
            </UniformGrid>

            <Rectangle Height="1" Fill="{DynamicResource DividerBrush}" Margin="0,6,0,6" />

            <!-- ═══ Input Fields ═══ -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Target Speed :" Foreground="{DynamicResource TextSecondary}" FontSize="{DynamicResource FontSizeXS}" VerticalAlignment="Center" Margin="0,0,6,3" />
                <TextBox Grid.Row="0" Grid.Column="1" Text="500" Background="{DynamicResource SurfaceVariantBrush}" Foreground="{DynamicResource ValueHighlightBrush}" BorderBrush="{DynamicResource BorderDefault}" FontFamily="{DynamicResource FontFamilyCode}" FontSize="{DynamicResource FontSizeXS}" Padding="5,2" Margin="0,0,0,3" />

                <!-- Tgt Pos: 2-column reciprocating targets -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Target Position :" Foreground="{DynamicResource TextSecondary}" FontSize="{DynamicResource FontSizeXS}" VerticalAlignment="Center" Margin="0,0,6,3" />
                <Grid Grid.Row="1" Grid.Column="1" Margin="0,0,0,3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" x:Name="TxtTgtPosA" Text="-500"
                             Background="{DynamicResource SurfaceVariantBrush}" Foreground="{DynamicResource ValueHighlightBrush}"
                             BorderBrush="{DynamicResource BorderDefault}" FontFamily="{DynamicResource FontFamilyCode}"
                             FontSize="{DynamicResource FontSizeXS}" Padding="5,2" />
                    <TextBlock Grid.Column="1" Text="↔" Foreground="{DynamicResource TextSecondary}"
                               FontSize="{DynamicResource FontSizeXS}" VerticalAlignment="Center" Margin="4,0" />
                    <TextBox Grid.Column="2" x:Name="TxtTgtPosB" Text="2000"
                             Background="{DynamicResource SurfaceVariantBrush}" Foreground="{DynamicResource ValueHighlightBrush}"
                             BorderBrush="{DynamicResource BorderDefault}" FontFamily="{DynamicResource FontFamilyCode}"
                             FontSize="{DynamicResource FontSizeXS}" Padding="5,2" />
                </Grid>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Current Limit :" Foreground="{DynamicResource TextSecondary}" FontSize="{DynamicResource FontSizeXS}" VerticalAlignment="Center" Margin="0,0,6,0" />
                <TextBox Grid.Row="2" Grid.Column="1" Text="100" Background="{DynamicResource SurfaceVariantBrush}" Foreground="{DynamicResource ValueHighlightBrush}" BorderBrush="{DynamicResource BorderDefault}" FontFamily="{DynamicResource FontFamilyCode}" FontSize="{DynamicResource FontSizeXS}" Padding="5,2" />
            </Grid>

            <!-- ═══ Motion Controls ═══ -->
            <UniformGrid Columns="4" Margin="0,6,0,0">
                <CheckBox x:Name="ChkReciprocate" Content="왕복" Margin="2,1" Foreground="{DynamicResource TextPrimary}" FontSize="{DynamicResource FontSizeXS}" VerticalContentAlignment="Center" />
                <Button Margin="2,1" Padding="4,2" Cursor="Hand" BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1" Background="Transparent" Foreground="{DynamicResource TextPrimary}" Click="BtnMoveAbs_Click">
                    <TextBlock Text="Move ABS" FontSize="{DynamicResource FontSizeXS}" VerticalAlignment="Center" />
                </Button>
                <Button Margin="2,1" Padding="4,2" Cursor="Hand" BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1" Background="Transparent" Foreground="{DynamicResource TextPrimary}" Click="BtnMoveRel_Click">
                    <TextBlock Text="Move Rel" FontSize="{DynamicResource FontSizeXS}" VerticalAlignment="Center" />
                </Button>
                <Button Margin="2,1" Padding="4,2" Cursor="Hand" BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1" Background="Transparent" Foreground="{DynamicResource TextPrimary}" Click="BtnMoveZero_Click">
                    <TextBlock Text="Move Zero" FontSize="{DynamicResource FontSizeXS}" VerticalAlignment="Center" />
                </Button>
            </UniformGrid>
        </StackPanel>
    </ScrollViewer>
    </Border>
    </Grid>
</UserControl>
