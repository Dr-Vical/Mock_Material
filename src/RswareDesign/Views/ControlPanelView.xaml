<UserControl x:Class="RswareDesign.Views.ControlPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{DynamicResource BackgroundBrush}">

    <Grid>
    <Border x:Name="EnableBorder" BorderThickness="2" BorderBrush="Transparent"
            CornerRadius="{StaticResource Radius.MD}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="8,6">

            <!-- ═══ Axis Status Monitor ═══ -->
            <TextBlock Text="{DynamicResource loc.control.axismonitor}" FontSize="{DynamicResource FontSizeSM}"
                       FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"
                       Margin="0,0,0,6" />

            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="4" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="4" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Card 1: ACTUAL POSITION -->
                <Border Grid.Column="0" Background="{DynamicResource SurfaceVariantBrush}"
                        CornerRadius="{StaticResource Radius.MD}" Padding="8,6">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource loc.control.position}" FontSize="{DynamicResource FontSizeXS}"
                                   Foreground="{DynamicResource TextSecondary}" FontWeight="SemiBold"
                                   Margin="0,0,0,4" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                            <TextBlock x:Name="TxtPositionValue" Text="0.00"
                                       FontSize="{DynamicResource FontSizeXXL}" FontWeight="Bold"
                                       FontFamily="{DynamicResource FontFamilyCode}"
                                       Foreground="{DynamicResource SuccessBrush}" />
                            <TextBlock Text=" mm" FontSize="{DynamicResource FontSizeSM}"
                                       Foreground="{DynamicResource SuccessBrush}"
                                       VerticalAlignment="Bottom" Margin="0,0,0,2" />
                        </StackPanel>
                        <!-- Progress bar with target marker -->
                        <Grid x:Name="PositionBarGrid" Height="8" Margin="0,2,0,4">
                            <Border Background="{DynamicResource SurfaceVariantBrush}" CornerRadius="2" />
                            <Border x:Name="PositionProgressBar" Background="{DynamicResource SuccessBrush}"
                                    CornerRadius="2" HorizontalAlignment="Left" Width="0" Height="4"
                                    VerticalAlignment="Center" />
                            <!-- Target position red marker -->
                            <Border x:Name="TargetPositionMarker" Width="2" Height="8"
                                    Background="{DynamicResource ErrorBrush}"
                                    HorizontalAlignment="Left" Margin="0"
                                    CornerRadius="1" />
                        </Grid>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock x:Name="TxtPositionRange" Text="-1,000 ~ 3,000 mm"
                                       FontSize="{DynamicResource FontSizeXS}"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontFamily="{DynamicResource FontFamilyCode}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Card 2: ACTUAL VELOCITY -->
                <Border Grid.Column="2" Background="{DynamicResource SurfaceVariantBrush}"
                        CornerRadius="{StaticResource Radius.MD}" Padding="8,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{DynamicResource loc.control.velocity}" FontSize="{DynamicResource FontSizeXS}"
                                       Foreground="{DynamicResource TextSecondary}" FontWeight="SemiBold"
                                       Margin="0,0,0,4" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                <TextBlock x:Name="TxtVelocityValue" Text="0"
                                           FontSize="{DynamicResource FontSizeXXL}" FontWeight="Bold"
                                           FontFamily="{DynamicResource FontFamilyCode}"
                                           Foreground="{DynamicResource SuccessBrush}" />
                                <TextBlock Text=" rpm" FontSize="{DynamicResource FontSizeSM}"
                                           Foreground="{DynamicResource SuccessBrush}"
                                           VerticalAlignment="Bottom" Margin="0,0,0,2" />
                            </StackPanel>
                            <TextBlock x:Name="TxtVelocityMax" Text="3,900 rpm"
                                       FontSize="{DynamicResource FontSizeXS}"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontFamily="{DynamicResource FontFamilyCode}"
                                       HorizontalAlignment="Left" Margin="0,4,0,0" />
                        </StackPanel>
                        <Canvas x:Name="VelocityArcGauge" Grid.Column="1"
                                Width="48" Height="48" VerticalAlignment="Center" Margin="4,0,0,0" />
                    </Grid>
                </Border>

                <!-- Card 3: ACTUAL LOAD -->
                <Border Grid.Column="4" Background="{DynamicResource SurfaceVariantBrush}"
                        CornerRadius="{StaticResource Radius.MD}" Padding="8,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" HorizontalAlignment="Right" Margin="0,0,10,0">
                            <TextBlock Text="{DynamicResource loc.control.load}" FontSize="{DynamicResource FontSizeXS}"
                                       Foreground="{DynamicResource TextSecondary}" FontWeight="SemiBold"
                                       Margin="0,0,0,4" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                <TextBlock x:Name="TxtLoadValue" Text="0"
                                           FontSize="{DynamicResource FontSizeXXL}" FontWeight="Bold"
                                           FontFamily="{DynamicResource FontFamilyCode}"
                                           Foreground="{DynamicResource TextPrimary}" />
                                <TextBlock Text=" %" FontSize="{DynamicResource FontSizeSM}"
                                           Foreground="{DynamicResource TextPrimary}"
                                           VerticalAlignment="Bottom" Margin="0,0,0,2" />
                            </StackPanel>
                        </StackPanel>
                        <Grid Grid.Column="1" Width="28" Margin="4,0,0,0" VerticalAlignment="Center">
                            <StackPanel>
                                <TextBlock Text="300%" FontSize="8"
                                           Foreground="{DynamicResource TextSecondary}"
                                           FontFamily="{DynamicResource FontFamilyCode}"
                                           HorizontalAlignment="Center" Margin="0,0,0,2" />
                                <Border Height="40" Background="{DynamicResource SurfaceVariantBrush}"
                                        CornerRadius="2">
                                    <Border x:Name="LoadBarFill" CornerRadius="2" VerticalAlignment="Bottom" Height="0">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0.5,1" EndPoint="0.5,0">
                                                <GradientStop Color="#FF66BB6A" Offset="0" />
                                                <GradientStop Color="#FFFFD54F" Offset="0.5" />
                                                <GradientStop Color="#FFEF5350" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <Rectangle Height="1" Fill="{DynamicResource DividerBrush}" Margin="0,2,0,6" />

            <!-- ═══ Control Buttons ═══ -->
            <DockPanel Margin="0,0,0,4">
                <TextBlock x:Name="TxtEnableStatus" DockPanel.Dock="Right"
                           Text="{DynamicResource loc.control.status.disabled}" FontSize="{DynamicResource FontSizeXS}"
                           Foreground="{DynamicResource ErrorBrush}"
                           FontFamily="{DynamicResource FontFamilyCode}"
                           VerticalAlignment="Center" />
                <TextBlock Text="{DynamicResource loc.control.title}" FontSize="{DynamicResource FontSizeSM}"
                           FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" />
            </DockPanel>

            <!-- Row 1: Enable / Disable / Clear Fault -->
            <UniformGrid Columns="3" Margin="0,0,0,2">
                <Button Margin="2,1" Padding="4,1" Cursor="Hand" Foreground="{DynamicResource TextOnPrimary}" BorderThickness="0" Click="BtnEnable_Click">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FF5BA85B" Offset="0" />
                            <GradientStop Color="#FF3D8B3D" Offset="1" />
                        </LinearGradientBrush>
                    </Button.Background>
                    <StackPanel Orientation="Horizontal"><materialDesign:PackIcon Kind="Play" Width="11" Height="11" VerticalAlignment="Center" Margin="0,0,2,0" /><TextBlock Text="{DynamicResource loc.control.enable}" FontSize="{DynamicResource FontSizeXS}" VerticalAlignment="Center" /></StackPanel>
                </Button>
                <Button Margin="2,1" Padding="4,1" Cursor="Hand" Foreground="{DynamicResource TextOnPrimary}" BorderThickness="0" Click="BtnDisable_Click">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FFD04848" Offset="0" />
                            <GradientStop Color="#FFB03030" Offset="1" />
                        </LinearGradientBrush>
                    </Button.Background>
                    <StackPanel Orientation="Horizontal"><materialDesign:PackIcon Kind="Stop" Width="11" Height="11" VerticalAlignment="Center" Margin="0,0,2,0" /><TextBlock Text="{DynamicResource loc.control.disable}" FontSize="{DynamicResource FontSizeXS}" VerticalAlignment="Center" /></StackPanel>
                </Button>
                <Button Margin="2,1" Padding="4,1" Cursor="Hand" Foreground="#212121" BorderThickness="0" Click="BtnClearFault_Click">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FFE0C040" Offset="0" />
                            <GradientStop Color="#FFC0A030" Offset="1" />
                        </LinearGradientBrush>
                    </Button.Background>
                    <StackPanel Orientation="Horizontal"><materialDesign:PackIcon Kind="AlertRemove" Width="11" Height="11" VerticalAlignment="Center" Margin="0,0,2,0" /><TextBlock Text="{DynamicResource loc.control.clearfault}" FontSize="{DynamicResource FontSizeXS}" VerticalAlignment="Center" /></StackPanel>
                </Button>
            </UniformGrid>

            <!-- Row 2: Jog- / Jog+ / Zero Set -->
            <UniformGrid Columns="3" Margin="0,0,0,2">
                <Button x:Name="BtnJogMinus" Margin="2,1" Padding="4,2" Cursor="Hand" BorderThickness="0" Foreground="{DynamicResource TextPrimary}"
                        PreviewMouseLeftButtonDown="BtnJogMinus_Down" PreviewMouseLeftButtonUp="BtnJog_Up">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FF484848" Offset="0" />
                            <GradientStop Color="#FF383838" Offset="1" />
                        </LinearGradientBrush>
                    </Button.Background>
                    <TextBlock Text="{DynamicResource loc.control.jogminus}" FontSize="{DynamicResource FontSizeXS}" VerticalAlignment="Center" />
                </Button>
                <Button x:Name="BtnJogPlus" Margin="2,1" Padding="4,2" Cursor="Hand" BorderThickness="0" Foreground="{DynamicResource TextPrimary}"
                        PreviewMouseLeftButtonDown="BtnJogPlus_Down" PreviewMouseLeftButtonUp="BtnJog_Up">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FF484848" Offset="0" />
                            <GradientStop Color="#FF383838" Offset="1" />
                        </LinearGradientBrush>
                    </Button.Background>
                    <TextBlock Text="{DynamicResource loc.control.jogplus}" FontSize="{DynamicResource FontSizeXS}" VerticalAlignment="Center" />
                </Button>
                <Button Margin="2,1" Padding="4,2" Cursor="Hand" BorderThickness="0" Foreground="{DynamicResource TextPrimary}" Click="BtnZeroSet_Click">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FF484848" Offset="0" />
                            <GradientStop Color="#FF383838" Offset="1" />
                        </LinearGradientBrush>
                    </Button.Background>
                    <StackPanel Orientation="Horizontal"><materialDesign:PackIcon Kind="Numeric0CircleOutline" Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,2,0" /><TextBlock Text="{DynamicResource loc.control.zeroset}" FontSize="{DynamicResource FontSizeXS}" VerticalAlignment="Center" /></StackPanel>
                </Button>
            </UniformGrid>

            <Rectangle Height="1" Fill="{DynamicResource DividerBrush}" Margin="0,6,0,6" />

            <!-- ═══ Input Fields ═══ -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource loc.control.targetspeed}" Foreground="{DynamicResource TextSecondary}" FontSize="{DynamicResource FontSizeXS}" VerticalAlignment="Center" Margin="0,0,6,3" />
                <TextBox x:Name="TxtTargetSpeed" Grid.Row="0" Grid.Column="1" Text="500" Background="{DynamicResource SurfaceVariantBrush}" Foreground="{DynamicResource ValueHighlightBrush}" BorderBrush="{DynamicResource BorderDefault}" FontFamily="{DynamicResource FontFamilyCode}" FontSize="{DynamicResource FontSizeXS}" Padding="5,2" Margin="0,0,0,3" />

                <!-- Tgt Pos: 2-column reciprocating targets -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource loc.control.targetposition}" Foreground="{DynamicResource TextSecondary}" FontSize="{DynamicResource FontSizeXS}" VerticalAlignment="Center" Margin="0,0,6,3" />
                <Grid Grid.Row="1" Grid.Column="1" Margin="0,0,0,3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" x:Name="TxtTgtPosA" Text="-500"
                             Background="{DynamicResource SurfaceVariantBrush}" Foreground="{DynamicResource ValueHighlightBrush}"
                             BorderBrush="{DynamicResource BorderDefault}" FontFamily="{DynamicResource FontFamilyCode}"
                             FontSize="{DynamicResource FontSizeXS}" Padding="5,2" />
                    <TextBlock Grid.Column="1" Text="↔" Foreground="{DynamicResource TextSecondary}"
                               FontSize="{DynamicResource FontSizeXS}" VerticalAlignment="Center" Margin="4,0" />
                    <TextBox Grid.Column="2" x:Name="TxtTgtPosB" Text="2000"
                             Background="{DynamicResource SurfaceVariantBrush}" Foreground="{DynamicResource ValueHighlightBrush}"
                             BorderBrush="{DynamicResource BorderDefault}" FontFamily="{DynamicResource FontFamilyCode}"
                             FontSize="{DynamicResource FontSizeXS}" Padding="5,2" />
                </Grid>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource loc.control.currentlimit}" Foreground="{DynamicResource TextSecondary}" FontSize="{DynamicResource FontSizeXS}" VerticalAlignment="Center" Margin="0,0,6,0" />
                <TextBox Grid.Row="2" Grid.Column="1" Text="100" Background="{DynamicResource SurfaceVariantBrush}" Foreground="{DynamicResource ValueHighlightBrush}" BorderBrush="{DynamicResource BorderDefault}" FontFamily="{DynamicResource FontFamilyCode}" FontSize="{DynamicResource FontSizeXS}" Padding="5,2" />
            </Grid>

            <!-- ═══ Motion Controls ═══ -->
            <UniformGrid Columns="4" Margin="0,6,0,0">
                <CheckBox x:Name="ChkReciprocate" Content="{DynamicResource loc.control.reciprocate}" Margin="2,1" Foreground="{DynamicResource TextPrimary}" FontSize="{DynamicResource FontSizeXS}" VerticalContentAlignment="Center" />
                <Button Margin="2,1" Padding="4,2" Cursor="Hand" Foreground="#1A1A1A" BorderThickness="0" Click="BtnMoveAbs_Click">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FFFFFFFF" Offset="0" />
                            <GradientStop Color="#FFD8D8D8" Offset="1" />
                        </LinearGradientBrush>
                    </Button.Background>
                    <TextBlock Text="{DynamicResource loc.control.moveabs}" FontSize="{DynamicResource FontSizeXS}" FontWeight="SemiBold" VerticalAlignment="Center" />
                </Button>
                <Button Margin="2,1" Padding="4,2" Cursor="Hand" Foreground="#1A1A1A" BorderThickness="0" Click="BtnMoveRel_Click">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FFFFFFFF" Offset="0" />
                            <GradientStop Color="#FFD8D8D8" Offset="1" />
                        </LinearGradientBrush>
                    </Button.Background>
                    <TextBlock Text="{DynamicResource loc.control.moverel}" FontSize="{DynamicResource FontSizeXS}" FontWeight="SemiBold" VerticalAlignment="Center" />
                </Button>
                <Button Margin="2,1" Padding="4,2" Cursor="Hand" Foreground="#1A1A1A" BorderThickness="0" Click="BtnMoveZero_Click">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FFFFFFFF" Offset="0" />
                            <GradientStop Color="#FFD8D8D8" Offset="1" />
                        </LinearGradientBrush>
                    </Button.Background>
                    <TextBlock Text="{DynamicResource loc.control.movezero}" FontSize="{DynamicResource FontSizeXS}" FontWeight="SemiBold" VerticalAlignment="Center" />
                </Button>
            </UniformGrid>
        </StackPanel>
    </ScrollViewer>
    </Border>
    </Grid>
</UserControl>
