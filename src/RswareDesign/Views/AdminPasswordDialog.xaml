<Window x:Class="RswareDesign.Views.AdminPasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="{DynamicResource loc.dialog.adminauth.title}"
        Width="360" Height="200"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource SurfaceBrush}"
        TextElement.Foreground="{DynamicResource TextPrimary}"
        TextElement.FontFamily="{DynamicResource FontFamilyUI}"
        TextElement.FontSize="{DynamicResource FontSizeMD}">

    <Grid Margin="{StaticResource Padding.Dialog}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <materialDesign:PackIcon Kind="ShieldLock"
                                     Width="{StaticResource Size.IconXL}"
                                     Height="{StaticResource Size.IconXL}"
                                     Foreground="{DynamicResource SecondaryBrush}"
                                     VerticalAlignment="Center"
                                     Margin="{StaticResource Margin.Inline}" />
            <TextBlock Text="{DynamicResource loc.dialog.adminauth}"
                       FontSize="{DynamicResource FontSizeLG}"
                       Foreground="{DynamicResource TextPrimary}"
                       VerticalAlignment="Center" />
        </StackPanel>

        <!-- Password -->
        <PasswordBox x:Name="PasswordInput" Grid.Row="1"
                     materialDesign:HintAssist.Hint="{DynamicResource loc.dialog.adminauth.hint}"
                     FontSize="{DynamicResource FontSizeMD}"
                     Margin="{StaticResource Margin.FormField}" />

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{DynamicResource loc.btn.cancel}"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Margin="{StaticResource Margin.Inline}"
                    Click="BtnCancel_Click" />
            <Button Content="{DynamicResource loc.btn.ok}"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Click="BtnOk_Click" />
        </StackPanel>
    </Grid>
</Window>
