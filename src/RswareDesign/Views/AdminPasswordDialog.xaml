<Window x:Class="RswareDesign.Views.AdminPasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="{DynamicResource loc.dialog.adminauth.title}"
        Width="360" Height="220"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="Transparent"
        TextElement.Foreground="{DynamicResource TextPrimary}"
        TextElement.FontFamily="{DynamicResource FontFamilyUI}"
        TextElement.FontSize="{DynamicResource FontSizeMD}">

    <Border Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource RSBlueBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource Radius.LG}"
            Margin="8"
            Effect="{StaticResource MaterialDesignShadowDepth3}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0"
                    Background="{DynamicResource RSBlueBrush}"
                    CornerRadius="8,8,0,0"
                    Padding="12,8"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="ShieldLock"
                                                 Width="{StaticResource Size.IconLG}"
                                                 Height="{StaticResource Size.IconLG}"
                                                 Foreground="{DynamicResource TextOnPrimary}"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,8,0" />
                        <TextBlock Text="{DynamicResource loc.dialog.adminauth}"
                                   FontSize="{DynamicResource FontSizeLG}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextOnPrimary}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Padding="4" MinWidth="0" Width="28" Height="28"
                            Click="BtnCancel_Click">
                        <materialDesign:PackIcon Kind="Close" Width="16" Height="16"
                                                 Foreground="{DynamicResource TextOnPrimary}" />
                    </Button>
                </Grid>
            </Border>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="{StaticResource Padding.Dialog}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Password -->
                <PasswordBox x:Name="PasswordInput" Grid.Row="0"
                             materialDesign:HintAssist.Hint="{DynamicResource loc.dialog.adminauth.hint}"
                             FontSize="{DynamicResource FontSizeMD}"
                             Margin="{StaticResource Margin.FormField}" />

                <!-- Buttons -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="{DynamicResource loc.btn.cancel}"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Margin="{StaticResource Margin.Inline}"
                            Click="BtnCancel_Click" />
                    <Button Content="{DynamicResource loc.btn.ok}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Click="BtnOk_Click" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
