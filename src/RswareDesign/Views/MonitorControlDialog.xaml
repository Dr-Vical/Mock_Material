<UserControl x:Class="RswareDesign.Views.MonitorControlDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:scottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
             Background="{DynamicResource BackgroundBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="200" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition x:Name="FavoritesColumn" Width="220" MinWidth="150" MaxWidth="440" />
        </Grid.ColumnDefinitions>

        <!-- NOTE: Column order: 0=Chart, 1=Splitter, 2=Favorites(Toggle embedded) -->

        <!-- ══════════════════════════════════════════ -->
        <!--  Column 0: Chart Area                      -->
        <!-- ══════════════════════════════════════════ -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition x:Name="ChartRow" Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Toolbar -->
            <Border x:Name="ChartToolbar" Grid.Row="0"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderDefault}"
                    BorderThickness="0,0,0,1"
                    Padding="6,3">
                <StackPanel>
                    <!-- Row 1: Controls + Progress -->
                    <DockPanel>
                        <!-- Right: Progress Bar -->
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="8,0,0,0" VerticalAlignment="Center">
                            <ProgressBar x:Name="CollectingProgress" Width="100" Height="10"
                                         Minimum="0" Maximum="100" Value="0"
                                         Visibility="Collapsed" Margin="0,0,4,0"
                                         Foreground="{DynamicResource SecondaryBrush}"
                                         Background="{DynamicResource SurfaceVariantBrush}" />
                            <TextBlock x:Name="TxtCollecting" Text="Collecting..."
                                       FontSize="{DynamicResource FontSizeXS}"
                                       Foreground="{DynamicResource SecondaryBrush}"
                                       VerticalAlignment="Center"
                                       Visibility="Collapsed" />
                        </StackPanel>
                        <!-- Left: Buttons -->
                        <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Click="BtnSingle_Click" Height="22"
                                    Padding="4,1" Margin="0,0,3,0"
                                    ToolTip="Single Capture">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ChartLine" Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,3,0" />
                                    <TextBlock Text="Single" VerticalAlignment="Center" FontSize="{DynamicResource FontSizeXS}" />
                                </StackPanel>
                            </Button>
                            <Button Click="BtnContinuous_Click" Height="22"
                                    Padding="4,1" Margin="0,0,3,0"
                                    ToolTip="Continuous Capture">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Refresh" Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,3,0" />
                                    <TextBlock Text="Contin" VerticalAlignment="Center" FontSize="{DynamicResource FontSizeXS}" />
                                </StackPanel>
                            </Button>
                            <Button Click="BtnStop_Click" Height="22"
                                    Padding="4,1" Margin="0,0,3,0"
                                    ToolTip="Stop">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Stop" Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,3,0" />
                                    <TextBlock Text="Stop" VerticalAlignment="Center" FontSize="{DynamicResource FontSizeXS}" />
                                </StackPanel>
                            </Button>
                            <Button Click="BtnAutoScale_Click" Height="22"
                                    Padding="4,1" Margin="0,0,3,0"
                                    ToolTip="Auto Scale">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ArrowExpandVertical" Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,3,0" />
                                    <TextBlock Text="Auto" VerticalAlignment="Center" FontSize="{DynamicResource FontSizeXS}" />
                                </StackPanel>
                            </Button>
                            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="3,2,6,2" />
                            <Button Click="BtnOption_Click" Height="22"
                                    Padding="4,1" Margin="0,0,3,0"
                                    ToolTip="Oscilloscope Settings">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Cog" Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,3,0" />
                                    <TextBlock Text="Setting" VerticalAlignment="Center" FontSize="{DynamicResource FontSizeXS}" />
                                </StackPanel>
                            </Button>
                            <Button Click="BtnSaveSetting_Click" Height="22"
                                    Padding="4,1" Margin="0,0,3,0"
                                    ToolTip="Save Scope Setting">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ContentSave" Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,3,0" />
                                    <TextBlock Text="Save" VerticalAlignment="Center" FontSize="{DynamicResource FontSizeXS}" />
                                </StackPanel>
                            </Button>
                            <Button Click="BtnLoadSetting_Click" Height="22"
                                    Padding="4,1" Margin="0,0,0,0"
                                    ToolTip="Load Scope Setting">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="FolderOpen" Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,3,0" />
                                    <TextBlock Text="Load" VerticalAlignment="Center" FontSize="{DynamicResource FontSizeXS}" />
                                </StackPanel>
                            </Button>
                        </WrapPanel>
                    </DockPanel>

                    <!-- Row 2: Channel Selectors -->
                    <WrapPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <!-- CH1 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,6,0">
                            <CheckBox x:Name="ChkCh1" IsChecked="True" VerticalAlignment="Center" Margin="0,0,2,0"
                                      Checked="Channel_Changed" Unchecked="Channel_Changed" />
                            <Ellipse x:Name="EllipseCh1" Fill="{DynamicResource ChartCH1Brush}" Width="8" Height="8"
                                     VerticalAlignment="Center" Margin="0,0,3,0" Cursor="Hand"
                                     Tag="0" MouseLeftButtonDown="ChannelColor_Click" />
                            <ComboBox x:Name="CmbCh1" Tag="0" Width="175" MaxDropDownHeight="300"
                                      FontSize="{DynamicResource FontSizeXS}"
                                      Background="{DynamicResource SurfaceVariantBrush}"
                                      Foreground="{DynamicResource ChartCH1Brush}"
                                      BorderBrush="{DynamicResource BorderDefault}"
                                      SelectionChanged="ChannelCombo_SelectionChanged" />
                        </StackPanel>
                        <!-- CH2 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,6,0">
                            <CheckBox x:Name="ChkCh2" IsChecked="True" VerticalAlignment="Center" Margin="0,0,2,0"
                                      Checked="Channel_Changed" Unchecked="Channel_Changed" />
                            <Ellipse x:Name="EllipseCh2" Fill="{DynamicResource ChartCH2Brush}" Width="8" Height="8"
                                     VerticalAlignment="Center" Margin="0,0,3,0" Cursor="Hand"
                                     Tag="1" MouseLeftButtonDown="ChannelColor_Click" />
                            <ComboBox x:Name="CmbCh2" Tag="1" Width="175" MaxDropDownHeight="300"
                                      FontSize="{DynamicResource FontSizeXS}"
                                      Background="{DynamicResource SurfaceVariantBrush}"
                                      Foreground="{DynamicResource ChartCH2Brush}"
                                      BorderBrush="{DynamicResource BorderDefault}"
                                      SelectionChanged="ChannelCombo_SelectionChanged" />
                        </StackPanel>
                        <!-- CH3 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,6,0">
                            <CheckBox x:Name="ChkCh3" IsChecked="True" VerticalAlignment="Center" Margin="0,0,2,0"
                                      Checked="Channel_Changed" Unchecked="Channel_Changed" />
                            <Ellipse x:Name="EllipseCh3" Fill="{DynamicResource ChartCH3Brush}" Width="8" Height="8"
                                     VerticalAlignment="Center" Margin="0,0,3,0" Cursor="Hand"
                                     Tag="2" MouseLeftButtonDown="ChannelColor_Click" />
                            <ComboBox x:Name="CmbCh3" Tag="2" Width="175" MaxDropDownHeight="300"
                                      FontSize="{DynamicResource FontSizeXS}"
                                      Background="{DynamicResource SurfaceVariantBrush}"
                                      Foreground="{DynamicResource ChartCH3Brush}"
                                      BorderBrush="{DynamicResource BorderDefault}"
                                      SelectionChanged="ChannelCombo_SelectionChanged" />
                        </StackPanel>
                        <!-- CH4 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                            <CheckBox x:Name="ChkCh4" IsChecked="True" VerticalAlignment="Center" Margin="0,0,2,0"
                                      Checked="Channel_Changed" Unchecked="Channel_Changed" />
                            <Ellipse x:Name="EllipseCh4" Fill="{DynamicResource ChartCH4Brush}" Width="8" Height="8"
                                     VerticalAlignment="Center" Margin="0,0,3,0" Cursor="Hand"
                                     Tag="3" MouseLeftButtonDown="ChannelColor_Click" />
                            <ComboBox x:Name="CmbCh4" Tag="3" Width="175" MaxDropDownHeight="300"
                                      FontSize="{DynamicResource FontSizeXS}"
                                      Background="{DynamicResource SurfaceVariantBrush}"
                                      Foreground="{DynamicResource ChartCH4Brush}"
                                      BorderBrush="{DynamicResource BorderDefault}"
                                      SelectionChanged="ChannelCombo_SelectionChanged" />
                        </StackPanel>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- Chart area with Scale Groups -->
            <Grid x:Name="ChartArea" Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- ═══ Scale Panel ═══ -->
                <Border x:Name="ScalePanel" Grid.Column="0" Width="148"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource DividerBrush}"
                        BorderThickness="0,0,1,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                  Padding="6,4">
                        <StackPanel x:Name="ScaleGroupsPanel" />
                    </ScrollViewer>
                </Border>

                <!-- Scale Panel Toggle -->
                <Button x:Name="BtnToggleScale" Grid.Column="1" Click="ToggleScalePanel_Click"
                        Width="18" Background="{DynamicResource SurfaceVariantBrush}"
                        BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,0,1,0"
                        Cursor="Hand" ToolTip="Toggle Scale Panel" Padding="0">
                    <materialDesign:PackIcon x:Name="ScaleToggleIcon" Kind="ChevronLeft"
                        Width="14" Height="14" Foreground="{DynamicResource TextSecondary}" />
                </Button>

                <!-- Chart -->
                <scottPlot:WpfPlot x:Name="MonitorPlot" Grid.Column="2" />
            </Grid>

            <!-- Status bar -->
            <Border x:Name="ChartStatusBar" Grid.Row="2" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderDefault}" BorderThickness="0,1,0,0" Padding="6,2">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="4 CH | 10 kHz | " Foreground="{DynamicResource TextSecondary}" FontSize="{DynamicResource FontSizeXS}" />
                    <TextBlock x:Name="TxtStatus" Text="Stopped" Foreground="{DynamicResource SecondaryBrush}" FontSize="{DynamicResource FontSizeXS}" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- GridSplitter for resizable Favorites -->
        <GridSplitter x:Name="FavoritesSplitter" Grid.Column="1" Width="4"
                      HorizontalAlignment="Center" VerticalAlignment="Stretch"
                      Background="{DynamicResource DividerBrush}" Cursor="SizeWE" />

        <!-- ══════════════════════════════════════════ -->
        <!--  Column 2: Toggle + Favorite Parameter     -->
        <!-- ══════════════════════════════════════════ -->
        <Grid x:Name="FavoritesContent" Grid.Column="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Favorites Toggle -->
            <Button x:Name="BtnToggleFavorites" Grid.Column="0" Click="ToggleFavoritesPanel_Click"
                    Width="18" Background="{DynamicResource SurfaceVariantBrush}"
                    BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,0,1,0"
                    Cursor="Hand" ToolTip="Toggle Favorite Parameter" Padding="0">
                <materialDesign:PackIcon x:Name="FavoritesToggleIcon" Kind="ChevronRight"
                    Width="14" Height="14" Foreground="{DynamicResource WarningBrush}" />
            </Button>

            <Border x:Name="FavoritesInnerContent" Grid.Column="1"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,0,0,1" Padding="8,5">
                    <DockPanel>
                        <TextBlock x:Name="FavCountText" DockPanel.Dock="Right"
                                   FontSize="{DynamicResource FontSizeXS}"
                                   Foreground="{DynamicResource TextSecondary}"
                                   VerticalAlignment="Center" />
                        <Button DockPanel.Dock="Left" Click="ClearAllFavorites_Click"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" Padding="2" Margin="0,0,4,0"
                                ToolTip="Clear all favorites">
                            <materialDesign:PackIcon Kind="Star" Width="14" Height="14"
                                                     Foreground="{DynamicResource WarningBrush}" />
                        </Button>
                        <TextBlock Text="Favorite Parameter"
                                   FontSize="{DynamicResource FontSizeSM}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource WarningBrush}"
                                   VerticalAlignment="Center" />
                    </DockPanel>
                </Border>

                <ListBox x:Name="FavoritesListBox" Grid.Row="1"
                         Background="Transparent" BorderThickness="0" Padding="4,2"
                         KeyDown="FavList_KeyDown"
                         PreviewMouseLeftButtonDown="FavList_PreviewMouseLeftButtonDown"
                         PreviewMouseMove="FavList_PreviewMouseMove"
                         PreviewMouseLeftButtonUp="FavList_PreviewMouseLeftButtonUp">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
                            <Setter Property="Padding" Value="5,3" />
                            <Setter Property="Margin" Value="0,1" />
                            <Setter Property="Cursor" Value="Hand" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                Padding="{TemplateBinding Padding}"
                                                CornerRadius="{StaticResource Radius.SM}"
                                                BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SurfaceVariantBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SelectedRowBrush}" />
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="44" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="45" />
                                </Grid.ColumnDefinitions>
                                <ToggleButton Grid.Column="0" IsChecked="{Binding IsFavorite, Mode=TwoWay}"
                                              Background="Transparent" BorderThickness="0"
                                              Cursor="Hand" Padding="0" Margin="0,0,3,0"
                                              Width="16" Height="16"
                                              PreviewMouseLeftButtonDown="FavStar_Click">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <materialDesign:PackIcon x:Name="StarIcon" Kind="Star"
                                                Width="14" Height="14"
                                                Foreground="{DynamicResource WarningBrush}" />
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="False">
                                                    <Setter TargetName="StarIcon" Property="Kind" Value="StarOutline" />
                                                    <Setter TargetName="StarIcon" Property="Foreground" Value="{DynamicResource TextSecondary}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                                <TextBlock Grid.Column="1" Text="{Binding ShortNumber}" FontFamily="{DynamicResource FontFamilyCode}" FontSize="{DynamicResource FontSizeXS}" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="2" Text="{Binding Name}" FontFamily="{DynamicResource FontFamilyCode}" FontSize="{DynamicResource FontSizeXS}" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                <TextBox Grid.Column="3" Text="{Binding Value, UpdateSourceTrigger=LostFocus}"
                                         FontFamily="{DynamicResource FontFamilyCode}" FontSize="{DynamicResource FontSizeXS}"
                                         Foreground="{DynamicResource ValueHighlightBrush}" FontWeight="SemiBold"
                                         Background="Transparent" BorderThickness="0"
                                         VerticalAlignment="Center" HorizontalAlignment="Right"
                                         Padding="2,0" MinWidth="30" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
        </Grid>

        <!-- Color Picker Popup -->
        <Popup x:Name="ColorPickerPopup" StaysOpen="True" Placement="Mouse" AllowsTransparency="True">
            <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderDefault}"
                    BorderThickness="1" CornerRadius="{StaticResource Radius.SM}" Padding="6">
                <WrapPanel x:Name="ColorSwatches" Width="160" />
            </Border>
        </Popup>
    </Grid>
</UserControl>
