<UserControl x:Class="RswareDesign.Views.MonitorControlDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:scottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
             Background="{DynamicResource BackgroundBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition x:Name="FavoritesColumn" Width="220" MinWidth="150" />
        </Grid.ColumnDefinitions>

        <!-- NOTE: Column order: 0=Chart, 1=Toggle, 2=Splitter, 3=Favorites -->

        <!-- ══════════════════════════════════════════ -->
        <!--  Column 0: Chart Area                      -->
        <!-- ══════════════════════════════════════════ -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition x:Name="ChartRow" Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Toolbar -->
            <Border x:Name="ChartToolbar" Grid.Row="0"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderDefault}"
                    BorderThickness="0,0,0,1"
                    Padding="6,3">
                <StackPanel>
                    <!-- Row 1: Controls + Progress -->
                    <DockPanel>
                        <!-- Right: Progress Bar -->
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="8,0,0,0" VerticalAlignment="Center">
                            <ProgressBar x:Name="CollectingProgress" Width="100" Height="10"
                                         Minimum="0" Maximum="100" Value="0"
                                         Visibility="Collapsed" Margin="0,0,4,0"
                                         Foreground="{DynamicResource SecondaryBrush}"
                                         Background="{DynamicResource SurfaceVariantBrush}" />
                            <TextBlock x:Name="TxtCollecting" Text="Collecting..."
                                       FontSize="{DynamicResource FontSizeXS}"
                                       Foreground="{DynamicResource SecondaryBrush}"
                                       VerticalAlignment="Center"
                                       Visibility="Collapsed" />
                        </StackPanel>
                        <!-- Left: Buttons -->
                        <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Click="BtnSingle_Click"
                                    Padding="{StaticResource Padding.Button.Small}" Margin="0,0,4,0"
                                    ToolTip="Single Capture">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ChartLine" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,4,0" />
                                    <TextBlock Text="Single" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Click="BtnContinuous_Click"
                                    Padding="{StaticResource Padding.Button.Small}" Margin="0,0,4,0"
                                    ToolTip="Continuous Capture">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Refresh" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,4,0" />
                                    <TextBlock Text="Continuous" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Click="BtnStop_Click"
                                    Padding="{StaticResource Padding.Button.Small}" Margin="0,0,4,0"
                                    ToolTip="Stop">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Stop" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,4,0" />
                                    <TextBlock Text="Stop" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Click="BtnAutoScale_Click"
                                    Padding="{StaticResource Padding.Button.Small}" Margin="0,0,4,0"
                                    ToolTip="Auto Scale">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ArrowExpandVertical" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,4,0" />
                                    <TextBlock Text="Auto Scale" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="4,2,8,2" />
                            <Button Click="BtnOption_Click"
                                    Padding="{StaticResource Padding.Button.Small}" Margin="0,0,0,0"
                                    ToolTip="Oscilloscope Settings">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Cog" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,4,0" />
                                    <TextBlock Text="Setting" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </WrapPanel>
                    </DockPanel>

                    <!-- Row 2: Channel Selectors -->
                    <WrapPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <!-- CH1 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,6,0">
                            <CheckBox x:Name="ChkCh1" IsChecked="True" VerticalAlignment="Center" Margin="0,0,2,0"
                                      Checked="Channel_Changed" Unchecked="Channel_Changed" />
                            <Ellipse Fill="{DynamicResource ChartCH1Brush}" Width="8" Height="8"
                                     VerticalAlignment="Center" Margin="0,0,3,0" />
                            <ComboBox x:Name="CmbCh1" Tag="0" Width="175" MaxDropDownHeight="300"
                                      FontSize="{DynamicResource FontSizeXS}"
                                      Background="{DynamicResource SurfaceVariantBrush}"
                                      Foreground="{DynamicResource ChartCH1Brush}"
                                      BorderBrush="{DynamicResource BorderDefault}"
                                      SelectionChanged="ChannelCombo_SelectionChanged" />
                        </StackPanel>
                        <!-- CH2 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,6,0">
                            <CheckBox x:Name="ChkCh2" IsChecked="True" VerticalAlignment="Center" Margin="0,0,2,0"
                                      Checked="Channel_Changed" Unchecked="Channel_Changed" />
                            <Ellipse Fill="{DynamicResource ChartCH2Brush}" Width="8" Height="8"
                                     VerticalAlignment="Center" Margin="0,0,3,0" />
                            <ComboBox x:Name="CmbCh2" Tag="1" Width="175" MaxDropDownHeight="300"
                                      FontSize="{DynamicResource FontSizeXS}"
                                      Background="{DynamicResource SurfaceVariantBrush}"
                                      Foreground="{DynamicResource ChartCH2Brush}"
                                      BorderBrush="{DynamicResource BorderDefault}"
                                      SelectionChanged="ChannelCombo_SelectionChanged" />
                        </StackPanel>
                        <!-- CH3 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,6,0">
                            <CheckBox x:Name="ChkCh3" IsChecked="True" VerticalAlignment="Center" Margin="0,0,2,0"
                                      Checked="Channel_Changed" Unchecked="Channel_Changed" />
                            <Ellipse Fill="{DynamicResource ChartCH3Brush}" Width="8" Height="8"
                                     VerticalAlignment="Center" Margin="0,0,3,0" />
                            <ComboBox x:Name="CmbCh3" Tag="2" Width="175" MaxDropDownHeight="300"
                                      FontSize="{DynamicResource FontSizeXS}"
                                      Background="{DynamicResource SurfaceVariantBrush}"
                                      Foreground="{DynamicResource ChartCH3Brush}"
                                      BorderBrush="{DynamicResource BorderDefault}"
                                      SelectionChanged="ChannelCombo_SelectionChanged" />
                        </StackPanel>
                        <!-- CH4 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                            <CheckBox x:Name="ChkCh4" IsChecked="True" VerticalAlignment="Center" Margin="0,0,2,0"
                                      Checked="Channel_Changed" Unchecked="Channel_Changed" />
                            <Ellipse Fill="{DynamicResource ChartCH4Brush}" Width="8" Height="8"
                                     VerticalAlignment="Center" Margin="0,0,3,0" />
                            <ComboBox x:Name="CmbCh4" Tag="3" Width="175" MaxDropDownHeight="300"
                                      FontSize="{DynamicResource FontSizeXS}"
                                      Background="{DynamicResource SurfaceVariantBrush}"
                                      Foreground="{DynamicResource ChartCH4Brush}"
                                      BorderBrush="{DynamicResource BorderDefault}"
                                      SelectionChanged="ChannelCombo_SelectionChanged" />
                        </StackPanel>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- Chart area with Scale Groups -->
            <Grid x:Name="ChartArea" Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- ═══ Scale Panel ═══ -->
                <Border x:Name="ScalePanel" Grid.Column="0" Width="148"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource DividerBrush}"
                        BorderThickness="0,0,1,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                  Padding="6,4">
                        <StackPanel>
                            <!-- Group 0: Position -->
                            <Border BorderThickness="3,0,0,0" BorderBrush="{DynamicResource ChartCH1Brush}"
                                    Background="{DynamicResource SurfaceVariantBrush}"
                                    CornerRadius="{StaticResource Radius.SM}" Padding="6,4" Margin="0,0,0,4">
                                <StackPanel>
                                    <DockPanel>
                                        <Button DockPanel.Dock="Right" Click="BtnAutoScaleGroup_Click" Tag="0"
                                                Background="Transparent" BorderThickness="0" Padding="2" Cursor="Hand"
                                                ToolTip="Auto Scale Position">
                                            <materialDesign:PackIcon Kind="ArrowExpandVertical" Width="12" Height="12"
                                                                     Foreground="{DynamicResource TextSecondary}" />
                                        </Button>
                                        <TextBlock FontSize="{DynamicResource FontSizeXS}" VerticalAlignment="Center">
                                            <Run Text="Position" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" />
                                            <Run Text=" (pulse)" Foreground="{DynamicResource TextSecondary}" />
                                        </TextBlock>
                                    </DockPanel>
                                    <Grid Margin="0,2,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="28" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Max" FontSize="{DynamicResource FontSizeXS}" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" />
                                        <TextBox x:Name="TxtMax0" Grid.Row="0" Grid.Column="1" Text="12000" Tag="0"
                                                 FontFamily="{DynamicResource FontFamilyCode}" FontSize="{DynamicResource FontSizeXS}"
                                                 Foreground="{DynamicResource ValueHighlightBrush}"
                                                 Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderDefault}"
                                                 Padding="3,1" Margin="0,0,0,1" LostFocus="ScaleValue_LostFocus" KeyDown="ScaleValue_KeyDown" />
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Min" FontSize="{DynamicResource FontSizeXS}" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" />
                                        <TextBox x:Name="TxtMin0" Grid.Row="1" Grid.Column="1" Text="-12000" Tag="0"
                                                 FontFamily="{DynamicResource FontFamilyCode}" FontSize="{DynamicResource FontSizeXS}"
                                                 Foreground="{DynamicResource ValueHighlightBrush}"
                                                 Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderDefault}"
                                                 Padding="3,1" LostFocus="ScaleValue_LostFocus" KeyDown="ScaleValue_KeyDown" />
                                    </Grid>
                                    <WrapPanel Margin="0,3,0,0">
                                        <Ellipse Fill="{DynamicResource ChartCH1Brush}" Width="6" Height="6" Margin="0,0,2,0" VerticalAlignment="Center" />
                                        <TextBlock Text="Cur" FontSize="{DynamicResource FontSizeXS}" Foreground="{DynamicResource ChartCH1Brush}" Margin="0,0,6,0" VerticalAlignment="Center" />
                                        <Ellipse Fill="{DynamicResource ChartCH2Brush}" Width="6" Height="6" Margin="0,0,2,0" VerticalAlignment="Center" />
                                        <TextBlock Text="Cmd" FontSize="{DynamicResource FontSizeXS}" Foreground="{DynamicResource ChartCH2Brush}" VerticalAlignment="Center" />
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <!-- Group 1: Velocity -->
                            <Border BorderThickness="3,0,0,0" BorderBrush="{DynamicResource ChartCH3Brush}"
                                    Background="{DynamicResource SurfaceVariantBrush}"
                                    CornerRadius="{StaticResource Radius.SM}" Padding="6,4" Margin="0,0,0,0">
                                <StackPanel>
                                    <DockPanel>
                                        <Button DockPanel.Dock="Right" Click="BtnAutoScaleGroup_Click" Tag="1"
                                                Background="Transparent" BorderThickness="0" Padding="2" Cursor="Hand"
                                                ToolTip="Auto Scale Velocity">
                                            <materialDesign:PackIcon Kind="ArrowExpandVertical" Width="12" Height="12"
                                                                     Foreground="{DynamicResource TextSecondary}" />
                                        </Button>
                                        <TextBlock FontSize="{DynamicResource FontSizeXS}" VerticalAlignment="Center">
                                            <Run Text="Velocity" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" />
                                            <Run Text=" (rpm)" Foreground="{DynamicResource TextSecondary}" />
                                        </TextBlock>
                                    </DockPanel>
                                    <Grid Margin="0,2,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="28" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Max" FontSize="{DynamicResource FontSizeXS}" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" />
                                        <TextBox x:Name="TxtMax1" Grid.Row="0" Grid.Column="1" Text="5000" Tag="1"
                                                 FontFamily="{DynamicResource FontFamilyCode}" FontSize="{DynamicResource FontSizeXS}"
                                                 Foreground="{DynamicResource ValueHighlightBrush}"
                                                 Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderDefault}"
                                                 Padding="3,1" Margin="0,0,0,1" LostFocus="ScaleValue_LostFocus" KeyDown="ScaleValue_KeyDown" />
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Min" FontSize="{DynamicResource FontSizeXS}" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" />
                                        <TextBox x:Name="TxtMin1" Grid.Row="1" Grid.Column="1" Text="-5000" Tag="1"
                                                 FontFamily="{DynamicResource FontFamilyCode}" FontSize="{DynamicResource FontSizeXS}"
                                                 Foreground="{DynamicResource ValueHighlightBrush}"
                                                 Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderDefault}"
                                                 Padding="3,1" LostFocus="ScaleValue_LostFocus" KeyDown="ScaleValue_KeyDown" />
                                    </Grid>
                                    <WrapPanel Margin="0,3,0,0">
                                        <Ellipse Fill="{DynamicResource ChartCH3Brush}" Width="6" Height="6" Margin="0,0,2,0" VerticalAlignment="Center" />
                                        <TextBlock Text="Cur" FontSize="{DynamicResource FontSizeXS}" Foreground="{DynamicResource ChartCH3Brush}" Margin="0,0,6,0" VerticalAlignment="Center" />
                                        <Ellipse Fill="{DynamicResource ChartCH4Brush}" Width="6" Height="6" Margin="0,0,2,0" VerticalAlignment="Center" />
                                        <TextBlock Text="Cmd" FontSize="{DynamicResource FontSizeXS}" Foreground="{DynamicResource ChartCH4Brush}" VerticalAlignment="Center" />
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- Scale Panel Toggle -->
                <Button x:Name="BtnToggleScale" Grid.Column="1" Click="ToggleScalePanel_Click"
                        Width="18" Background="{DynamicResource SurfaceVariantBrush}"
                        BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,0,1,0"
                        Cursor="Hand" ToolTip="Toggle Scale Panel" Padding="0">
                    <materialDesign:PackIcon x:Name="ScaleToggleIcon" Kind="ChevronLeft"
                        Width="14" Height="14" Foreground="{DynamicResource TextSecondary}" />
                </Button>

                <!-- Chart -->
                <scottPlot:WpfPlot x:Name="MonitorPlot" Grid.Column="2" />
            </Grid>

            <!-- Status bar -->
            <Border x:Name="ChartStatusBar" Grid.Row="2" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderDefault}" BorderThickness="0,1,0,0" Padding="6,2">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="4 CH | 10 kHz | " Foreground="{DynamicResource TextSecondary}" FontSize="{DynamicResource FontSizeXS}" />
                    <TextBlock x:Name="TxtStatus" Text="Stopped" Foreground="{DynamicResource SecondaryBrush}" FontSize="{DynamicResource FontSizeXS}" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Favorites Toggle (always visible, never squeezed) -->
        <Button x:Name="BtnToggleFavorites" Grid.Column="1" Click="ToggleFavoritesPanel_Click"
                Width="18" Background="{DynamicResource SurfaceVariantBrush}"
                BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,0,1,0"
                Cursor="Hand" ToolTip="Toggle Favorite Parameter" Padding="0">
            <materialDesign:PackIcon x:Name="FavoritesToggleIcon" Kind="ChevronRight"
                Width="14" Height="14" Foreground="{DynamicResource WarningBrush}" />
        </Button>

        <!-- GridSplitter for resizable Favorites -->
        <GridSplitter x:Name="FavoritesSplitter" Grid.Column="2" Width="4"
                      HorizontalAlignment="Center" VerticalAlignment="Stretch"
                      Background="{DynamicResource DividerBrush}" Cursor="SizeWE" />

        <!-- ══════════════════════════════════════════ -->
        <!--  Column 3: Favorite Parameter              -->
        <!-- ══════════════════════════════════════════ -->
        <Border x:Name="FavoritesContent" Grid.Column="3"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,0,0,1" Padding="8,5">
                    <DockPanel>
                        <TextBlock x:Name="FavCountText" DockPanel.Dock="Right"
                                   FontSize="{DynamicResource FontSizeXS}"
                                   Foreground="{DynamicResource TextSecondary}"
                                   VerticalAlignment="Center" />
                        <Button DockPanel.Dock="Left" Click="ClearAllFavorites_Click"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" Padding="2" Margin="0,0,4,0"
                                ToolTip="Clear all favorites">
                            <materialDesign:PackIcon Kind="Star" Width="14" Height="14"
                                                     Foreground="{DynamicResource WarningBrush}" />
                        </Button>
                        <TextBlock Text="Favorite Parameter"
                                   FontSize="{DynamicResource FontSizeSM}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource WarningBrush}"
                                   VerticalAlignment="Center" />
                    </DockPanel>
                </Border>

                <ListBox x:Name="FavoritesListBox" Grid.Row="1"
                         Background="Transparent" BorderThickness="0" Padding="4,2"
                         AllowDrop="True"
                         KeyDown="FavList_KeyDown"
                         PreviewMouseLeftButtonDown="FavList_PreviewMouseLeftButtonDown"
                         PreviewMouseMove="FavList_PreviewMouseMove"
                         Drop="FavList_Drop" DragOver="FavList_DragOver">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
                            <Setter Property="Padding" Value="5,3" />
                            <Setter Property="Margin" Value="0,1" />
                            <Setter Property="Cursor" Value="Hand" />
                            <Setter Property="AllowDrop" Value="True" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                Padding="{TemplateBinding Padding}"
                                                CornerRadius="{StaticResource Radius.SM}"
                                                BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SurfaceVariantBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SelectedRowBrush}" />
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="38" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="45" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding ShortNumber}" FontFamily="{DynamicResource FontFamilyCode}" FontSize="{DynamicResource FontSizeXS}" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="1" Text="{Binding Name}" FontFamily="{DynamicResource FontFamilyCode}" FontSize="{DynamicResource FontSizeXS}" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                <TextBox Grid.Column="2" Text="{Binding Value, UpdateSourceTrigger=LostFocus}"
                                         FontFamily="{DynamicResource FontFamilyCode}" FontSize="{DynamicResource FontSizeXS}"
                                         Foreground="{DynamicResource ValueHighlightBrush}" FontWeight="SemiBold"
                                         Background="Transparent" BorderThickness="0"
                                         VerticalAlignment="Center" HorizontalAlignment="Right"
                                         Padding="2,0" MinWidth="30" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
    </Grid>
</UserControl>
