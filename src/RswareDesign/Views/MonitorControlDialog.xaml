<UserControl x:Class="RswareDesign.Views.MonitorControlDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:scottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
             Background="{DynamicResource BackgroundBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition x:Name="FavoritesColumn" Width="220" MinWidth="150" />
        </Grid.ColumnDefinitions>

        <!-- GridSplitter for resizable Favorites -->
        <GridSplitter x:Name="FavoritesSplitter" Grid.Column="1" Width="4"
                      HorizontalAlignment="Center" VerticalAlignment="Stretch"
                      Background="{DynamicResource DividerBrush}"
                      Cursor="SizeWE" />

        <!-- ══════════════════════════════════════════ -->
        <!--  LEFT: Chart + Controls                    -->
        <!-- ══════════════════════════════════════════ -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition x:Name="ChartRow" Height="*" />
                <RowDefinition x:Name="ControlRow" Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Toolbar: Start/Stop + Channel toggles -->
            <Border x:Name="ChartToolbar" Grid.Row="0"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderDefault}"
                    BorderThickness="0,0,0,1"
                    Padding="6,3">
                <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnStartStop" Click="BtnStartStop_Click"
                            Padding="{StaticResource Padding.Button.Small}" Margin="0,0,6,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon x:Name="StartStopIcon" Kind="Play"
                                                     Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,4,0" />
                            <TextBlock x:Name="StartStopText" Text="Start" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Click="BtnAutoScale_Click"
                            Padding="{StaticResource Padding.Button.Small}" Margin="0,0,6,0"
                            ToolTip="Auto Scale">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ArrowExpandVertical"
                                                     Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,4,0" />
                            <TextBlock Text="Auto Scale" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="4,2,8,2" />
                    <CheckBox x:Name="ChkCh1" Content="Cont.Cur" IsChecked="True" Foreground="{DynamicResource ChartCH1Brush}" FontSize="{DynamicResource FontSizeXS}" Margin="0,0,5,0" Checked="Channel_Changed" Unchecked="Channel_Changed" />
                    <CheckBox x:Name="ChkCh2" Content="Tgt.Cur" IsChecked="True" Foreground="{DynamicResource ChartCH2Brush}" FontSize="{DynamicResource FontSizeXS}" Margin="0,0,5,0" Checked="Channel_Changed" Unchecked="Channel_Changed" />
                    <CheckBox x:Name="ChkCh3" Content="Vel" IsChecked="True" Foreground="{DynamicResource ChartCH3Brush}" FontSize="{DynamicResource FontSizeXS}" Margin="0,0,5,0" Checked="Channel_Changed" Unchecked="Channel_Changed" />
                    <CheckBox x:Name="ChkCh4" Content="Tgt.Vel" IsChecked="True" Foreground="{DynamicResource ChartCH4Brush}" FontSize="{DynamicResource FontSizeXS}" Margin="0,0,5,0" Checked="Channel_Changed" Unchecked="Channel_Changed" />
                    <CheckBox x:Name="ChkCh5" Content="Cur.Pos" IsChecked="True" Foreground="{DynamicResource ChartCH5Brush}" FontSize="{DynamicResource FontSizeXS}" Margin="0,0,5,0" Checked="Channel_Changed" Unchecked="Channel_Changed" />
                    <CheckBox x:Name="ChkCh6" Content="Cur.Pos2" IsChecked="True" Foreground="{DynamicResource ChartCH6Brush}" FontSize="{DynamicResource FontSizeXS}" Margin="0,0,5,0" Checked="Channel_Changed" Unchecked="Channel_Changed" />
                    <CheckBox x:Name="ChkCh7" Content="Error" IsChecked="True" Foreground="{DynamicResource ChartCH7Brush}" FontSize="{DynamicResource FontSizeXS}" Margin="0,0,5,0" Checked="Channel_Changed" Unchecked="Channel_Changed" />
                    <CheckBox x:Name="ChkCh8" Content="Inpos" IsChecked="True" Foreground="{DynamicResource ChartCH8Brush}" FontSize="{DynamicResource FontSizeXS}" Margin="0,0,5,0" Checked="Channel_Changed" Unchecked="Channel_Changed" />
                </WrapPanel>
            </Border>

            <!-- Chart area with Scale Groups -->
            <Grid x:Name="ChartArea" Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- ═══ Scale Panel ═══ -->
                <Border x:Name="ScalePanel" Grid.Column="0" Width="148"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource DividerBrush}"
                        BorderThickness="0,0,1,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                  Padding="6,4">
                        <StackPanel>

                            <!-- Group 0: Current -->
                            <Border BorderThickness="3,0,0,0" BorderBrush="{DynamicResource ChartCH1Brush}"
                                    Background="{DynamicResource SurfaceVariantBrush}"
                                    CornerRadius="{StaticResource Radius.SM}" Padding="6,4" Margin="0,0,0,4">
                                <StackPanel>
                                    <DockPanel>
                                        <Button DockPanel.Dock="Right" Click="BtnAutoScaleGroup_Click" Tag="0"
                                                Background="Transparent" BorderThickness="0" Padding="2" Cursor="Hand"
                                                ToolTip="Auto Scale Current">
                                            <materialDesign:PackIcon Kind="ArrowExpandVertical" Width="12" Height="12"
                                                                     Foreground="{DynamicResource TextSecondary}" />
                                        </Button>
                                        <TextBlock FontSize="{DynamicResource FontSizeXS}" VerticalAlignment="Center">
                                            <Run Text="Current" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" />
                                            <Run Text=" (A)" Foreground="{DynamicResource TextSecondary}" />
                                        </TextBlock>
                                    </DockPanel>
                                    <Grid Margin="0,2,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="28" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Max" FontSize="{DynamicResource FontSizeXS}" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" />
                                        <TextBox x:Name="TxtMax0" Grid.Row="0" Grid.Column="1" Text="3000" Tag="0"
                                                 FontFamily="{DynamicResource FontFamilyCode}" FontSize="{DynamicResource FontSizeXS}"
                                                 Foreground="{DynamicResource ValueHighlightBrush}"
                                                 Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderDefault}"
                                                 Padding="3,1" Margin="0,0,0,1" LostFocus="ScaleValue_LostFocus" KeyDown="ScaleValue_KeyDown" />
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Min" FontSize="{DynamicResource FontSizeXS}" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" />
                                        <TextBox x:Name="TxtMin0" Grid.Row="1" Grid.Column="1" Text="-3000" Tag="0"
                                                 FontFamily="{DynamicResource FontFamilyCode}" FontSize="{DynamicResource FontSizeXS}"
                                                 Foreground="{DynamicResource ValueHighlightBrush}"
                                                 Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderDefault}"
                                                 Padding="3,1" LostFocus="ScaleValue_LostFocus" KeyDown="ScaleValue_KeyDown" />
                                    </Grid>
                                    <WrapPanel Margin="0,3,0,0">
                                        <Ellipse Fill="{DynamicResource ChartCH1Brush}" Width="6" Height="6" Margin="0,0,2,0" VerticalAlignment="Center" />
                                        <TextBlock Text="Cont.Cur" FontSize="{DynamicResource FontSizeXS}" Foreground="{DynamicResource ChartCH1Brush}" Margin="0,0,6,0" VerticalAlignment="Center" />
                                        <Ellipse Fill="{DynamicResource ChartCH2Brush}" Width="6" Height="6" Margin="0,0,2,0" VerticalAlignment="Center" />
                                        <TextBlock Text="Tgt.Cur" FontSize="{DynamicResource FontSizeXS}" Foreground="{DynamicResource ChartCH2Brush}" VerticalAlignment="Center" />
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <!-- Group 1: Velocity -->
                            <Border BorderThickness="3,0,0,0" BorderBrush="{DynamicResource ChartCH3Brush}"
                                    Background="{DynamicResource SurfaceVariantBrush}"
                                    CornerRadius="{StaticResource Radius.SM}" Padding="6,4" Margin="0,0,0,4">
                                <StackPanel>
                                    <DockPanel>
                                        <Button DockPanel.Dock="Right" Click="BtnAutoScaleGroup_Click" Tag="1"
                                                Background="Transparent" BorderThickness="0" Padding="2" Cursor="Hand"
                                                ToolTip="Auto Scale Velocity">
                                            <materialDesign:PackIcon Kind="ArrowExpandVertical" Width="12" Height="12"
                                                                     Foreground="{DynamicResource TextSecondary}" />
                                        </Button>
                                        <TextBlock FontSize="{DynamicResource FontSizeXS}" VerticalAlignment="Center">
                                            <Run Text="Velocity" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" />
                                            <Run Text=" (rpm)" Foreground="{DynamicResource TextSecondary}" />
                                        </TextBlock>
                                    </DockPanel>
                                    <Grid Margin="0,2,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="28" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Max" FontSize="{DynamicResource FontSizeXS}" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" />
                                        <TextBox x:Name="TxtMax1" Grid.Row="0" Grid.Column="1" Text="5000" Tag="1"
                                                 FontFamily="{DynamicResource FontFamilyCode}" FontSize="{DynamicResource FontSizeXS}"
                                                 Foreground="{DynamicResource ValueHighlightBrush}"
                                                 Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderDefault}"
                                                 Padding="3,1" Margin="0,0,0,1" LostFocus="ScaleValue_LostFocus" KeyDown="ScaleValue_KeyDown" />
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Min" FontSize="{DynamicResource FontSizeXS}" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" />
                                        <TextBox x:Name="TxtMin1" Grid.Row="1" Grid.Column="1" Text="-5000" Tag="1"
                                                 FontFamily="{DynamicResource FontFamilyCode}" FontSize="{DynamicResource FontSizeXS}"
                                                 Foreground="{DynamicResource ValueHighlightBrush}"
                                                 Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderDefault}"
                                                 Padding="3,1" LostFocus="ScaleValue_LostFocus" KeyDown="ScaleValue_KeyDown" />
                                    </Grid>
                                    <WrapPanel Margin="0,3,0,0">
                                        <Ellipse Fill="{DynamicResource ChartCH3Brush}" Width="6" Height="6" Margin="0,0,2,0" VerticalAlignment="Center" />
                                        <TextBlock Text="Vel" FontSize="{DynamicResource FontSizeXS}" Foreground="{DynamicResource ChartCH3Brush}" Margin="0,0,6,0" VerticalAlignment="Center" />
                                        <Ellipse Fill="{DynamicResource ChartCH4Brush}" Width="6" Height="6" Margin="0,0,2,0" VerticalAlignment="Center" />
                                        <TextBlock Text="Tgt.Vel" FontSize="{DynamicResource FontSizeXS}" Foreground="{DynamicResource ChartCH4Brush}" VerticalAlignment="Center" />
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <!-- Group 2: Position -->
                            <Border BorderThickness="3,0,0,0" BorderBrush="{DynamicResource ChartCH5Brush}"
                                    Background="{DynamicResource SurfaceVariantBrush}"
                                    CornerRadius="{StaticResource Radius.SM}" Padding="6,4" Margin="0,0,0,4">
                                <StackPanel>
                                    <DockPanel>
                                        <Button DockPanel.Dock="Right" Click="BtnAutoScaleGroup_Click" Tag="2"
                                                Background="Transparent" BorderThickness="0" Padding="2" Cursor="Hand"
                                                ToolTip="Auto Scale Position">
                                            <materialDesign:PackIcon Kind="ArrowExpandVertical" Width="12" Height="12"
                                                                     Foreground="{DynamicResource TextSecondary}" />
                                        </Button>
                                        <TextBlock FontSize="{DynamicResource FontSizeXS}" VerticalAlignment="Center">
                                            <Run Text="Position" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" />
                                            <Run Text=" (pulse)" Foreground="{DynamicResource TextSecondary}" />
                                        </TextBlock>
                                    </DockPanel>
                                    <Grid Margin="0,2,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="28" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Max" FontSize="{DynamicResource FontSizeXS}" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" />
                                        <TextBox x:Name="TxtMax2" Grid.Row="0" Grid.Column="1" Text="12000" Tag="2"
                                                 FontFamily="{DynamicResource FontFamilyCode}" FontSize="{DynamicResource FontSizeXS}"
                                                 Foreground="{DynamicResource ValueHighlightBrush}"
                                                 Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderDefault}"
                                                 Padding="3,1" Margin="0,0,0,1" LostFocus="ScaleValue_LostFocus" KeyDown="ScaleValue_KeyDown" />
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Min" FontSize="{DynamicResource FontSizeXS}" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" />
                                        <TextBox x:Name="TxtMin2" Grid.Row="1" Grid.Column="1" Text="-12000" Tag="2"
                                                 FontFamily="{DynamicResource FontFamilyCode}" FontSize="{DynamicResource FontSizeXS}"
                                                 Foreground="{DynamicResource ValueHighlightBrush}"
                                                 Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderDefault}"
                                                 Padding="3,1" LostFocus="ScaleValue_LostFocus" KeyDown="ScaleValue_KeyDown" />
                                    </Grid>
                                    <WrapPanel Margin="0,3,0,0">
                                        <Ellipse Fill="{DynamicResource ChartCH5Brush}" Width="6" Height="6" Margin="0,0,2,0" VerticalAlignment="Center" />
                                        <TextBlock Text="Cur.Pos" FontSize="{DynamicResource FontSizeXS}" Foreground="{DynamicResource ChartCH5Brush}" Margin="0,0,6,0" VerticalAlignment="Center" />
                                        <Ellipse Fill="{DynamicResource ChartCH6Brush}" Width="6" Height="6" Margin="0,0,2,0" VerticalAlignment="Center" />
                                        <TextBlock Text="Cur.Pos2" FontSize="{DynamicResource FontSizeXS}" Foreground="{DynamicResource ChartCH6Brush}" VerticalAlignment="Center" />
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <!-- Group 3: Status -->
                            <Border BorderThickness="3,0,0,0" BorderBrush="{DynamicResource ChartCH7Brush}"
                                    Background="{DynamicResource SurfaceVariantBrush}"
                                    CornerRadius="{StaticResource Radius.SM}" Padding="6,4" Margin="0,0,0,0">
                                <StackPanel>
                                    <DockPanel>
                                        <Button DockPanel.Dock="Right" Click="BtnAutoScaleGroup_Click" Tag="3"
                                                Background="Transparent" BorderThickness="0" Padding="2" Cursor="Hand"
                                                ToolTip="Auto Scale Status">
                                            <materialDesign:PackIcon Kind="ArrowExpandVertical" Width="12" Height="12"
                                                                     Foreground="{DynamicResource TextSecondary}" />
                                        </Button>
                                        <TextBlock FontSize="{DynamicResource FontSizeXS}" VerticalAlignment="Center">
                                            <Run Text="Status" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" />
                                        </TextBlock>
                                    </DockPanel>
                                    <Grid Margin="0,2,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="28" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Max" FontSize="{DynamicResource FontSizeXS}" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" />
                                        <TextBox x:Name="TxtMax3" Grid.Row="0" Grid.Column="1" Text="500" Tag="3"
                                                 FontFamily="{DynamicResource FontFamilyCode}" FontSize="{DynamicResource FontSizeXS}"
                                                 Foreground="{DynamicResource ValueHighlightBrush}"
                                                 Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderDefault}"
                                                 Padding="3,1" Margin="0,0,0,1" LostFocus="ScaleValue_LostFocus" KeyDown="ScaleValue_KeyDown" />
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Min" FontSize="{DynamicResource FontSizeXS}" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" />
                                        <TextBox x:Name="TxtMin3" Grid.Row="1" Grid.Column="1" Text="-500" Tag="3"
                                                 FontFamily="{DynamicResource FontFamilyCode}" FontSize="{DynamicResource FontSizeXS}"
                                                 Foreground="{DynamicResource ValueHighlightBrush}"
                                                 Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderDefault}"
                                                 Padding="3,1" LostFocus="ScaleValue_LostFocus" KeyDown="ScaleValue_KeyDown" />
                                    </Grid>
                                    <WrapPanel Margin="0,3,0,0">
                                        <Ellipse Fill="{DynamicResource ChartCH7Brush}" Width="6" Height="6" Margin="0,0,2,0" VerticalAlignment="Center" />
                                        <TextBlock Text="Error" FontSize="{DynamicResource FontSizeXS}" Foreground="{DynamicResource ChartCH7Brush}" Margin="0,0,6,0" VerticalAlignment="Center" />
                                        <Ellipse Fill="{DynamicResource ChartCH8Brush}" Width="6" Height="6" Margin="0,0,2,0" VerticalAlignment="Center" />
                                        <TextBlock Text="Inpos" FontSize="{DynamicResource FontSizeXS}" Foreground="{DynamicResource ChartCH8Brush}" VerticalAlignment="Center" />
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- Scale Panel Toggle -->
                <Button x:Name="BtnToggleScale" Grid.Column="1" Click="ToggleScalePanel_Click"
                        Width="18" Background="{DynamicResource SurfaceVariantBrush}"
                        BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,0,1,0"
                        Cursor="Hand" ToolTip="Toggle Scale Panel" Padding="0">
                    <materialDesign:PackIcon x:Name="ScaleToggleIcon" Kind="ChevronLeft"
                        Width="14" Height="14" Foreground="{DynamicResource TextSecondary}" />
                </Button>

                <!-- Chart -->
                <scottPlot:WpfPlot x:Name="MonitorPlot" Grid.Column="2" />
            </Grid>

            <!-- Control Panel (toggleable) -->
            <Border x:Name="ControlPanel" Grid.Row="2"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource DividerBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="8,6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Row 0: Gauge Instruments -->
                    <UniformGrid Grid.Row="0" Columns="3" Margin="0,0,0,4">

                        <!-- Velocity Gauge -->
                        <Border Background="{DynamicResource SurfaceVariantBrush}"
                                CornerRadius="{StaticResource Radius.MD}" Padding="8,6" Margin="2">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="Velocity" FontSize="{DynamicResource FontSizeXS}"
                                           Foreground="{DynamicResource TextSecondary}"
                                           HorizontalAlignment="Center" FontWeight="SemiBold" />
                                <Canvas x:Name="VelocityGauge" Width="130" Height="72" Margin="0,2,0,0" />
                                <Grid Width="130" Margin="0,-4,0,0">
                                    <TextBlock Text="-5000" FontSize="{DynamicResource FontSizeXS}"
                                               Foreground="{DynamicResource TextSecondary}"
                                               FontFamily="{DynamicResource FontFamilyCode}"
                                               HorizontalAlignment="Left" />
                                    <TextBlock Text="0" FontSize="{DynamicResource FontSizeXS}"
                                               Foreground="{DynamicResource TextSecondary}"
                                               FontFamily="{DynamicResource FontFamilyCode}"
                                               HorizontalAlignment="Center" />
                                    <TextBlock Text="5000" FontSize="{DynamicResource FontSizeXS}"
                                               Foreground="{DynamicResource TextSecondary}"
                                               FontFamily="{DynamicResource FontFamilyCode}"
                                               HorizontalAlignment="Right" />
                                </Grid>
                                <TextBlock x:Name="TxtVelocityCur" Text="0"
                                           FontSize="{DynamicResource FontSizeLG}"
                                           FontFamily="{DynamicResource FontFamilyCode}"
                                           Foreground="{DynamicResource TextPrimary}"
                                           HorizontalAlignment="Center" FontWeight="Bold" />
                                <TextBlock Text="rpm" FontSize="{DynamicResource FontSizeXS}"
                                           Foreground="{DynamicResource TextSecondary}"
                                           HorizontalAlignment="Center" Margin="0,-2,0,2" />
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock x:Name="TxtVelocityCmd" Text="Cmd: 0"
                                               FontSize="{DynamicResource FontSizeXS}"
                                               Foreground="{DynamicResource ChartCH4Brush}"
                                               FontFamily="{DynamicResource FontFamilyCode}" Margin="0,0,10,0" />
                                    <TextBlock x:Name="TxtVelocityCurLabel" Text="Cur: 0"
                                               FontSize="{DynamicResource FontSizeXS}"
                                               Foreground="{DynamicResource ChartCH3Brush}"
                                               FontFamily="{DynamicResource FontFamilyCode}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Torque (Current) Gauge -->
                        <Border Background="{DynamicResource SurfaceVariantBrush}"
                                CornerRadius="{StaticResource Radius.MD}" Padding="8,6" Margin="2">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="Current (Torque)" FontSize="{DynamicResource FontSizeXS}"
                                           Foreground="{DynamicResource TextSecondary}"
                                           HorizontalAlignment="Center" FontWeight="SemiBold" />
                                <Canvas x:Name="TorqueGauge" Width="130" Height="72" Margin="0,2,0,0" />
                                <Grid Width="130" Margin="0,-4,0,0">
                                    <TextBlock Text="-3000" FontSize="{DynamicResource FontSizeXS}"
                                               Foreground="{DynamicResource TextSecondary}"
                                               FontFamily="{DynamicResource FontFamilyCode}"
                                               HorizontalAlignment="Left" />
                                    <TextBlock Text="0" FontSize="{DynamicResource FontSizeXS}"
                                               Foreground="{DynamicResource TextSecondary}"
                                               FontFamily="{DynamicResource FontFamilyCode}"
                                               HorizontalAlignment="Center" />
                                    <TextBlock Text="3000" FontSize="{DynamicResource FontSizeXS}"
                                               Foreground="{DynamicResource TextSecondary}"
                                               FontFamily="{DynamicResource FontFamilyCode}"
                                               HorizontalAlignment="Right" />
                                </Grid>
                                <TextBlock x:Name="TxtTorqueCur" Text="0"
                                           FontSize="{DynamicResource FontSizeLG}"
                                           FontFamily="{DynamicResource FontFamilyCode}"
                                           Foreground="{DynamicResource TextPrimary}"
                                           HorizontalAlignment="Center" FontWeight="Bold" />
                                <TextBlock Text="A" FontSize="{DynamicResource FontSizeXS}"
                                           Foreground="{DynamicResource TextSecondary}"
                                           HorizontalAlignment="Center" Margin="0,-2,0,2" />
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock x:Name="TxtTorqueCmd" Text="Cmd: 0"
                                               FontSize="{DynamicResource FontSizeXS}"
                                               Foreground="{DynamicResource ChartCH2Brush}"
                                               FontFamily="{DynamicResource FontFamilyCode}" Margin="0,0,10,0" />
                                    <TextBlock x:Name="TxtTorqueCurLabel" Text="Cur: 0"
                                               FontSize="{DynamicResource FontSizeXS}"
                                               Foreground="{DynamicResource ChartCH1Brush}"
                                               FontFamily="{DynamicResource FontFamilyCode}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Position Range Bar -->
                        <Border Background="{DynamicResource SurfaceVariantBrush}"
                                CornerRadius="{StaticResource Radius.MD}" Padding="8,6" Margin="2">
                            <StackPanel>
                                <TextBlock Text="Position" FontSize="{DynamicResource FontSizeXS}"
                                           Foreground="{DynamicResource TextSecondary}"
                                           HorizontalAlignment="Center" FontWeight="SemiBold" />
                                <Grid Margin="0,10,0,4">
                                    <Border Height="6" Background="{DynamicResource SurfaceBrush}"
                                            CornerRadius="3" VerticalAlignment="Center" Margin="8,0" />
                                    <Canvas x:Name="PositionCanvas" Height="32" Margin="8,0" ClipToBounds="True" />
                                </Grid>
                                <Grid Margin="8,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                        <TextBlock Text="Min:" FontSize="{DynamicResource FontSizeXS}"
                                                   Foreground="{DynamicResource TextSecondary}" Margin="0,0,3,0" />
                                        <TextBlock x:Name="TxtPositionMin" Text="0"
                                                   FontSize="{DynamicResource FontSizeXS}"
                                                   Foreground="{DynamicResource TextPrimary}"
                                                   FontFamily="{DynamicResource FontFamilyCode}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock x:Name="TxtPositionCurLabel" Text="Cur: 0"
                                                   FontSize="{DynamicResource FontSizeXS}"
                                                   Foreground="{DynamicResource ChartCH5Brush}"
                                                   FontFamily="{DynamicResource FontFamilyCode}" Margin="0,0,8,0" />
                                        <TextBlock x:Name="TxtPositionCmdLabel" Text="Cmd: 0"
                                                   FontSize="{DynamicResource FontSizeXS}"
                                                   Foreground="{DynamicResource ChartCH6Brush}"
                                                   FontFamily="{DynamicResource FontFamilyCode}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                                        <TextBlock Text="Max:" FontSize="{DynamicResource FontSizeXS}"
                                                   Foreground="{DynamicResource TextSecondary}" Margin="0,0,3,0" />
                                        <TextBlock x:Name="TxtPositionMax" Text="0"
                                                   FontSize="{DynamicResource FontSizeXS}"
                                                   Foreground="{DynamicResource TextPrimary}"
                                                   FontFamily="{DynamicResource FontFamilyCode}" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                    </UniformGrid>

                    <!-- Row 1: Action Buttons + Input Fields -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Action Buttons -->
                        <WrapPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Margin="2,1" Padding="4,4" Cursor="Hand" Background="{DynamicResource SuccessBrush}" Foreground="{DynamicResource TextOnPrimary}" BorderThickness="0">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Play" Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,2,0" />
                                    <TextBlock Text="Enable" FontSize="{DynamicResource FontSizeXS}" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Margin="2,1" Padding="4,4" Cursor="Hand" Background="{DynamicResource ErrorBrush}" Foreground="{DynamicResource TextOnPrimary}" BorderThickness="0">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Stop" Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,2,0" />
                                    <TextBlock Text="Disable" FontSize="{DynamicResource FontSizeXS}" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Margin="2,1" Padding="4,4" Cursor="Hand" BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1" Background="Transparent" Foreground="{DynamicResource TextPrimary}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ArrowRight" Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,2,0" Foreground="{DynamicResource SecondaryBrush}" />
                                    <TextBlock Text="Jog +" FontSize="{DynamicResource FontSizeXS}" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Margin="2,1" Padding="4,4" Cursor="Hand" BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1" Background="Transparent" Foreground="{DynamicResource TextPrimary}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ArrowLeft" Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,2,0" Foreground="{DynamicResource SecondaryBrush}" />
                                    <TextBlock Text="Jog -" FontSize="{DynamicResource FontSizeXS}" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Margin="2,1" Padding="4,4" Cursor="Hand" BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1" Background="Transparent" Foreground="{DynamicResource TextPrimary}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="AlertRemove" Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,2,0" Foreground="{DynamicResource WarningBrush}" />
                                    <TextBlock Text="Clr Fault" FontSize="{DynamicResource FontSizeXS}" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Margin="2,1" Padding="4,4" Cursor="Hand" BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1" Background="Transparent" Foreground="{DynamicResource TextPrimary}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Restart" Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,2,0" Foreground="{DynamicResource SecondaryBrush}" />
                                    <TextBlock Text="Reset" FontSize="{DynamicResource FontSizeXS}" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Margin="2,1" Padding="4,4" Cursor="Hand" BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1" Background="Transparent" Foreground="{DynamicResource TextPrimary}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="PlusCircleOutline" Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,2,0" Foreground="{DynamicResource PrimaryBrush}" />
                                    <TextBlock Text="Tgt Pos+" FontSize="{DynamicResource FontSizeXS}" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Margin="2,1" Padding="4,4" Cursor="Hand" BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1" Background="Transparent" Foreground="{DynamicResource TextPrimary}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="MinusCircleOutline" Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,2,0" Foreground="{DynamicResource PrimaryBrush}" />
                                    <TextBlock Text="Tgt Pos-" FontSize="{DynamicResource FontSizeXS}" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Margin="2,1" Padding="4,4" Cursor="Hand" Background="{DynamicResource PrimaryBrush}" Foreground="{DynamicResource TextOnPrimary}" BorderThickness="0">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Numeric0CircleOutline" Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,2,0" />
                                    <TextBlock Text="Zero Set" FontSize="{DynamicResource FontSizeXS}" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Margin="2,1" Padding="4,4" Cursor="Hand" Background="{DynamicResource PrimaryBrush}" Foreground="{DynamicResource TextOnPrimary}" BorderThickness="0">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="HomeCircleOutline" Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,2,0" />
                                    <TextBlock Text="Move Zero" FontSize="{DynamicResource FontSizeXS}" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </WrapPanel>

                        <!-- Separator -->
                        <Rectangle Grid.Column="1" Width="1" Fill="{DynamicResource DividerBrush}" Margin="8,0" />

                        <!-- Input Fields -->
                        <Grid Grid.Column="2" VerticalAlignment="Center" MinWidth="160">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Target Speed :" Foreground="{DynamicResource TextSecondary}" FontSize="{DynamicResource FontSizeXS}" VerticalAlignment="Center" Margin="0,0,6,3" />
                            <TextBox Grid.Row="0" Grid.Column="1" Text="0" Background="{DynamicResource SurfaceVariantBrush}" Foreground="{DynamicResource ValueHighlightBrush}" BorderBrush="{DynamicResource BorderDefault}" FontFamily="{DynamicResource FontFamilyCode}" FontSize="{DynamicResource FontSizeXS}" Padding="5,2" Margin="0,0,0,3" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Target Pos :" Foreground="{DynamicResource TextSecondary}" FontSize="{DynamicResource FontSizeXS}" VerticalAlignment="Center" Margin="0,0,6,3" />
                            <TextBox Grid.Row="1" Grid.Column="1" Text="0" Background="{DynamicResource SurfaceVariantBrush}" Foreground="{DynamicResource ValueHighlightBrush}" BorderBrush="{DynamicResource BorderDefault}" FontFamily="{DynamicResource FontFamilyCode}" FontSize="{DynamicResource FontSizeXS}" Padding="5,2" Margin="0,0,0,3" />
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Current Limit :" Foreground="{DynamicResource TextSecondary}" FontSize="{DynamicResource FontSizeXS}" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBox Grid.Row="2" Grid.Column="1" Text="100" Background="{DynamicResource SurfaceVariantBrush}" Foreground="{DynamicResource ValueHighlightBrush}" BorderBrush="{DynamicResource BorderDefault}" FontFamily="{DynamicResource FontFamilyCode}" FontSize="{DynamicResource FontSizeXS}" Padding="5,2" />
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

            <!-- Status bar -->
            <Border x:Name="ChartStatusBar" Grid.Row="3" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderDefault}" BorderThickness="0,1,0,0" Padding="6,2">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="8 CH | 10 kHz | " Foreground="{DynamicResource TextSecondary}" FontSize="{DynamicResource FontSizeXS}" />
                    <TextBlock x:Name="TxtStatus" Text="Stopped" Foreground="{DynamicResource SecondaryBrush}" FontSize="{DynamicResource FontSizeXS}" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Favorites Toggle -->
        <Button x:Name="BtnToggleFavorites" Grid.Column="2" Click="ToggleFavoritesPanel_Click"
                Width="18" Background="{DynamicResource SurfaceVariantBrush}"
                BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,0,1,0"
                Cursor="Hand" ToolTip="Toggle Favorites" Padding="0">
            <materialDesign:PackIcon x:Name="FavoritesToggleIcon" Kind="ChevronRight"
                Width="14" Height="14" Foreground="{DynamicResource WarningBrush}" />
        </Button>

        <!-- ══════════════════════════════════════════ -->
        <!--  RIGHT: Favorites                          -->
        <!-- ══════════════════════════════════════════ -->
        <Border x:Name="FavoritesContent" Grid.Column="3"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource DividerBrush}"
                BorderThickness="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Header with clear-all button -->
                <Border Grid.Row="0" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,0,0,1" Padding="8,5">
                    <DockPanel>
                        <TextBlock x:Name="FavCountText" DockPanel.Dock="Right"
                                   FontSize="{DynamicResource FontSizeXS}"
                                   Foreground="{DynamicResource TextSecondary}"
                                   VerticalAlignment="Center" />
                        <!-- Clear-all star button -->
                        <Button DockPanel.Dock="Left" Click="ClearAllFavorites_Click"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" Padding="2" Margin="0,0,4,0"
                                ToolTip="Clear all favorites">
                            <materialDesign:PackIcon Kind="Star" Width="14" Height="14"
                                                     Foreground="{DynamicResource WarningBrush}" />
                        </Button>
                        <TextBlock Text="Favorites"
                                   FontSize="{DynamicResource FontSizeSM}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource WarningBrush}"
                                   VerticalAlignment="Center" />
                    </DockPanel>
                </Border>

                <ListBox x:Name="FavoritesListBox" Grid.Row="1"
                         Background="Transparent" BorderThickness="0" Padding="4,2"
                         AllowDrop="True"
                         KeyDown="FavList_KeyDown"
                         PreviewMouseLeftButtonDown="FavList_PreviewMouseLeftButtonDown"
                         PreviewMouseMove="FavList_PreviewMouseMove"
                         Drop="FavList_Drop"
                         DragOver="FavList_DragOver">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
                            <Setter Property="Padding" Value="5,3" />
                            <Setter Property="Margin" Value="0,1" />
                            <Setter Property="Cursor" Value="Hand" />
                            <Setter Property="AllowDrop" Value="True" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                Padding="{TemplateBinding Padding}"
                                                CornerRadius="{StaticResource Radius.SM}"
                                                BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SurfaceVariantBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SelectedRowBrush}" />
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="35" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="45" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding ShortNumber}" FontFamily="{DynamicResource FontFamilyCode}" FontSize="{DynamicResource FontSizeXS}" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="1" Text="{Binding Name}" FontFamily="{DynamicResource FontFamilyCode}" FontSize="{DynamicResource FontSizeXS}" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                <TextBox Grid.Column="2" Text="{Binding Value, UpdateSourceTrigger=LostFocus}"
                                         FontFamily="{DynamicResource FontFamilyCode}" FontSize="{DynamicResource FontSizeXS}"
                                         Foreground="{DynamicResource ValueHighlightBrush}" FontWeight="SemiBold"
                                         Background="Transparent" BorderThickness="0"
                                         VerticalAlignment="Center" HorizontalAlignment="Right"
                                         Padding="2,0" MinWidth="30" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
    </Grid>
</UserControl>
