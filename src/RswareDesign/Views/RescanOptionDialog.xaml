<Window x:Class="RswareDesign.Views.RescanOptionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="{DynamicResource loc.ribbon.btn.rescanoption}"
        Width="600" Height="480"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="Transparent"
        TextElement.Foreground="{DynamicResource TextPrimary}"
        TextElement.FontFamily="{DynamicResource FontFamilyUI}"
        TextElement.FontSize="{DynamicResource FontSizeMD}">

    <Border Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource BorderDefault}"
            BorderThickness="1"
            CornerRadius="{StaticResource Radius.LG}"
            Margin="8"
            Effect="{StaticResource MaterialDesignShadowDepth3}">
        <Grid Margin="{StaticResource Padding.Dialog}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                <materialDesign:PackIcon Kind="CogRefresh"
                                         Width="{StaticResource Size.IconXL}"
                                         Height="{StaticResource Size.IconXL}"
                                         Foreground="{DynamicResource PrimaryBrush}"
                                         VerticalAlignment="Center"
                                         Margin="{StaticResource Margin.Inline}" />
                <TextBlock Text="{DynamicResource loc.ribbon.btn.rescanoption}"
                           FontSize="{DynamicResource FontSizeLG}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimary}"
                           VerticalAlignment="Center" />
            </StackPanel>

            <!-- Content: Left=Models, Right=Channels -->
            <Grid Grid.Row="1" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Left: Drive Models -->
                <Border Grid.Column="0"
                        Background="{DynamicResource SurfaceVariantBrush}"
                        CornerRadius="{StaticResource Radius.MD}"
                        Padding="12,8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="{DynamicResource loc.rescan.drivemodel}"
                                   FontSize="{DynamicResource FontSizeSM}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondary}"
                                   Margin="0,0,0,6" />

                        <!-- Select All -->
                        <CheckBox Grid.Row="1" x:Name="ChkSelectAll"
                                  Content="{DynamicResource loc.rescan.selectall}"
                                  IsChecked="True"
                                  FontSize="{DynamicResource FontSizeSM}"
                                  Foreground="{DynamicResource PrimaryBrush}"
                                  FontWeight="SemiBold"
                                  Margin="0,0,0,4"
                                  Click="ChkSelectAll_Click" />

                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="ModelCheckList" />
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- Right: Channel Range -->
                <Border Grid.Column="2"
                        Background="{DynamicResource SurfaceVariantBrush}"
                        CornerRadius="{StaticResource Radius.MD}"
                        Padding="12,8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="{DynamicResource loc.rescan.channel}"
                                   FontSize="{DynamicResource FontSizeSM}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondary}"
                                   Margin="0,0,0,6" />

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="ChannelList" />
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="{DynamicResource loc.btn.cancel}"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Margin="{StaticResource Margin.Inline}"
                        Click="BtnCancel_Click" />
                <Button Content="{DynamicResource loc.btn.ok}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="{DynamicResource PrimaryBrush}"
                        BorderThickness="0"
                        Click="BtnConfirm_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
