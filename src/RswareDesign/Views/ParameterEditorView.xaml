<UserControl x:Class="RswareDesign.Views.ParameterEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{DynamicResource SurfaceBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Parameter DataGrid -->
        <DataGrid Grid.Row="0"
                  ItemsSource="{Binding Parameters}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserReorderColumns="False"
                  CanUserSortColumns="True"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  RowHeight="{DynamicResource Size.GridRowHeight}"
                  ColumnHeaderHeight="{DynamicResource Size.GridHeaderHeight}"
                  Background="{DynamicResource SurfaceBrush}"
                  Foreground="{DynamicResource TextPrimary}"
                  BorderThickness="0"
                  FontFamily="{DynamicResource FontFamilyCode}"
                  FontSize="{DynamicResource FontSizeSM}"
                  HorizontalGridLinesBrush="{DynamicResource DividerBrush}"
                  AlternatingRowBackground="{DynamicResource GridAlternatingRowBrush}">

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="{DynamicResource GridHeaderBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                    <Setter Property="FontFamily" Value="{DynamicResource FontFamilyUI}" />
                    <Setter Property="FontSize" Value="{DynamicResource FontSizeSM}" />
                    <Setter Property="Padding" Value="{StaticResource Padding.GridCell}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
                    <Setter Property="BorderThickness" Value="0,0,1,1" />
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="Padding" Value="{StaticResource Padding.GridCell}" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="DataGridCell">
                                <Border Padding="{TemplateBinding Padding}"
                                        Background="{TemplateBinding Background}">
                                    <ContentPresenter VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{DynamicResource SelectedRowBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.CellStyle>

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="Transparent" />
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{DynamicResource SelectedRowBrush}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource SurfaceVariantBrush}" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="FT NUM"
                                    Binding="{Binding FtNumber}"
                                    IsReadOnly="True"
                                    Width="80" />
                <DataGridTextColumn Header="PARAMETER"
                                    Binding="{Binding Name}"
                                    IsReadOnly="True"
                                    Width="*" />
                <DataGridTextColumn Header="VALUE"
                                    Binding="{Binding Value}"
                                    Width="120">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource SecondaryBrush}" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="UNITS"
                                    Binding="{Binding Unit}"
                                    IsReadOnly="True"
                                    Width="100" />
                <DataGridTextColumn Header="DEFAULT"
                                    Binding="{Binding Default}"
                                    IsReadOnly="True"
                                    Width="100" />
                <DataGridTextColumn Header="MIN"
                                    Binding="{Binding Min}"
                                    IsReadOnly="True"
                                    Width="100" />
                <DataGridTextColumn Header="MAX"
                                    Binding="{Binding Max}"
                                    IsReadOnly="True"
                                    Width="100" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Bottom Checkboxes -->
        <Border Grid.Row="1"
                Background="{DynamicResource SurfaceVariantBrush}"
                BorderBrush="{DynamicResource DividerBrush}"
                BorderThickness="0,1,0,0"
                Padding="{StaticResource Padding.ToolWindow}">
            <StackPanel Orientation="Horizontal">
                <CheckBox Content="Show Helps"
                          IsChecked="{Binding ShowHelps}"
                          Foreground="{DynamicResource TextSecondary}"
                          Margin="0,0,16,0" />
                <CheckBox Content="Show Status"
                          IsChecked="{Binding ShowStatus}"
                          Foreground="{DynamicResource TextSecondary}"
                          Margin="0,0,16,0" />
                <CheckBox Content="Show Commands"
                          IsChecked="{Binding ShowCommands}"
                          Foreground="{DynamicResource TextSecondary}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
