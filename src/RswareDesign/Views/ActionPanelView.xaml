<UserControl x:Class="RswareDesign.Views.ActionPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{DynamicResource SurfaceBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="{StaticResource Padding.ToolWindow}">

            <!-- Read All -->
            <Button Height="{DynamicResource Size.ActionButtonHeight}"
                    Width="{DynamicResource Size.ActionButtonWidth}"
                    Margin="{StaticResource Margin.ListItem}"
                    Background="{DynamicResource PrimaryBrush}"
                    Foreground="{DynamicResource PrimaryForegroundBrush}"
                    BorderThickness="0"
                    Cursor="Hand">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="DatabaseArrowDown"
                                             Width="{DynamicResource Size.IconSM}"
                                             Height="{DynamicResource Size.IconSM}"
                                             VerticalAlignment="Center"
                                             Margin="0,0,6,0" />
                    <TextBlock Text="Read All"
                               VerticalAlignment="Center"
                               FontSize="{DynamicResource FontSizeSM}" />
                </StackPanel>
            </Button>

            <!-- Write All -->
            <Button Height="{DynamicResource Size.ActionButtonHeight}"
                    Width="{DynamicResource Size.ActionButtonWidth}"
                    Margin="{StaticResource Margin.ListItem}"
                    Background="{DynamicResource PrimaryBrush}"
                    Foreground="{DynamicResource PrimaryForegroundBrush}"
                    BorderThickness="0"
                    Cursor="Hand">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="DatabaseArrowUp"
                                             Width="{DynamicResource Size.IconSM}"
                                             Height="{DynamicResource Size.IconSM}"
                                             VerticalAlignment="Center"
                                             Margin="0,0,6,0" />
                    <TextBlock Text="Write All"
                               VerticalAlignment="Center"
                               FontSize="{DynamicResource FontSizeSM}" />
                </StackPanel>
            </Button>

            <!-- Save to Flash -->
            <Button Height="{DynamicResource Size.ActionButtonHeight}"
                    Width="{DynamicResource Size.ActionButtonWidth}"
                    Margin="{StaticResource Margin.ListItem}"
                    Command="{Binding SaveParametersCommand}"
                    Background="{DynamicResource SecondaryBrush}"
                    Foreground="{DynamicResource BackgroundBrush}"
                    BorderThickness="0"
                    Cursor="Hand">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="ContentSaveAll"
                                             Width="{DynamicResource Size.IconSM}"
                                             Height="{DynamicResource Size.IconSM}"
                                             VerticalAlignment="Center"
                                             Margin="0,0,6,0" />
                    <TextBlock Text="Save to Flash"
                               VerticalAlignment="Center"
                               FontSize="{DynamicResource FontSizeSM}" />
                </StackPanel>
            </Button>

            <Separator Margin="0,8" Background="{DynamicResource DividerBrush}" />

            <!-- Compare -->
            <Button Height="{DynamicResource Size.ActionButtonHeight}"
                    Width="{DynamicResource Size.ActionButtonWidth}"
                    Margin="{StaticResource Margin.ListItem}"
                    Background="{DynamicResource SurfaceVariantBrush}"
                    Foreground="{DynamicResource TextPrimary}"
                    BorderBrush="{DynamicResource BorderDefault}"
                    BorderThickness="1"
                    Cursor="Hand">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="CompareHorizontal"
                                             Width="{DynamicResource Size.IconSM}"
                                             Height="{DynamicResource Size.IconSM}"
                                             VerticalAlignment="Center"
                                             Margin="0,0,6,0" />
                    <TextBlock Text="Compare"
                               VerticalAlignment="Center"
                               FontSize="{DynamicResource FontSizeSM}" />
                </StackPanel>
            </Button>

            <!-- Export -->
            <Button Height="{DynamicResource Size.ActionButtonHeight}"
                    Width="{DynamicResource Size.ActionButtonWidth}"
                    Margin="{StaticResource Margin.ListItem}"
                    Background="{DynamicResource SurfaceVariantBrush}"
                    Foreground="{DynamicResource TextPrimary}"
                    BorderBrush="{DynamicResource BorderDefault}"
                    BorderThickness="1"
                    Cursor="Hand">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Export"
                                             Width="{DynamicResource Size.IconSM}"
                                             Height="{DynamicResource Size.IconSM}"
                                             VerticalAlignment="Center"
                                             Margin="0,0,6,0" />
                    <TextBlock Text="Export"
                               VerticalAlignment="Center"
                               FontSize="{DynamicResource FontSizeSM}" />
                </StackPanel>
            </Button>

            <!-- Revert -->
            <Button Height="{DynamicResource Size.ActionButtonHeight}"
                    Width="{DynamicResource Size.ActionButtonWidth}"
                    Margin="{StaticResource Margin.ListItem}"
                    Command="{Binding RevertParametersCommand}"
                    Background="{DynamicResource SurfaceVariantBrush}"
                    Foreground="{DynamicResource TextPrimary}"
                    BorderBrush="{DynamicResource BorderDefault}"
                    BorderThickness="1"
                    Cursor="Hand">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="UndoVariant"
                                             Width="{DynamicResource Size.IconSM}"
                                             Height="{DynamicResource Size.IconSM}"
                                             VerticalAlignment="Center"
                                             Margin="0,0,6,0" />
                    <TextBlock Text="Revert"
                               VerticalAlignment="Center"
                               FontSize="{DynamicResource FontSizeSM}" />
                </StackPanel>
            </Button>

        </StackPanel>
    </ScrollViewer>
</UserControl>
