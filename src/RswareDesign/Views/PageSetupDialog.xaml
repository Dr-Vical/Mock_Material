<Window x:Class="RswareDesign.Views.PageSetupDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="{DynamicResource loc.ribbon.btn.pagesetup}"
        Width="520" Height="580"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="Transparent"
        TextElement.Foreground="{DynamicResource TextPrimary}"
        TextElement.FontFamily="{DynamicResource FontFamilyUI}"
        TextElement.FontSize="{DynamicResource FontSizeMD}">

    <Border Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource RSBlueBrush}"
            BorderThickness="2"
            CornerRadius="{StaticResource Radius.LG}"
            Margin="8"
            Effect="{StaticResource MaterialDesignShadowDepth3}">
        <Grid Margin="{StaticResource Padding.Dialog}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                <materialDesign:PackIcon Kind="FileDocumentEdit"
                                         Width="{StaticResource Size.IconXL}"
                                         Height="{StaticResource Size.IconXL}"
                                         Foreground="{DynamicResource PrimaryBrush}"
                                         VerticalAlignment="Center"
                                         Margin="{StaticResource Margin.Inline}" />
                <TextBlock Text="{DynamicResource loc.ribbon.btn.pagesetup}"
                           FontSize="{DynamicResource FontSizeLG}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimary}"
                           VerticalAlignment="Center" />
            </StackPanel>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,12">
                <StackPanel>

                    <!-- ═══ Document Header ═══ -->
                    <TextBlock Text="{DynamicResource loc.pagesetup.header}"
                               FontSize="{DynamicResource FontSizeSM}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondary}"
                               Margin="0,0,0,6" />

                    <Border Background="{DynamicResource SurfaceVariantBrush}"
                            CornerRadius="{StaticResource Radius.MD}"
                            Padding="12,8" Margin="0,0,0,12">
                        <StackPanel>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{DynamicResource loc.pagesetup.title}"
                                           Foreground="{DynamicResource TextSecondary}"
                                           VerticalAlignment="Center" />
                                <TextBox x:Name="TxtDocTitle" Grid.Column="1"
                                         materialDesign:HintAssist.Hint="Document Title"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         FontSize="{DynamicResource FontSizeSM}"
                                         Padding="6,4" />
                            </Grid>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{DynamicResource loc.pagesetup.company}"
                                           Foreground="{DynamicResource TextSecondary}"
                                           VerticalAlignment="Center" />
                                <TextBox x:Name="TxtCompany" Grid.Column="1"
                                         materialDesign:HintAssist.Hint="Company Name"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         FontSize="{DynamicResource FontSizeSM}"
                                         Padding="6,4" />
                            </Grid>
                            <CheckBox x:Name="ChkIncludeDate" Content="{DynamicResource loc.pagesetup.includedate}"
                                      IsChecked="True" Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- ═══ Drive Info ═══ -->
                    <TextBlock Text="{DynamicResource loc.pagesetup.driveinfo}"
                               FontSize="{DynamicResource FontSizeSM}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondary}"
                               Margin="0,0,0,6" />

                    <Border Background="{DynamicResource SurfaceVariantBrush}"
                            CornerRadius="{StaticResource Radius.MD}"
                            Padding="12,8" Margin="0,0,0,12">
                        <StackPanel>
                            <CheckBox x:Name="ChkDriveModel" Content="{DynamicResource loc.pagesetup.drivemodel}"
                                      IsChecked="True" Margin="0,2" />
                            <CheckBox x:Name="ChkFirmware" Content="{DynamicResource loc.pagesetup.firmware}"
                                      IsChecked="True" Margin="0,2" />
                            <CheckBox x:Name="ChkConnection" Content="{DynamicResource loc.pagesetup.connection}"
                                      IsChecked="True" Margin="0,2" />
                        </StackPanel>
                    </Border>

                    <!-- ═══ Print Content ═══ -->
                    <TextBlock Text="{DynamicResource loc.pagesetup.content}"
                               FontSize="{DynamicResource FontSizeSM}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondary}"
                               Margin="0,0,0,6" />

                    <Border Background="{DynamicResource SurfaceVariantBrush}"
                            CornerRadius="{StaticResource Radius.MD}"
                            Padding="12,8" Margin="0,0,0,12">
                        <StackPanel>
                            <CheckBox x:Name="ChkAllParams" Content="{DynamicResource loc.pagesetup.allparams}"
                                      IsChecked="True" Margin="0,2" />
                            <CheckBox x:Name="ChkModifiedOnly" Content="{DynamicResource loc.pagesetup.modifiedonly}"
                                      IsChecked="False" Margin="16,2,0,2" />
                            <CheckBox x:Name="ChkFavorites" Content="{DynamicResource loc.pagesetup.favorites}"
                                      IsChecked="False" Margin="0,2" />
                            <CheckBox x:Name="ChkFaults" Content="{DynamicResource loc.pagesetup.faults}"
                                      IsChecked="False" Margin="0,2" />
                            <CheckBox x:Name="ChkMonitorData" Content="{DynamicResource loc.pagesetup.monitor}"
                                      IsChecked="False" Margin="0,2" />
                        </StackPanel>
                    </Border>

                    <!-- ═══ Header / Footer ═══ -->
                    <TextBlock Text="{DynamicResource loc.pagesetup.headerfooter}"
                               FontSize="{DynamicResource FontSizeSM}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondary}"
                               Margin="0,0,0,6" />

                    <Border Background="{DynamicResource SurfaceVariantBrush}"
                            CornerRadius="{StaticResource Radius.MD}"
                            Padding="12,8" Margin="0,0,0,12">
                        <StackPanel>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{DynamicResource loc.pagesetup.headertext}"
                                           Foreground="{DynamicResource TextSecondary}"
                                           VerticalAlignment="Center" />
                                <TextBox x:Name="TxtHeader" Grid.Column="1"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         FontSize="{DynamicResource FontSizeSM}"
                                         Padding="6,4" />
                            </Grid>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{DynamicResource loc.pagesetup.footertext}"
                                           Foreground="{DynamicResource TextSecondary}"
                                           VerticalAlignment="Center" />
                                <TextBox x:Name="TxtFooter" Grid.Column="1"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         FontSize="{DynamicResource FontSizeSM}"
                                         Padding="6,4" />
                            </Grid>
                            <CheckBox x:Name="ChkPageNumbers" Content="{DynamicResource loc.pagesetup.pagenumbers}"
                                      IsChecked="True" Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- ═══ Margins ═══ -->
                    <TextBlock Text="{DynamicResource loc.pagesetup.margins}"
                               FontSize="{DynamicResource FontSizeSM}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondary}"
                               Margin="0,0,0,6" />

                    <Border Background="{DynamicResource SurfaceVariantBrush}"
                            CornerRadius="{StaticResource Radius.MD}"
                            Padding="12,8" Margin="0,0,0,4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                <TextBlock Text="{DynamicResource loc.pagesetup.margin.top}"
                                           FontSize="{DynamicResource FontSizeXS}"
                                           Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,2" />
                                <TextBox x:Name="TxtMarginTop" Text="20"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         FontSize="{DynamicResource FontSizeSM}"
                                         Padding="4,2" HorizontalContentAlignment="Center" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,6,0">
                                <TextBlock Text="{DynamicResource loc.pagesetup.margin.bottom}"
                                           FontSize="{DynamicResource FontSizeXS}"
                                           Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,2" />
                                <TextBox x:Name="TxtMarginBottom" Text="20"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         FontSize="{DynamicResource FontSizeSM}"
                                         Padding="4,2" HorizontalContentAlignment="Center" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="0,0,6,0">
                                <TextBlock Text="{DynamicResource loc.pagesetup.margin.left}"
                                           FontSize="{DynamicResource FontSizeXS}"
                                           Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,2" />
                                <TextBox x:Name="TxtMarginLeft" Text="15"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         FontSize="{DynamicResource FontSizeSM}"
                                         Padding="4,2" HorizontalContentAlignment="Center" />
                            </StackPanel>
                            <StackPanel Grid.Column="3">
                                <TextBlock Text="{DynamicResource loc.pagesetup.margin.right}"
                                           FontSize="{DynamicResource FontSizeXS}"
                                           Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,2" />
                                <TextBox x:Name="TxtMarginRight" Text="15"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         FontSize="{DynamicResource FontSizeSM}"
                                         Padding="4,2" HorizontalContentAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- Buttons -->
            <Grid Grid.Row="2">
                <Button Content="{DynamicResource loc.pagesetup.preview}"
                        HorizontalAlignment="Left"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        BorderBrush="{DynamicResource RSBlueBrush}"
                        Foreground="{DynamicResource PrimaryBrush}"
                        Click="BtnPreview_Click" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="{DynamicResource loc.btn.cancel}"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Margin="{StaticResource Margin.Inline}"
                            Click="BtnCancel_Click" />
                    <Button Content="{DynamicResource loc.btn.ok}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="{DynamicResource PrimaryBrush}"
                            BorderThickness="0"
                            Click="BtnConfirm_Click" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
